package space.kernel

// Darwin personality (Mach + BSD subset demo only).
// Honest: not full XNU. Maps classic BSD/xnu syscall numbers onto Space VFS/process.
// Userland OS personality on Darwin is mostly BSD syscalls (syscalls.master), not raw Mach
// for files/process. Space follows that: BSD numbers → vfs-*/fs-*/proc-signal.
//
// Classic BSD/xnu numbers used here (FreeBSD-leaning where Darwin conflicts):
//   exit=1, fork=2, read=3, write=4, open=5, close=6, wait4=7 (FreeBSD; Darwin 199=lseek),
//   unlink=10, chdir=12, getpid=20, getuid=24, geteuid=25, recvfrom=29, access=33, kill=37,
//   dup=41, pipe=42, execve=59, socket=97, connect=98, sendto=133, rename=128,
//   mkdir=136, rmdir=137, stat=188, fstat=189, getcwd=192, mmap=197, lseek=199, munmap=73
// Open flags: BSD/Darwin O_CREAT=0x200, O_TRUNC=0x400 (mapped onto VFS-O-*).
// Optional Mach stubs: task_self trap 0x1000 → 1; mach_msg 0x1001 → -1.
// Pipe lite: max 4 pipes, 4KB ring; vfs fd type field (+24) = 2, pipe idx at +8.

const DARWIN-SYS-EXIT = 1
const DARWIN-SYS-FORK = 2
const DARWIN-SYS-READ = 3
const DARWIN-SYS-WRITE = 4
const DARWIN-SYS-OPEN = 5
const DARWIN-SYS-CLOSE = 6
const DARWIN-SYS-WAIT4 = 7
const DARWIN-SYS-UNLINK = 10
const DARWIN-SYS-CHDIR = 12
const DARWIN-SYS-GETPID = 20
const DARWIN-SYS-GETUID = 24
const DARWIN-SYS-GETEUID = 25
const DARWIN-SYS-RECVFROM = 29
const DARWIN-SYS-ACCESS = 33
const DARWIN-SYS-KILL = 37
const DARWIN-SYS-DUP = 41
const DARWIN-SYS-PIPE = 42
const DARWIN-SYS-EXECVE = 59
const DARWIN-SYS-MUNMAP = 73
const DARWIN-SYS-SOCKET = 97
const DARWIN-SYS-CONNECT = 98
const DARWIN-SYS-RENAME = 128
const DARWIN-SYS-SENDTO = 133
const DARWIN-SYS-MKDIR = 136
const DARWIN-SYS-RMDIR = 137
const DARWIN-SYS-STAT = 188
const DARWIN-SYS-FSTAT = 189
const DARWIN-SYS-GETCWD = 192
const DARWIN-SYS-MMAP = 197
const DARWIN-SYS-LSEEK = 199
const DARWIN-SEEK-SET = 0
const DARWIN-STAT-SIZE = 144
const DARWIN-STAT-OFF-SIZE = 48

// BSD/Darwin open flags (not Linux).
const DARWIN-O-RDONLY = 0
const DARWIN-O-WRONLY = 1
const DARWIN-O-RDWR = 2
const DARWIN-O-CREAT = 0x200
const DARWIN-O-TRUNC = 0x400

// BSD socket types (match netstack SOCK-STREAM/DGRAM).
const DARWIN-SOCK-STREAM = 1
const DARWIN-SOCK-DGRAM = 2
const DARWIN-AF-INET = 2

// Optional Mach trap stubs (not real MIG/IPC).
const DARWIN-MACH-TASK-SELF = 0x1000
const DARWIN-MACH-MSG = 0x1001

const DARWIN-ESRCH = -3
const DARWIN-EBADF = -9
const DARWIN-ENOENT = -2
const DARWIN-ENOSYS = -38
const DARWIN-ENOMEM = -12

// Pipe side-table: slot = used|buf|head|count|r_open|w_open (48 bytes).
const DARWIN-PIPE-MAX = 4
const DARWIN-PIPE-CAP = 4096
const DARWIN-PIPE-SLOT = 48
const DARWIN-PIPE-OFF-USED = 0
const DARWIN-PIPE-OFF-BUF = 8
const DARWIN-PIPE-OFF-HEAD = 16
const DARWIN-PIPE-OFF-COUNT = 24
const DARWIN-PIPE-OFF-ROPEN = 32
const DARWIN-PIPE-OFF-WOPEN = 40
const DARWIN-FD-TYPE-PIPE = 2
const DARWIN-PIPE-END-READ = 0
const DARWIN-PIPE-END-WRITE = 1

var darwin-ready: Int = 0
var darwin-pipe-table: Int = 0

fn darwin-pipe-table-init() -> void {
  if darwin-pipe-table != 0 {
    return
  }
  darwin-pipe-table = alloc(DARWIN-PIPE-MAX * DARWIN-PIPE-SLOT)
  let i = 0
  while i < DARWIN-PIPE-MAX {
    let base = darwin-pipe-table + i * DARWIN-PIPE-SLOT
    store64(base + DARWIN-PIPE-OFF-USED, 0)
    store64(base + DARWIN-PIPE-OFF-BUF, 0)
    store64(base + DARWIN-PIPE-OFF-HEAD, 0)
    store64(base + DARWIN-PIPE-OFF-COUNT, 0)
    store64(base + DARWIN-PIPE-OFF-ROPEN, 0)
    store64(base + DARWIN-PIPE-OFF-WOPEN, 0)
    i = i + 1
  }
  return
}

fn darwin-init() -> void {
  if darwin-ready != 0 {
    return
  }
  if vfs-fd-table == 0 {
    vfs-init()
  }
  darwin-pipe-table-init()
  darwin-ready = 1
  return
}

// Map BSD/Darwin open flags onto Space VFS flags (Linux-shaped bits under the hood).
fn darwin-map-open-flags(flags: Int) -> Int {
  let vf = flags & 3
  if (flags & DARWIN-O-CREAT) != 0 {
    vf = vf | VFS-O-CREAT
  }
  return vf
}

fn darwin-fd-is-pipe(fd: Int) -> Int {
  if fd < 3 {
    return 0
  }
  if vfs-fd-valid(fd) == 0 {
    return 0
  }
  if load64(vfs-fd-table + fd * 32 + 24) == DARWIN-FD-TYPE-PIPE {
    return 1
  }
  return 0
}

fn darwin-pipe-slot(fd: Int) -> Int {
  return load64(vfs-fd-table + fd * 32 + 8)
}

fn darwin-pipe-end(fd: Int) -> Int {
  return load64(vfs-fd-table + fd * 32 + 16)
}

fn darwin-pipe-release(idx: Int, end: Int) -> void {
  if idx < 0 || idx >= DARWIN-PIPE-MAX {
    return
  }
  let base = darwin-pipe-table + idx * DARWIN-PIPE-SLOT
  if load64(base + DARWIN-PIPE-OFF-USED) == 0 {
    return
  }
  if end == DARWIN-PIPE-END-READ {
    store64(base + DARWIN-PIPE-OFF-ROPEN, 0)
  } else {
    store64(base + DARWIN-PIPE-OFF-WOPEN, 0)
  }
  if load64(base + DARWIN-PIPE-OFF-ROPEN) == 0 {
    if load64(base + DARWIN-PIPE-OFF-WOPEN) == 0 {
      store64(base + DARWIN-PIPE-OFF-USED, 0)
      store64(base + DARWIN-PIPE-OFF-BUF, 0)
      store64(base + DARWIN-PIPE-OFF-HEAD, 0)
      store64(base + DARWIN-PIPE-OFF-COUNT, 0)
    }
  }
  return
}

fn darwin-sys-open(pathname: Int, flags: Int, mode: Int) -> Int {
  return vfs-open(pathname, darwin-map-open-flags(flags))
}

fn darwin-sys-close(fd: Int) -> Int {
  if darwin-fd-is-pipe(fd) != 0 {
    let idx = darwin-pipe-slot(fd)
    let end = darwin-pipe-end(fd)
    darwin-pipe-release(idx, end)
    vfs-fd-clear(fd)
    return 0
  }
  return vfs-close(fd)
}

fn darwin-pipe-read(fd: Int, buf: Int, count: Int) -> Int {
  if count <= 0 {
    return 0
  }
  if darwin-pipe-end(fd) != DARWIN-PIPE-END-READ {
    return DARWIN-EBADF
  }
  let idx = darwin-pipe-slot(fd)
  if idx < 0 || idx >= DARWIN-PIPE-MAX {
    return DARWIN-EBADF
  }
  let base = darwin-pipe-table + idx * DARWIN-PIPE-SLOT
  if load64(base + DARWIN-PIPE-OFF-USED) == 0 {
    return DARWIN-EBADF
  }
  let n = load64(base + DARWIN-PIPE-OFF-COUNT)
  if n == 0 {
    if load64(base + DARWIN-PIPE-OFF-WOPEN) == 0 {
      return 0
    }
    return 0
  }
  let take = count
  if take > n {
    take = n
  }
  let pbuf = load64(base + DARWIN-PIPE-OFF-BUF)
  let head = load64(base + DARWIN-PIPE-OFF-HEAD)
  let i = 0
  while i < take {
    store8(buf + i, load8(pbuf + head))
    head = head + 1
    if head >= DARWIN-PIPE-CAP {
      head = 0
    }
    i = i + 1
  }
  store64(base + DARWIN-PIPE-OFF-HEAD, head)
  store64(base + DARWIN-PIPE-OFF-COUNT, n - take)
  return take
}

fn darwin-pipe-write(fd: Int, buf: Int, count: Int) -> Int {
  if count <= 0 {
    return 0
  }
  if darwin-pipe-end(fd) != DARWIN-PIPE-END-WRITE {
    return DARWIN-EBADF
  }
  let idx = darwin-pipe-slot(fd)
  if idx < 0 || idx >= DARWIN-PIPE-MAX {
    return DARWIN-EBADF
  }
  let base = darwin-pipe-table + idx * DARWIN-PIPE-SLOT
  if load64(base + DARWIN-PIPE-OFF-USED) == 0 {
    return DARWIN-EBADF
  }
  if load64(base + DARWIN-PIPE-OFF-ROPEN) == 0 {
    return DARWIN-EBADF
  }
  let n = load64(base + DARWIN-PIPE-OFF-COUNT)
  let space = DARWIN-PIPE-CAP - n
  if space <= 0 {
    return 0
  }
  let put = count
  if put > space {
    put = space
  }
  let pbuf = load64(base + DARWIN-PIPE-OFF-BUF)
  let head = load64(base + DARWIN-PIPE-OFF-HEAD)
  let tail = head + n
  while tail >= DARWIN-PIPE-CAP {
    tail = tail - DARWIN-PIPE-CAP
  }
  let i = 0
  while i < put {
    store8(pbuf + tail, load8(buf + i))
    tail = tail + 1
    if tail >= DARWIN-PIPE-CAP {
      tail = 0
    }
    i = i + 1
  }
  store64(base + DARWIN-PIPE-OFF-COUNT, n + put)
  return put
}

fn darwin-sys-read(fd: Int, buf: Int, count: Int) -> Int {
  if darwin-fd-is-pipe(fd) != 0 {
    return darwin-pipe-read(fd, buf, count)
  }
  return vfs-read(fd, buf, count)
}

fn darwin-sys-write(port: Int, fd: Int, buf: Int, count: Int) -> Int {
  // Keep serial port path for stdio so demos can target COM1 explicitly.
  if fd == 1 || fd == 2 {
    let i = 0
    while i < count {
      serial-put(port, load8(buf + i))
      i = i + 1
    }
    return count
  }
  if darwin-fd-is-pipe(fd) != 0 {
    return darwin-pipe-write(fd, buf, count)
  }
  return vfs-write(fd, buf, count)
}

fn darwin-sys-unlink(pathname: Int) -> Int {
  let rc = fs-delete(pathname)
  if rc != 0 {
    return DARWIN-ENOENT
  }
  return 0
}

fn darwin-sys-getpid() -> Int {
  return current-task
}

fn darwin-sys-kill(pid: Int, sig: Int) -> Int {
  if pid < 0 || pid >= proc-count {
    return DARWIN-ESRCH
  }
  if proc-signal(pid, sig) != 0 {
    return DARWIN-ESRCH
  }
  return 0
}

fn darwin-sys-exit(code: Int) -> Int {
  // Demo only: report status, do not halt the kernel.
  return code
}

fn darwin-sys-getcwd(buf: Int, size: Int) -> Int {
  return posix-sys-getcwd(buf, size)
}

fn darwin-sys-chdir(path: Int) -> Int {
  let rc = posix-sys-chdir(path)
  if rc != 0 {
    return DARWIN-ENOENT
  }
  return 0
}

fn darwin-sys-mkdir(path: Int, mode: Int) -> Int {
  let rc = fs-mkdir(path)
  if rc < 0 {
    return DARWIN-ENOENT
  }
  return 0
}

fn darwin-sys-fstat(fd: Int, buf: Int) -> Int {
  if vfs-fd-valid(fd) == 0 {
    return DARWIN-EBADF
  }
  let i = 0
  while i < DARWIN-STAT-SIZE {
    store8(buf + i, 0)
    i = i + 1
  }
  if fd < 3 {
    store64(buf + DARWIN-STAT-OFF-SIZE, 0)
    return 0
  }
  let base = vfs-fd-table + fd * 32
  let fpath = load64(base + 0)
  let sfbuf = alloc(64)
  let st = fs-stat(fpath, sfbuf)
  if st != 0 {
    return DARWIN-ENOENT
  }
  store64(buf + DARWIN-STAT-OFF-SIZE, load64(sfbuf + SF-ST-SIZE))
  return 0
}

fn darwin-sys-lseek(fd: Int, offset: Int, whence: Int) -> Int {
  return vfs-lseek(fd, offset, whence)
}

fn darwin-sys-rename(oldp: Int, newp: Int) -> Int {
  let rc = fs-rename(oldp, newp)
  if rc != 0 {
    return DARWIN-ENOENT
  }
  return 0
}

fn darwin-sys-rmdir(path: Int) -> Int {
  let rc = fs-rmdir(path)
  if rc != 0 {
    return DARWIN-ENOENT
  }
  return 0
}

// access: existence probe via fs-stat (mode bits ignored for now).
fn darwin-sys-access(path: Int, mode: Int) -> Int {
  let stbuf = alloc(64)
  let st = fs-stat(path, stbuf)
  if st != 0 {
    return DARWIN-ENOENT
  }
  return 0
}

fn darwin-sys-getuid() -> Int {
  return 0
}

fn darwin-sys-geteuid() -> Int {
  return 0
}

// Clone path/offset/flags from an open vfs fd into a new slot.
fn darwin-sys-dup(fd: Int) -> Int {
  if vfs-fd-valid(fd) == 0 {
    return DARWIN-EBADF
  }
  if fd < 3 {
    let nfd = vfs-fd-alloc()
    if nfd < 0 {
      return DARWIN-ENOSYS
    }
    let nbase = vfs-fd-table + nfd * 32
    store64(nbase + 0, 0)
    store64(nbase + 8, 0)
    store64(nbase + 16, load64(vfs-fd-table + fd * 32 + 16))
    store64(nbase + 24, 0)
    return nfd
  }
  let base = vfs-fd-table + fd * 32
  let path = load64(base + 0)
  let nfd = vfs-fd-alloc()
  if nfd < 0 {
    return DARWIN-ENOSYS
  }
  let nbase = vfs-fd-table + nfd * 32
  store64(nbase + 0, path)
  store64(nbase + 8, load64(base + 8))
  store64(nbase + 16, load64(base + 16))
  store64(nbase + 24, load64(base + 24))
  return nfd
}

fn darwin-sys-fork() -> Int {
  return posix-sys-fork()
}

fn darwin-sys-wait4(pid: Int, wstatus: Int, options: Int, rusage: Int) -> Int {
  return posix-sys-wait4(pid, wstatus, options, rusage)
}

fn darwin-sys-execve(path: Int, argv: Int, envp: Int) -> Int {
  return posix-sys-execve(path, argv, envp)
}

// pipe lite: two vfs fds (type=2) share 4KB ring in side table (max 4 pipes).
fn darwin-sys-pipe(fds: Int) -> Int {
  darwin-pipe-table-init()
  let idx = -1
  let i = 0
  while i < DARWIN-PIPE-MAX {
    let base = darwin-pipe-table + i * DARWIN-PIPE-SLOT
    if load64(base + DARWIN-PIPE-OFF-USED) == 0 {
      idx = i
      break
    }
    i = i + 1
  }
  if idx < 0 {
    return DARWIN-ENOMEM
  }
  let rfd = vfs-fd-alloc()
  if rfd < 0 {
    return DARWIN-ENOMEM
  }
  let wfd = vfs-fd-alloc()
  if wfd < 0 {
    vfs-fd-clear(rfd)
    return DARWIN-ENOMEM
  }
  let pbuf = alloc(DARWIN-PIPE-CAP)
  let pbase = darwin-pipe-table + idx * DARWIN-PIPE-SLOT
  store64(pbase + DARWIN-PIPE-OFF-USED, 1)
  store64(pbase + DARWIN-PIPE-OFF-BUF, pbuf)
  store64(pbase + DARWIN-PIPE-OFF-HEAD, 0)
  store64(pbase + DARWIN-PIPE-OFF-COUNT, 0)
  store64(pbase + DARWIN-PIPE-OFF-ROPEN, 1)
  store64(pbase + DARWIN-PIPE-OFF-WOPEN, 1)
  // path unused for pipe; mark non--1 so vfs-fd-valid accepts slot.
  let rbase = vfs-fd-table + rfd * 32
  store64(rbase + 0, 0)
  store64(rbase + 8, idx)
  store64(rbase + 16, DARWIN-PIPE-END-READ)
  store64(rbase + 24, DARWIN-FD-TYPE-PIPE)
  let wbase = vfs-fd-table + wfd * 32
  store64(wbase + 0, 0)
  store64(wbase + 8, idx)
  store64(wbase + 16, DARWIN-PIPE-END-WRITE)
  store64(wbase + 24, DARWIN-FD-TYPE-PIPE)
  if fds != 0 {
    store32(fds + 0, rfd)
    store32(fds + 4, wfd)
  }
  return 0
}

// mmap simplified: a0 addr a1 len a2 prot → posix-sys-mmap (anon).
fn darwin-sys-mmap(addr: Int, len: Int, prot: Int) -> Int {
  return posix-sys-mmap(addr, len, prot, 0, -1, 0)
}

fn darwin-sys-munmap(addr: Int, len: Int) -> Int {
  return posix-sys-munmap(addr, len)
}

// path fs-stat size into buf (same shape as fstat).
fn darwin-sys-stat(path: Int, buf: Int) -> Int {
  let i = 0
  while i < DARWIN-STAT-SIZE {
    store8(buf + i, 0)
    i = i + 1
  }
  let sfbuf = alloc(64)
  let st = fs-stat(path, sfbuf)
  if st != 0 {
    return DARWIN-ENOENT
  }
  store64(buf + DARWIN-STAT-OFF-SIZE, load64(sfbuf + SF-ST-SIZE))
  return 0
}

// BSD SOCK_STREAM=1 DGRAM=2 already match netstack; domain AF_INET=2.
fn darwin-sys-socket(domain: Int, stype: Int, proto: Int) -> Int {
  return sock-socket(domain, stype, proto)
}

fn darwin-sys-connect(fd: Int, ip: Int, port: Int) -> Int {
  return sock-connect(fd, ip, port)
}

fn darwin-sys-sendto(fd: Int, buf: Int, len: Int, rip: Int) -> Int {
  // a3 = remote ip; port defaults 0 for demo (caller may use connect first).
  return sock-sendto(fd, buf, len, rip, 0)
}

fn darwin-sys-recvfrom(fd: Int, buf: Int, len: Int) -> Int {
  return sock-recvfrom(fd, buf, len)
}

// BSD/Mach-ish dispatch. a0..a3 carry classic arg slots (open mode in a2, kill sig in a1).
fn darwin-dispatch(port: Int, num: Int, a0: Int, a1: Int, a2: Int, a3: Int) -> Int {
  if darwin-ready == 0 {
    darwin-init()
  }
  if num == DARWIN-SYS-FORK {
    return darwin-sys-fork()
  }
  if num == DARWIN-SYS-READ {
    return darwin-sys-read(a0, a1, a2)
  }
  if num == DARWIN-SYS-WRITE {
    return darwin-sys-write(port, a0, a1, a2)
  }
  if num == DARWIN-SYS-OPEN {
    return darwin-sys-open(a0, a1, a2)
  }
  if num == DARWIN-SYS-CLOSE {
    return darwin-sys-close(a0)
  }
  if num == DARWIN-SYS-WAIT4 {
    return darwin-sys-wait4(a0, a1, a2, a3)
  }
  if num == DARWIN-SYS-UNLINK {
    return darwin-sys-unlink(a0)
  }
  if num == DARWIN-SYS-CHDIR {
    return darwin-sys-chdir(a0)
  }
  if num == DARWIN-SYS-GETPID {
    return darwin-sys-getpid()
  }
  if num == DARWIN-SYS-GETUID {
    return darwin-sys-getuid()
  }
  if num == DARWIN-SYS-GETEUID {
    return darwin-sys-geteuid()
  }
  if num == DARWIN-SYS-RECVFROM {
    return darwin-sys-recvfrom(a0, a1, a2)
  }
  if num == DARWIN-SYS-ACCESS {
    return darwin-sys-access(a0, a1)
  }
  if num == DARWIN-SYS-KILL {
    return darwin-sys-kill(a0, a1)
  }
  if num == DARWIN-SYS-DUP {
    return darwin-sys-dup(a0)
  }
  if num == DARWIN-SYS-PIPE {
    return darwin-sys-pipe(a0)
  }
  if num == DARWIN-SYS-EXECVE {
    return darwin-sys-execve(a0, a1, a2)
  }
  if num == DARWIN-SYS-MUNMAP {
    return darwin-sys-munmap(a0, a1)
  }
  if num == DARWIN-SYS-SOCKET {
    return darwin-sys-socket(a0, a1, a2)
  }
  if num == DARWIN-SYS-CONNECT {
    return darwin-sys-connect(a0, a1, a2)
  }
  if num == DARWIN-SYS-RENAME {
    return darwin-sys-rename(a0, a1)
  }
  if num == DARWIN-SYS-SENDTO {
    return darwin-sys-sendto(a0, a1, a2, a3)
  }
  if num == DARWIN-SYS-MKDIR {
    return darwin-sys-mkdir(a0, a1)
  }
  if num == DARWIN-SYS-RMDIR {
    return darwin-sys-rmdir(a0)
  }
  if num == DARWIN-SYS-STAT {
    return darwin-sys-stat(a0, a1)
  }
  if num == DARWIN-SYS-FSTAT {
    return darwin-sys-fstat(a0, a1)
  }
  if num == DARWIN-SYS-GETCWD {
    return darwin-sys-getcwd(a0, a1)
  }
  if num == DARWIN-SYS-MMAP {
    return darwin-sys-mmap(a0, a1, a2)
  }
  if num == DARWIN-SYS-LSEEK {
    return darwin-sys-lseek(a0, a1, a2)
  }
  if num == DARWIN-SYS-EXIT {
    return darwin-sys-exit(a0)
  }
  if num == DARWIN-MACH-TASK-SELF {
    return 1
  }
  if num == DARWIN-MACH-MSG {
    return -1
  }
  return DARWIN-ENOSYS
}

fn darwin-demo(port: Int) -> void {
  if darwin-ready == 0 {
    darwin-init()
  }
  serial-write-cstr(port, "darwin: Mach/BSD subset personality registered (not full XNU)")
  serial-nl(port)

  let msg = "  hello from darwin personality (write)\n"
  let mlen = 0
  while load8(msg + mlen) != 0 {
    mlen = mlen + 1
  }
  let wrc = darwin-dispatch(port, DARWIN-SYS-WRITE, 1, msg, mlen, 0)
  serial-write-cstr(port, "darwin: write(1, msg, ")
  serial-write-dec-wide(port, mlen)
  serial-write-cstr(port, ") = ")
  serial-write-dec-wide(port, wrc)
  serial-nl(port)

  let pid = darwin-dispatch(port, DARWIN-SYS-GETPID, 0, 0, 0, 0)
  serial-write-cstr(port, "darwin: getpid() = ")
  serial-write-dec-wide(port, pid)
  serial-nl(port)

  let fname = "darwin-hello.txt"
  let fd = darwin-dispatch(port, DARWIN-SYS-OPEN, fname, DARWIN-O-CREAT | DARWIN-O-RDWR, 0, 0)
  serial-write-cstr(port, "darwin: open(darwin-hello.txt, O_CREAT|O_RDWR) = ")
  serial-write-dec-wide(port, fd)
  serial-nl(port)

  if fd >= 0 {
    let content = "darwin file content"
    let clen = 0
    while load8(content + clen) != 0 {
      clen = clen + 1
    }
    let fwrc = darwin-dispatch(port, DARWIN-SYS-WRITE, fd, content, clen, 0)
    serial-write-cstr(port, "darwin: write(fd, content, ")
    serial-write-dec-wide(port, clen)
    serial-write-cstr(port, ") = ")
    serial-write-dec-wide(port, fwrc)
    serial-nl(port)

    darwin-dispatch(port, DARWIN-SYS-CLOSE, fd, 0, 0, 0)
    serial-write-cstr(port, "darwin: close(fd) = 0")
    serial-nl(port)
  }

  let rfd = darwin-dispatch(port, DARWIN-SYS-OPEN, fname, DARWIN-O-RDONLY, 0, 0)
  serial-write-cstr(port, "darwin: open(darwin-hello.txt, O_RDONLY) = ")
  serial-write-dec-wide(port, rfd)
  serial-nl(port)

  if rfd >= 0 {
    let rbuf = alloc(256)
    let rlen = darwin-dispatch(port, DARWIN-SYS-READ, rfd, rbuf, 255, 0)
    serial-write-cstr(port, "darwin: read(fd, buf, 255) = ")
    serial-write-dec-wide(port, rlen)
    serial-write-cstr(port, " -> '")
    let ri = 0
    while ri < rlen {
      serial-put(port, load8(rbuf + ri))
      ri = ri + 1
    }
    serial-write-cstr(port, "'")
    serial-nl(port)
    darwin-dispatch(port, DARWIN-SYS-CLOSE, rfd, 0, 0, 0)
  }

  let dname = "darwin-dir"
  let mrc = darwin-dispatch(port, DARWIN-SYS-MKDIR, dname, 0o755, 0, 0)
  serial-write-cstr(port, "darwin: mkdir(darwin-dir) = ")
  serial-write-dec-wide(port, mrc)
  serial-nl(port)

  if mrc == 0 {
    let crc = darwin-dispatch(port, DARWIN-SYS-CHDIR, dname, 0, 0, 0)
    serial-write-cstr(port, "darwin: chdir(darwin-dir) = ")
    serial-write-dec-wide(port, crc)
    serial-nl(port)
  }

  let cwdbuf = alloc(64)
  let cwdrc = darwin-dispatch(port, DARWIN-SYS-GETCWD, cwdbuf, 64, 0, 0)
  serial-write-cstr(port, "darwin: getcwd() = '")
  if cwdrc != 0 {
    serial-write-cstr(port, cwdbuf)
  }
  serial-write-cstr(port, "'")
  serial-nl(port)

  // chdir back to root so later absolute-ish paths stay simple
  darwin-dispatch(port, DARWIN-SYS-CHDIR, "/", 0, 0, 0)

  let uid = darwin-dispatch(port, DARWIN-SYS-GETUID, 0, 0, 0, 0)
  serial-write-cstr(port, "darwin: getuid() = ")
  serial-write-dec-wide(port, uid)
  serial-nl(port)

  let euid = darwin-dispatch(port, DARWIN-SYS-GETEUID, 0, 0, 0, 0)
  serial-write-cstr(port, "darwin: geteuid() = ")
  serial-write-dec-wide(port, euid)
  serial-nl(port)

  let arc = darwin-dispatch(port, DARWIN-SYS-ACCESS, fname, 0, 0, 0)
  serial-write-cstr(port, "darwin: access(darwin-hello.txt, F_OK) = ")
  serial-write-dec-wide(port, arc)
  serial-nl(port)

  let sfd = darwin-dispatch(port, DARWIN-SYS-OPEN, fname, DARWIN-O-RDONLY, 0, 0)
  serial-write-cstr(port, "darwin: open(darwin-hello.txt, O_RDONLY) for lseek/fstat/dup = ")
  serial-write-dec-wide(port, sfd)
  serial-nl(port)
  if sfd >= 0 {
    let pos = darwin-dispatch(port, DARWIN-SYS-LSEEK, sfd, 7, DARWIN-SEEK-SET, 0)
    serial-write-cstr(port, "darwin: lseek(fd, 7, SEEK_SET) = ")
    serial-write-dec-wide(port, pos)
    serial-nl(port)

    let stbuf = alloc(DARWIN-STAT-SIZE)
    let frc = darwin-dispatch(port, DARWIN-SYS-FSTAT, sfd, stbuf, 0, 0)
    serial-write-cstr(port, "darwin: fstat(fd) = ")
    serial-write-dec-wide(port, frc)
    if frc == 0 {
      serial-write-cstr(port, ", st_size = ")
      serial-write-dec-wide(port, load64(stbuf + DARWIN-STAT-OFF-SIZE))
    }
    serial-nl(port)

    let dfd = darwin-dispatch(port, DARWIN-SYS-DUP, sfd, 0, 0, 0)
    serial-write-cstr(port, "darwin: dup(fd) = ")
    serial-write-dec-wide(port, dfd)
    serial-nl(port)
    if dfd >= 0 {
      darwin-dispatch(port, DARWIN-SYS-CLOSE, dfd, 0, 0, 0)
    }
    darwin-dispatch(port, DARWIN-SYS-CLOSE, sfd, 0, 0, 0)
  }

  let fname2 = "darwin-hello2.txt"
  let rnrc = darwin-dispatch(port, DARWIN-SYS-RENAME, fname, fname2, 0, 0)
  serial-write-cstr(port, "darwin: rename(darwin-hello.txt, darwin-hello2.txt) = ")
  serial-write-dec-wide(port, rnrc)
  serial-nl(port)

  let urc = darwin-dispatch(port, DARWIN-SYS-UNLINK, fname2, 0, 0, 0)
  serial-write-cstr(port, "darwin: unlink(darwin-hello2.txt) = ")
  serial-write-dec-wide(port, urc)
  serial-nl(port)

  let rrc = darwin-dispatch(port, DARWIN-SYS-RMDIR, dname, 0, 0, 0)
  serial-write-cstr(port, "darwin: rmdir(darwin-dir) = ")
  serial-write-dec-wide(port, rrc)
  serial-nl(port)

  // Recreate a small file for path stat after earlier rename/unlink.
  let sname = "darwin-stat.txt"
  let stfd = darwin-dispatch(port, DARWIN-SYS-OPEN, sname, DARWIN-O-CREAT | DARWIN-O-RDWR, 0, 0)
  if stfd >= 0 {
    let scontent = "stat-me"
    let slen = 0
    while load8(scontent + slen) != 0 {
      slen = slen + 1
    }
    darwin-dispatch(port, DARWIN-SYS-WRITE, stfd, scontent, slen, 0)
    darwin-dispatch(port, DARWIN-SYS-CLOSE, stfd, 0, 0, 0)
  }
  let stpath = alloc(DARWIN-STAT-SIZE)
  let strc = darwin-dispatch(port, DARWIN-SYS-STAT, sname, stpath, 0, 0)
  serial-write-cstr(port, "darwin: stat(darwin-stat.txt) = ")
  serial-write-dec-wide(port, strc)
  if strc == 0 {
    serial-write-cstr(port, ", st_size = ")
    serial-write-dec-wide(port, load64(stpath + DARWIN-STAT-OFF-SIZE))
  }
  serial-nl(port)
  darwin-dispatch(port, DARWIN-SYS-UNLINK, sname, 0, 0, 0)

  let map = darwin-dispatch(port, DARWIN-SYS-MMAP, 0, 64, 0, 0)
  serial-write-cstr(port, "darwin: mmap(0, 64) = ")
  serial-write-dec-wide(port, map)
  serial-nl(port)
  if map > 0 {
    store8(map + 0, 65)
    let urc = darwin-dispatch(port, DARWIN-SYS-MUNMAP, map, 64, 0, 0)
    serial-write-cstr(port, "darwin: munmap(map, 64) = ")
    serial-write-dec-wide(port, urc)
    serial-nl(port)
  }

  let sock = darwin-dispatch(port, DARWIN-SYS-SOCKET, DARWIN-AF-INET, DARWIN-SOCK-DGRAM, 0, 0)
  serial-write-cstr(port, "darwin: socket(AF_INET, SOCK_DGRAM, 0) = ")
  serial-write-dec-wide(port, sock)
  serial-nl(port)

  let pfds = alloc(8)
  let prc = darwin-dispatch(port, DARWIN-SYS-PIPE, pfds, 0, 0, 0)
  serial-write-cstr(port, "darwin: pipe() = ")
  serial-write-dec-wide(port, prc)
  serial-nl(port)
  if prc == 0 {
    let rfd = load32(pfds + 0)
    let wfd = load32(pfds + 4)
    serial-write-cstr(port, "darwin: pipe fds r=")
    serial-write-dec-wide(port, rfd)
    serial-write-cstr(port, " w=")
    serial-write-dec-wide(port, wfd)
    serial-nl(port)
    let pmsg = "pipe-lite"
    let plen = 0
    while load8(pmsg + plen) != 0 {
      plen = plen + 1
    }
    let pw = darwin-dispatch(port, DARWIN-SYS-WRITE, wfd, pmsg, plen, 0)
    serial-write-cstr(port, "darwin: write(pipe_w, pipe-lite) = ")
    serial-write-dec-wide(port, pw)
    serial-nl(port)
    let pbuf = alloc(32)
    let pr = darwin-dispatch(port, DARWIN-SYS-READ, rfd, pbuf, 31, 0)
    serial-write-cstr(port, "darwin: read(pipe_r) = ")
    serial-write-dec-wide(port, pr)
    serial-write-cstr(port, " -> '")
    let pi = 0
    while pi < pr {
      serial-put(port, load8(pbuf + pi))
      pi = pi + 1
    }
    serial-write-cstr(port, "'")
    serial-nl(port)
    darwin-dispatch(port, DARWIN-SYS-CLOSE, rfd, 0, 0, 0)
    darwin-dispatch(port, DARWIN-SYS-CLOSE, wfd, 0, 0, 0)
  }

  // fork/execve wired in dispatch; shell demo skips (proc-wait yields; execve replaces image).

  let krc = darwin-dispatch(port, DARWIN-SYS-KILL, 99999, SIGKILL, 0, 0)
  serial-write-cstr(port, "darwin: kill(invalid) = ")
  serial-write-dec-wide(port, krc)
  if krc == DARWIN-ESRCH {
    serial-write-cstr(port, " (ESRCH expected)")
  }
  serial-nl(port)

  let task = darwin-dispatch(port, DARWIN-MACH-TASK-SELF, 0, 0, 0, 0)
  serial-write-cstr(port, "darwin: mach_task_self stub = ")
  serial-write-dec-wide(port, task)
  serial-nl(port)

  let erc = darwin-dispatch(port, DARWIN-SYS-EXIT, 0, 0, 0, 0)
  serial-write-cstr(port, "darwin: exit(0) mapped (demo status ")
  serial-write-dec-wide(port, erc)
  serial-write-cstr(port, ", no halt)")
  serial-nl(port)

  serial-write-cstr(port, "darwin: personality demo complete")
  serial-nl(port)
  return
}
