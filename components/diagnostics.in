package space.kernel

fn diagnostics-fetch(port: Int) -> void {
  serial-write-cstr(port, "  SpaceOS")
  serial-write-cstr(port, " 0.2.")
  serial-write-dec-wide(port, SPACE-VERSION-PATCH)
  serial-nl(port)
  serial-write-cstr(port, "  kernel      Space nanokernel")
  serial-nl(port)
  serial-write-cstr(port, "  arch        x86_64 long mode")
  serial-nl(port)
  serial-write-cstr(port, "  memory      ")
  serial-write-dec-wide(port, total-ram / 1048576)
  serial-write-cstr(port, " MiB")
  serial-nl(port)
  serial-write-cstr(port, "  display     ")
  serial-write-dec-wide(port, fb-width)
  serial-write-cstr(port, "x")
  serial-write-dec-wide(port, fb-height)
  serial-write-cstr(port, "x")
  serial-write-dec-wide(port, fb-bpp)
  serial-nl(port)
  serial-write-cstr(port, "  framebuffer ")
  serial-write-dec-wide(port, fb-size / 1048576)
  serial-write-cstr(port, " MiB")
  serial-nl(port)
  serial-write-cstr(port, "  storage     sparkfs ")
  if nvme-ready != 0 {
    serial-write-cstr(port, "nvme")
  } else {
    serial-write-cstr(port, "mem")
  }
  serial-nl(port)
  serial-write-cstr(port, "  input       PS/2 keyboard + mouse")
  serial-nl(port)
  serial-write-cstr(port, "  linux abi   syscall personality")
  serial-nl(port)
  serial-write-cstr(port, "  processes   ")
  serial-write-dec-wide(port, proc-count)
  serial-nl(port)
  serial-write-cstr(port, "  domains     ")
  serial-write-dec-wide(port, domain-count)
  serial-nl(port)
  serial-write-cstr(port, "  objects     0x")
  serial-write-hex(port, obj-counter)
  serial-nl(port)
  return
}
