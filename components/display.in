package space.display

import "../protocol/display.in"

const SPDP_OBJ_SURFACE = 5

interface DisplayDevice {
  fn map(phys: Int, size: Int) -> void
  fn present() -> void
}

component Display {
  target "x86_64-unknown-none"
  deterministic true
  checkpoint none

  capability display: DisplayDevice(map, present)
}

const COM1_PORT = 0x3F8
const SPACE_VERSION_MAJOR = 0
const SPACE_VERSION_MINOR = 2
const SPACE_VERSION_PATCH = 75

fn com1() -> Int {
  return COM1_PORT
}

fn serial_wait_tx(port: Int) -> void {
  while (inb(port + 5) & 0x20) == 0 {
  }
  return
}

fn serial_init(port: Int) -> void {
  outb(port + 1, 0x00)
  outb(port + 3, 0x80)
  outb(port + 0, 0x03)
  outb(port + 1, 0x00)
  outb(port + 3, 0x03)
  outb(port + 2, 0xC7)
  outb(port + 4, 0x0B)
  return
}

fn serial_put(port: Int, ch: Int) -> void {
  serial_wait_tx(port)
  outb(port, ch)
  return
}

fn serial_nl(port: Int) -> void {
  serial_put(port, 10)
  return
}

fn serial_write_cstr(port: Int, addr: Int) -> void {
  let i = 0
  let c = load8(addr + i)
  while c != 0 {
    serial_put(port, c)
    i = i + 1
    c = load8(addr + i)
  }
  return
}

fn serial_write_dec_wide(port: Int, value: Int) -> void {
  let n = value
  if n < 0 {
    serial_put(port, 45)
    n = -n
  }
  if n == 0 {
    serial_put(port, 48)
    return
  }
  let div = 1
  while n / div >= 10 {
    div = div * 10
  }
  while div > 0 {
    serial_put(port, 48 + (n / div) % 10)
    div = div / 10
  }
  return
}

fn serial_write_hex(port: Int, value: Int) -> void {
  let shift = 60
  while shift >= 0 {
    let nibble = (value >> shift) & 0xF
    if nibble < 10 {
      serial_put(port, 48 + nibble)
    } else {
      serial_put(port, 87 + nibble)
    }
    shift = shift - 4
  }
  return
}

fn serial_has_byte(port: Int) -> Int {
  return 0
}

var heap_next: Int = 0x300000
var heap_end: Int = 0x400000

fn display_heap_init(base: Int, size: Int) -> void {
  heap_next = base
  heap_end = base + size
  return
}

fn alloc(n: Int) -> Int {
  let aligned = (n + 15) & -16
  let p = heap_next
  let next = heap_next + aligned
  if next > heap_end {
    return 0
  }
  heap_next = next
  return p
}

const PCI_CONFIG_ADDR = 0xCF8
const PCI_CONFIG_DATA = 0xCFC

fn pci_read32(bus: Int, dev: Int, func: Int, off: Int) -> Int {
  let addr = 0x80000000 | (bus << 16) | (dev << 11) | (func << 8) | (off & 0xFC)
  outl(PCI_CONFIG_ADDR, addr)
  return inl(PCI_CONFIG_DATA)
}

fn pci_write32(bus: Int, dev: Int, func: Int, off: Int, val: Int) -> void {
  let addr = 0x80000000 | (bus << 16) | (dev << 11) | (func << 8) | (off & 0xFC)
  outl(PCI_CONFIG_ADDR, addr)
  outl(PCI_CONFIG_DATA, val)
  return
}


fn outw(port: Int, val: Int) -> void {
  outb(port, val & 0xFF)
  outb(port + 1, (val >> 8) & 0xFF)
  return
}

fn inw(port: Int) -> Int {
  return inb(port) | (inb(port + 1) << 8)
}

fn outl(port: Int, val: Int) -> void {
  outb(port, val & 0xFF)
  outb(port + 1, (val >> 8) & 0xFF)
  outb(port + 2, (val >> 16) & 0xFF)
  outb(port + 3, (val >> 24) & 0xFF)
  return
}

fn inl(port: Int) -> Int {
  return inb(port) | (inb(port + 1) << 8) | (inb(port + 2) << 16) | (inb(port + 3) << 24)
}

