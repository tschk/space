package space.kernel

const EDITOR-BUF-SIZE = 4096
const EDITOR-NAME-SIZE = 256
const EDITOR-KEY-LEFT = 1000
const EDITOR-KEY-RIGHT = 1001
const EDITOR-KEY-UP = 1002
const EDITOR-KEY-DOWN = 1003
const EDITOR-KEY-HOME = 1004
const EDITOR-KEY-END = 1005
const EDITOR-KEY-PGUP = 1006
const EDITOR-KEY-PGDN = 1007
const EDITOR-KEY-DELETE = 1008

var editor-buf: Int = 0
var editor-name: Int = 0
var editor-query: Int = 0
var editor-len: Int = 0
var editor-row: Int = 0
var editor-col: Int = 0
var editor-scroll: Int = 0
var editor-dirty: Int = 0
var editor-pushback: Int = 0

fn editor-num(port: Int, value: Int) -> void {
  serial-write-dec-wide(port, value)
  return
}

fn editor-csi(port: Int, a: Int, b: Int) -> void {
  serial-put(port, 27)
  serial-put(port, 91)
  if a != 0 { serial-put(port, a) }
  serial-put(port, b)
  return
}

fn editor-csi-xy(port: Int, row: Int, col: Int) -> void {
  serial-put(port, 27)
  serial-put(port, 91)
  editor-num(port, row)
  serial-put(port, 59)
  editor-num(port, col)
  serial-put(port, 72)
  return
}

fn editor-alt-enter(port: Int) -> void {
  serial-put(port, 27)
  serial-put(port, 91)
  serial-put(port, 63)
  serial-put(port, 49)
  serial-put(port, 48)
  serial-put(port, 52)
  serial-put(port, 57)
  serial-put(port, 104)
  serial-put(port, 27)
  serial-put(port, 91)
  serial-put(port, 63)
  serial-put(port, 50)
  serial-put(port, 53)
  serial-put(port, 108)
  return
}

fn editor-alt-exit(port: Int) -> void {
  serial-put(port, 27)
  serial-put(port, 91)
  serial-put(port, 63)
  serial-put(port, 49)
  serial-put(port, 48)
  serial-put(port, 52)
  serial-put(port, 57)
  serial-put(port, 108)
  return
}

fn editor-read-byte(port: Int) -> Int {
  if editor-pushback != 0 {
    let ch = editor-pushback
    editor-pushback = 0
    return ch
  }
  return serial-read(port)
}

fn editor-read-key(port: Int) -> Int {
  let ch = editor-read-byte(port)
  if ch != 27 { return ch }
  let next = editor-read-byte(port)
  if next != 91 {
    editor-pushback = next
    return 27
  }
  let final = editor-read-byte(port)
  if final == 65 { return EDITOR-KEY-UP }
  if final == 66 { return EDITOR-KEY-DOWN }
  if final == 67 { return EDITOR-KEY-RIGHT }
  if final == 68 { return EDITOR-KEY-LEFT }
  if final == 72 { return EDITOR-KEY-HOME }
  if final == 70 { return EDITOR-KEY-END }
  if final == 51 { editor-read-byte(port); return EDITOR-KEY-DELETE }
  if final == 53 { editor-read-byte(port); return EDITOR-KEY-PGUP }
  if final == 54 { editor-read-byte(port); return EDITOR-KEY-PGDN }
  return 27
}

fn editor-copy(dst: Int, src: Int, max: Int) -> Int {
  let i = 0
  while i < max - 1 && load8(src + i) != 0 {
    store8(dst + i, load8(src + i))
    i = i + 1
  }
  store8(dst + i, 0)
  return i
}

fn editor-row-offset(row: Int) -> Int {
  let off = 0
  let current = 0
  while current < row && off < editor-len {
    if load8(editor-buf + off) == 10 { current = current + 1 }
    off = off + 1
  }
  return off
}

fn editor-row-length(row: Int) -> Int {
  let off = editor-row-offset(row)
  let len = 0
  while off + len < editor-len && load8(editor-buf + off + len) != 10 {
    len = len + 1
  }
  return len
}

fn editor-row-count() -> Int {
  let count = 1
  let i = 0
  while i < editor-len {
    if load8(editor-buf + i) == 10 { count = count + 1 }
    i = i + 1
  }
  return count
}

fn editor-offset() -> Int {
  return editor-row-offset(editor-row) + editor-col
}

fn editor-insert(ch: Int) -> void {
  if editor-len >= EDITOR-BUF-SIZE - 1 { return }
  let off = editor-offset()
  let i = editor-len
  while i > off {
    store8(editor-buf + i, load8(editor-buf + i - 1))
    i = i - 1
  }
  store8(editor-buf + off, ch)
  editor-len = editor-len + 1
  store8(editor-buf + editor-len, 0)
  editor-dirty = 1
  return
}

fn editor-delete() -> void {
  let off = editor-offset()
  if off >= editor-len { return }
  let i = off
  while i < editor-len - 1 {
    store8(editor-buf + i, load8(editor-buf + i + 1))
    i = i + 1
  }
  editor-len = editor-len - 1
  store8(editor-buf + editor-len, 0)
  editor-dirty = 1
  return
}

fn editor-backspace() -> void {
  let off = editor-offset()
  if off == 0 { return }
  if load8(editor-buf + off - 1) == 10 {
    editor-row = editor-row - 1
    editor-col = editor-row-length(editor-row)
  } else {
    editor-col = editor-col - 1
  }
  editor-delete()
  return
}

fn editor-left() -> void {
  if editor-col > 0 {
    editor-col = editor-col - 1
  } else if editor-row > 0 {
    editor-row = editor-row - 1
    editor-col = editor-row-length(editor-row)
  }
  return
}

fn editor-right() -> void {
  if editor-col < editor-row-length(editor-row) {
    editor-col = editor-col + 1
  } else if editor-row < editor-row-count() - 1 {
    editor-row = editor-row + 1
    editor-col = 0
  }
  return
}

fn editor-vertical(delta: Int) -> void {
  let row = editor-row + delta
  if row < 0 { row = 0 }
  let total = editor-row-count()
  if row >= total { row = total - 1 }
  editor-row = row
  let width = editor-row-length(editor-row)
  if editor-col > width { editor-col = width }
  return
}

fn editor-adjust-scroll() -> void {
  if editor-row < editor-scroll { editor-scroll = editor-row }
  if editor-row >= editor-scroll + 22 { editor-scroll = editor-row - 21 }
  return
}

fn editor-render(port: Int) -> void {
  editor-adjust-scroll()
  editor-csi(port, 50, 74)
  editor-csi(port, 0, 72)
  let y = 0
  let total = editor-row-count()
  while y < 22 {
    let file-row = editor-scroll + y
    editor-csi-xy(port, y + 1, 1)
    if file-row < total {
      let number = file-row + 1
      serial-put(port, 32)
      if number < 10 { serial-put(port, 32); serial-put(port, 32) } else if number < 100 { serial-put(port, 32) }
      editor-num(port, number)
      serial-put(port, 32)
      let off = editor-row-offset(file-row)
      let width = editor-row-length(file-row)
      let x = 0
      while x < width && x < 72 { serial-put(port, load8(editor-buf + off + x)); x = x + 1 }
    } else {
      serial-write-cstr(port, "    ~")
    }
    editor-csi(port, 0, 75)
    y = y + 1
  }
  editor-csi-xy(port, 24, 1)
  editor-csi(port, 55, 109)
  serial-put(port, 32)
  serial-write-cstr(port, editor-name)
  if editor-dirty != 0 { serial-put(port, 43) } else { serial-put(port, 32) }
  serial-write-cstr(port, "  Ctrl-S save  Ctrl-F find  Ctrl-Q quit")
  editor-csi(port, 0, 75)
  editor-csi(port, 48, 109)
  serial-put(port, 27)
  serial-put(port, 91)
  serial-put(port, 63)
  serial-put(port, 50)
  serial-put(port, 53)
  serial-put(port, 104)
  editor-csi-xy(port, editor-row - editor-scroll + 1, editor-col + 6)
  return
}

fn editor-match(start: Int, query-len: Int) -> Int {
  if query-len == 0 { return -1 }
  let i = start
  while i + query-len <= editor-len {
    let j = 0
    while j < query-len && load8(editor-buf + i + j) == load8(editor-query + j) { j = j + 1 }
    if j == query-len { return i }
    i = i + 1
  }
  return -1
}

fn editor-cursor-at(offset: Int) -> void {
  editor-row = 0
  editor-col = 0
  let i = 0
  while i < offset {
    if load8(editor-buf + i) == 10 { editor-row = editor-row + 1; editor-col = 0 } else { editor-col = editor-col + 1 }
    i = i + 1
  }
  return
}

fn editor-find(port: Int) -> void {
  let len = 0
  store8(editor-query, 0)
  while true {
    editor-csi-xy(port, 23, 1)
    serial-write-cstr(port, "find: ")
    serial-write-cstr(port, editor-query)
    editor-csi(port, 0, 75)
    let found = editor-match(editor-offset() + 1, len)
    if found >= 0 { editor-cursor-at(found); editor-render(port) }
    let ch = editor-read-key(port)
    if ch == 27 || ch == 13 || ch == 10 { return }
    if ch == 8 || ch == 127 {
      if len > 0 { len = len - 1; store8(editor-query + len, 0) }
    } else if ch >= 32 && ch < 127 && len < 127 {
      store8(editor-query + len, ch)
      len = len + 1
      store8(editor-query + len, 0)
    }
  }
  return
}

fn editor-save() -> Int {
  let rc = 0
  if volume-ready != 0 {
    let n = volume-rpc-write-file(editor-name, editor-buf, editor-len)
    if n < 0 {
      rc = -1
    } else {
      rc = 0
    }
  } else {
    rc = sparkfs-write(editor-name, editor-buf, editor-len)
  }
  if rc == 0 { editor-dirty = 0 }
  return rc
}

fn editor-run(port: Int, name: Int) -> void {
  if name == 0 || load8(name) == 0 {
    serial-write-cstr(port, "usage: edit <file>")
    serial-nl(port)
    return
  }
  if editor-buf == 0 { editor-buf = alloc(EDITOR-BUF-SIZE); editor-name = alloc(EDITOR-NAME-SIZE); editor-query = alloc(128) }
  if volume-ready != 0 {
    editor-len = volume-rpc-read-file(name, editor-buf, EDITOR-BUF-SIZE - 1)
  } else {
    editor-len = sparkfs-read(name, editor-buf, EDITOR-BUF-SIZE - 1)
  }
  if editor-len < 0 { editor-len = 0; store8(editor-buf, 0) }
  if volume-ready != 0 {
    let st = alloc(64)
    if volume-rpc-stat(name, st) == 0 && load32(st + SF-ST-TYPE) != SF-TYPE-FILE {
      serial-write-cstr(port, "edit: not a file")
      serial-nl(port)
      return
    }
  } else {
    let inode = sf-lookup-path(name)
    if inode >= 0 && load32(sf-inode-addr(inode) + SF-IN-TYPE) != SF-TYPE-FILE {
      serial-write-cstr(port, "edit: not a file")
      serial-nl(port)
      return
    }
  }
  editor-copy(editor-name, name, EDITOR-NAME-SIZE)
  editor-row = 0
  editor-col = 0
  editor-scroll = 0
  editor-dirty = 0
  editor-pushback = 0
  editor-alt-enter(port)
  editor-render(port)
  while true {
    let ch = editor-read-key(port)
    if ch == 17 {
      if editor-dirty != 0 {
        editor-alt-exit(port)
        serial-write-cstr(port, "edit: unsaved changes. Ctrl-Q again discards; other key resumes.")
        serial-nl(port)
        if editor-read-key(port) != 17 { editor-alt-enter(port); editor-render(port); continue }
      }
      editor-alt-exit(port)
      return
    }
    if ch == 19 { editor-save(); editor-render(port); continue }
    if ch == 6 { editor-find(port); editor-render(port); continue }
    if ch == EDITOR-KEY-LEFT { editor-left() } else if ch == EDITOR-KEY-RIGHT { editor-right() } else if ch == EDITOR-KEY-UP { editor-vertical(-1) } else if ch == EDITOR-KEY-DOWN { editor-vertical(1) } else if ch == EDITOR-KEY-HOME { editor-col = 0 } else if ch == EDITOR-KEY-END { editor-col = editor-row-length(editor-row) } else if ch == EDITOR-KEY-PGUP { editor-vertical(-22) } else if ch == EDITOR-KEY-PGDN { editor-vertical(22) } else if ch == EDITOR-KEY-DELETE { editor-delete() } else if ch == 13 || ch == 10 { editor-insert(10); editor-row = editor-row + 1; editor-col = 0 } else if ch == 8 || ch == 127 { editor-backspace() } else if ch == 9 { editor-insert(32); editor-col = editor-col + 1; editor-insert(32); editor-col = editor-col + 1 } else if ch >= 32 && ch < 127 { editor-insert(ch); editor-col = editor-col + 1 }
    editor-render(port)
  }
  return
}
