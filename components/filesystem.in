package space.kernel

// SparkFS public compatibility API.

fn fs-init() -> void {
  sparkfs-init()
  return
}

fn fs-format() -> Int {
  return sparkfs-format()
}

fn fs-list(port: Int) -> void {
  sparkfs-list("/", port)
  return
}

fn fs-list-path(path: Int, port: Int) -> void {
  sparkfs-list(path, port)
  return
}

fn fs-read-file(name: Int, buf: Int) -> Int {
  if volume-ready != 0 {
    return volume-rpc-read-file(name, buf, 0x100000)
  }
  return sparkfs-read(name, buf, 0x7FFFFFFF)
}

fn fs-write-file(name: Int, buf: Int, size: Int) -> Int {
  if volume-ready != 0 {
    let n = volume-rpc-write-file(name, buf, size)
    if n < 0 {
      return -1
    }
    return 0
  }
  return sparkfs-write(name, buf, size)
}

fn fs-delete(name: Int) -> Int {
  if volume-ready != 0 {
    return volume-rpc-delete(name)
  }
  return sparkfs-delete(name)
}

fn fs-mkdir(path: Int) -> Int {
  if volume-ready != 0 {
    return volume-rpc-mkdir(path)
  }
  return sparkfs-mkdir(path)
}

fn fs-rmdir(path: Int) -> Int {
  if volume-ready != 0 {
    return volume-rpc-rmdir(path)
  }
  return sparkfs-rmdir(path)
}

fn fs-rename(old: Int, new: Int) -> Int {
  if volume-ready != 0 {
    return volume-rpc-rename(old, new)
  }
  return sparkfs-rename(old, new)
}

fn fs-stat(path: Int, buf: Int) -> Int {
  if volume-ready != 0 {
    return volume-rpc-stat(path, buf)
  }
  return sparkfs-stat(path, buf)
}

fn fs-open-path(path: Int) -> Int {
  if volume-ready != 0 {
    return volume-rpc-open(path, 0)
  }
  let ino = sf-lookup-path(path)
  if ino < 0 {
    return -1
  }
  return ino
}
