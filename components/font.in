// Wayland-style compositor for the Space nanokernel.
// Manages windows, renders them to the VBE framebuffer, and handles
// mouse/keyboard input. This is a minimal display server that demonstrates
// the Space OS desktop environment.
//
// Window record (64 bytes):
//   [0..4]   id
//   [4..8]   x
//   [8..12]  y
//   [12..16] width
//   [16..20] height
//   [20..24] flags (bit 0 = visible, bit 1 = focused, bit 2 = dirty)
//   [24..32] title string address
//   [32..40] content buffer address (or 0 for auto-rendered)
//   [40..48] reserved
//   [48..56] reserved
//   [56..64] reserved

// --- window constants -------------------------------------------------------
const COMP-MAX-WINDOWS = 16
const COMP-WIN-SIZE = 64
const COMP-TITLE-BAR-H = 28
const COMP-BORDER-W = 1
const COMP-TASKBAR-H = 28
const COMP-COLOR-DESKTOP = 0x000B0909
const COMP-COLOR-PANEL = 0x001B1818
const COMP-COLOR-PANEL-LINE = 0x0027272A
const COMP-COLOR-TITLE = 0x00333336
const COMP-COLOR-TITLE-ACTIVE = 0x00444444
const COMP-COLOR-WINDOW = 0x00FFFFFF
const COMP-COLOR-BORDER = 0x003F3F46
const COMP-COLOR-ACCENT = 0x00F8BD38
const COMP-COLOR-TEXT = 0x0018181B
const COMP-COLOR-MUTED = 0x00AAA1A1
const COMP-COLOR-SURFACE = 0x00FFFFFF
const COMP-COLOR-SURFACE-ALT = 0x00E4E4E7
const COMP-COLOR-TERM-BG = 0x000B0909
const COMP-COLOR-TERM-TEXT = 0x00F5F4F4

const COMP-WIN-VISIBLE = 1
const COMP-WIN-FOCUSED = 2
const COMP-WIN-DIRTY = 4
const COMP-WIN-MINIMIZED = 8
const COMP-CURSOR-W = 16
const COMP-CURSOR-H = 16
const COMP-ROLE-TEXT = 0
const COMP-ROLE-UTILITIES = 2
const COMP-ROLE-TERMINAL = 3
const COMP-MIN-WIN-W = 280
const COMP-MIN-WIN-H = 180
const COMP-MIN-EDITOR-W = 640
const COMP-MIN-SIDE-W = 520

// --- compositor state -------------------------------------------------------
var comp-windows: Int = 0    // array of window records
var comp-count: Int = 0      // number of windows
var comp-focused: Int = 0    // index of focused window
// Track drag mode: 1 = move (title bar), 2 = resize (bottom-right corner)
var comp-drag-mode: Int = 0   // index of window being dragged (-1 = none)
var comp-drag-off-x: Int = 0 // drag offset from window origin to mouse
var comp-drag-off-y: Int = 0
var comp-running: Int = 0    // 1 when compositor loop is active
// --- window management ------------------------------------------------------

// Initialize the compositor.
fn comp-init() -> void {
  // ponytail: backbuffer at top of heap avoids alloc/heap_next (optimizer crash).
  if fb-width > 0 && fb-height > 0 {
    let heap-top = 0x0FFE0000
    let sz = fb-width * fb-height * 4
    comp-backbuf = heap-top - ((sz + 4095) & -4096)
  }
  comp-windows = alloc(COMP-MAX-WINDOWS * COMP-WIN-SIZE)
  let i = 0
  while i < COMP-MAX-WINDOWS {
    comp-win-clear(i)
    i = i + 1
  }
  comp-count = 0
  comp-focused = -1
  comp-drag-mode = -1
  comp-dragging = -1
  comp-running = 0
  comp-cur-drawn = 0
  comp-cursor-init()
  comp-term-init()
  return
}



// Clear a window slot.
fn comp-win-clear(idx: Int) -> void {
  let base = comp-windows + idx * COMP-WIN-SIZE
  let i = 0
  while i < COMP-WIN-SIZE {
    store8(base + i, 0)
    i = i + 1
  }
  return
}

// Get the base address of a window record.
fn comp-win-base(idx: Int) -> Int {
  return comp-windows + idx * COMP-WIN-SIZE
}

// Create a new window. Returns the window index or -1 if the table is full.
fn comp-win-create(title: Int, x: Int, y: Int, w: Int, h: Int) -> Int {
  if comp-count >= COMP-MAX-WINDOWS {
    return -1
  }
  let idx = comp-count
  let base = comp-win-base(idx)
  store32(base + 0, idx)
  store32(base + 4, x)
  store32(base + 8, y)
  store32(base + 12, w)
  store32(base + 16, h)
  store32(base + 20, COMP-WIN-VISIBLE | COMP-WIN-DIRTY)
  store64(base + 24, title)
  store64(base + 32, 0)
  store64(base + 40, COMP-ROLE-TEXT)
  comp-count = comp-count + 1
  comp-focused = idx
  return idx
}

// Set a window's content buffer (for custom rendering).
fn comp-win-set-content(idx: Int, buf: Int) -> void {
  if idx < 0 || idx >= comp-count {
    return
  }
  store64(comp-win-base(idx) + 32, buf)
  return
}

fn comp-win-set-role(idx: Int, role: Int) -> void {
  if idx < 0 || idx >= comp-count {
    return
  }
  store64(comp-win-base(idx) + 40, role)
  return
}

// Check if a point is inside a window's title bar.
fn comp-win-in-titlebar(idx: Int, mx: Int, my: Int) -> Int {
  let base = comp-win-base(idx)
  let x = load32(base + 4)
  let y = load32(base + 8)
  let w = load32(base + 12)
  if mx >= x && mx < x + w && my >= y && my < y + COMP-TITLE-BAR-H {
    return 1
  }
  return 0
}

// Check if a point is inside a window (including title bar).
fn comp-win-contains(idx: Int, mx: Int, my: Int) -> Int {
  let base = comp-win-base(idx)
  let x = load32(base + 4)
  let y = load32(base + 8)
  let w = load32(base + 12)
  let h = load32(base + 16)
  if mx >= x && mx < x + w && my >= y && my < y + h + COMP-TITLE-BAR-H {
    return 1
  }
  return 0
}

// Find the topmost window at a point. Returns index or -1.
fn comp-win-at-point(mx: Int, my: Int) -> Int {
  let i = comp-count - 1
  while i >= 0 {
    let flags = load32(comp-win-base(i) + 20)
    if (flags & COMP-WIN-VISIBLE) != 0 {
      if comp-win-contains(i, mx, my) != 0 {
        return i
      }
    }
    i = i - 1
  }
  return -1
}

// Focus a window (bring to front conceptually — we just update the focused flag).
fn comp-win-close(idx: Int) -> void {
  if idx < 0 || idx >= comp-count {
    return
  }
  // Shift remaining windows down
  let i = idx
  while i < comp-count - 1 {
    let src = comp-win-base(i + 1)
    let dst = comp-win-base(i)
    let j = 0
    while j < COMP-WIN-SIZE {
      store8(dst + j, load8(src + j))
      j = j + 1
    }
    i = i + 1
  }
  comp-win-clear(comp-count - 1)
  comp-count = comp-count - 1
  // Adjust focused index
  if comp-focused >= comp-count {
    comp-focused = comp-count - 1
  }
  // Mark full redraw (window removed)
  comp-full-redraw = 1
  return
}

// Minimize window — clear VISIBLE flag, set MINIMIZED.
fn comp-win-minimize(idx: Int) -> void {
  if idx < 0 || idx >= comp-count {
    return
  }
  let base = comp-win-base(idx)
  let flags = load32(base + 20)
  store32(base + 20, (flags | COMP-WIN-MINIMIZED | COMP-WIN-DIRTY) & -2)
  comp-full-redraw = 1
  return
}

// Restore a minimized window — set VISIBLE, clear MINIMIZED.
fn comp-win-restore(idx: Int) -> void {
  if idx < 0 || idx >= comp-count {
    return
  }
  let base = comp-win-base(idx)
  let flags = load32(base + 20)
  store32(base + 20, (flags & -9) | COMP-WIN-VISIBLE | COMP-WIN-DIRTY)
  comp-win-focus(idx)
  comp-full-redraw = 1
  return
}

// Focus a window (bring to front conceptually — we just update the focused flag).
fn comp-win-focus(idx: Int) -> void {
  let i = 0
  while i < comp-count {
    let base = comp-win-base(i)
    let flags = load32(base + 20)
    if i == idx {
      store32(base + 20, flags | COMP-WIN-FOCUSED | COMP-WIN-DIRTY)
    } else {
      store32(base + 20, (flags & -3) | COMP-WIN-DIRTY)
    }
    i = i + 1
  }
  comp-focused = idx
  return
}

// --- rendering --------------------------------------------------------------

// Draw the desktop background (flat color, no stripes — ponytail: stripes were 20 loops per frame).
fn comp-render-background() -> void {
  fb-clear(COMP-COLOR-DESKTOP)
}

// X11-style arrow cursor bitmap (16x16, top-left hotspot)
// MSB = leftmost pixel, row-major, 2 bytes per row, 32 bytes total
var comp-cursor-bits: Int = 0

fn comp-cursor-init() -> void {
  comp-cursor-bits = alloc(32)
  store8(comp-cursor-bits + 0, 0x80); store8(comp-cursor-bits + 1, 0x00)
  store8(comp-cursor-bits + 2, 0xC0); store8(comp-cursor-bits + 3, 0x00)
  store8(comp-cursor-bits + 4, 0xE0); store8(comp-cursor-bits + 5, 0x00)
  store8(comp-cursor-bits + 6, 0xF0); store8(comp-cursor-bits + 7, 0x00)
  store8(comp-cursor-bits + 8, 0xF8); store8(comp-cursor-bits + 9, 0x00)
  store8(comp-cursor-bits + 10, 0xFC); store8(comp-cursor-bits + 11, 0x00)
  store8(comp-cursor-bits + 12, 0xFE); store8(comp-cursor-bits + 13, 0x00)
  store8(comp-cursor-bits + 14, 0xFF); store8(comp-cursor-bits + 15, 0x00)
  store8(comp-cursor-bits + 16, 0xFF); store8(comp-cursor-bits + 17, 0x80)
  store8(comp-cursor-bits + 18, 0xFF); store8(comp-cursor-bits + 19, 0xC0)
  store8(comp-cursor-bits + 20, 0xFF); store8(comp-cursor-bits + 21, 0xE0)
  store8(comp-cursor-bits + 22, 0xFC); store8(comp-cursor-bits + 23, 0x00)
  store8(comp-cursor-bits + 24, 0xFC); store8(comp-cursor-bits + 25, 0x60)
  store8(comp-cursor-bits + 26, 0xFC); store8(comp-cursor-bits + 27, 0x70)
  store8(comp-cursor-bits + 28, 0xFC); store8(comp-cursor-bits + 29, 0x38)
  store8(comp-cursor-bits + 30, 0x00); store8(comp-cursor-bits + 31, 0x1C)
}

// Draw the X11-style arrow cursor (white, no outline — ponytail: outline was 256 extra pixel calls per frame).
fn comp-render-cursor() -> void {
  let x = mouse-x
  let y = mouse-y
  let row = 0
  while row < COMP-CURSOR-H {
    let b0 = load8(comp-cursor-bits + row * 2)
    let b1 = load8(comp-cursor-bits + row * 2 + 1)
    let col = 0
    while col < COMP-CURSOR-W {
      let bit = 0
      if col < 8 {
        bit = (b0 >> (7 - col)) & 1
      } else {
        bit = (b1 >> (15 - col)) & 1
      }
      if bit != 0 {
        let px = x + col
        let py = y + row
        fb-put-pixel(px, py, FB-COLOR-WHITE)
      }
      col = col + 1
    }
    row = row + 1
  }
}

