package space.display

const FB-FONT-WIDTH = 8
const FB-FONT-HEIGHT = 8
var fb-font: Int = 0

fn fb-font-set(ch: Int, r0: Int, r1: Int, r2: Int, r3: Int, r4: Int, r5: Int, r6: Int, r7: Int) -> void {
  let p = fb-font + ch * 8
  store8(p + 0, r0)
  store8(p + 1, r1)
  store8(p + 2, r2)
  store8(p + 3, r3)
  store8(p + 4, r4)
  store8(p + 5, r5)
  store8(p + 6, r6)
  store8(p + 7, r7)
  return
}

// Initialize the 8x8 bitmap font with a basic ASCII subset.
fn fb-font-init() -> void {
  fb-font = alloc(128 * 8)
  let i = 0
  while i < 1024 {
    store8(fb-font + i, 0)
    i = i + 1
  }
  // Space (32)
  fb-font-set(32, 0, 0, 0, 0, 0, 0, 0, 0)
  // ! (33)
  fb-font-set(33, 0x18, 0x18, 0x18, 0x18, 0x18, 0x00, 0x18, 0x00)
  // " (34)
  fb-font-set(34, 0x66, 0x66, 0x66, 0x00, 0x00, 0x00, 0x00, 0x00)
  // ( (40)
  fb-font-set(40, 0x0C, 0x18, 0x30, 0x30, 0x30, 0x18, 0x0C, 0x00)
  // ) (41)
  fb-font-set(41, 0x30, 0x18, 0x0C, 0x0C, 0x0C, 0x18, 0x30, 0x00)
  // * (42)
  fb-font-set(42, 0x00, 0x66, 0x3C, 0xFF, 0x3C, 0x66, 0x00, 0x00)
  // + (43)
  fb-font-set(43, 0x00, 0x18, 0x18, 0x7E, 0x18, 0x18, 0x00, 0x00)
  // , (44)
  fb-font-set(44, 0x00, 0x00, 0x00, 0x00, 0x00, 0x18, 0x18, 0x30)
  // - (45)
  fb-font-set(45, 0x00, 0x00, 0x00, 0x7E, 0x00, 0x00, 0x00, 0x00)
  // . (46)
  fb-font-set(46, 0x00, 0x00, 0x00, 0x00, 0x00, 0x18, 0x18, 0x00)
  // / (47)
  fb-font-set(47, 0x00, 0x03, 0x07, 0x0E, 0x1C, 0x38, 0x70, 0x60)
  // 0-9 (48-57)
  fb-font-set(48, 0x3C, 0x66, 0x6E, 0x76, 0x66, 0x66, 0x3C, 0x00)
  fb-font-set(49, 0x18, 0x38, 0x18, 0x18, 0x18, 0x18, 0x7E, 0x00)
  fb-font-set(50, 0x3C, 0x66, 0x06, 0x0C, 0x30, 0x60, 0x7E, 0x00)
  fb-font-set(51, 0x3C, 0x66, 0x06, 0x1C, 0x06, 0x66, 0x3C, 0x00)
  fb-font-set(52, 0x0E, 0x1E, 0x36, 0x66, 0x7F, 0x06, 0x06, 0x00)
  fb-font-set(53, 0x7E, 0x60, 0x7C, 0x06, 0x06, 0x66, 0x3C, 0x00)
  fb-font-set(54, 0x3C, 0x66, 0x60, 0x7C, 0x66, 0x66, 0x3C, 0x00)
  fb-font-set(55, 0x7E, 0x66, 0x0C, 0x18, 0x18, 0x18, 0x18, 0x00)
  fb-font-set(56, 0x3C, 0x66, 0x66, 0x3C, 0x66, 0x66, 0x3C, 0x00)
  fb-font-set(57, 0x3C, 0x66, 0x66, 0x3E, 0x06, 0x66, 0x3C, 0x00)
  // : (58)
  fb-font-set(58, 0x00, 0x18, 0x18, 0x00, 0x00, 0x18, 0x18, 0x00)
  // ; (59)
  fb-font-set(59, 0x00, 0x18, 0x18, 0x00, 0x00, 0x18, 0x18, 0x30)
  // < (60)
  fb-font-set(60, 0x06, 0x0C, 0x18, 0x30, 0x18, 0x0C, 0x06, 0x00)
  // = (61)
  fb-font-set(61, 0x00, 0x00, 0x7E, 0x00, 0x7E, 0x00, 0x00, 0x00)
  // > (62)
  fb-font-set(62, 0x60, 0x30, 0x18, 0x0C, 0x18, 0x30, 0x60, 0x00)
  // ? (63)
  fb-font-set(63, 0x3C, 0x66, 0x06, 0x0C, 0x18, 0x00, 0x18, 0x00)
  // A-Z (65-90)
  fb-font-set(65, 0x18, 0x3C, 0x66, 0x66, 0x7E, 0x66, 0x66, 0x00)
  fb-font-set(66, 0x7C, 0x66, 0x66, 0x7C, 0x66, 0x66, 0x7C, 0x00)
