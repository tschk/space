  fb-font-set(126, 0x00, 0x00, 0x60, 0x7E, 0x06, 0x00, 0x00, 0x00)
  // # (35)
  fb-font-set(35, 0x66, 0x66, 0xFF, 0xFF, 0x66, 0x66, 0xFF, 0xFF)
  return
}

fn fb-glyph8(ch: Int, row: Int) -> Int {
  if ch == 33 && row == 0 { return 0x18 }
  if ch == 33 && row == 1 { return 0x18 }
  if ch == 33 && row == 2 { return 0x18 }
  if ch == 33 && row == 3 { return 0x18 }
  if ch == 33 && row == 4 { return 0x18 }
  if ch == 33 && row == 6 { return 0x18 }
  if ch == 34 && row == 0 { return 0x66 }
  if ch == 34 && row == 1 { return 0x66 }
  if ch == 34 && row == 2 { return 0x66 }
  if ch == 35 && row == 0 { return 0x66 }
  if ch == 35 && row == 1 { return 0x66 }
  if ch == 35 && row == 2 { return 0xFF }
