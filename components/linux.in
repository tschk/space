package space.kernel

import "posix.in"

// Linux personality layer for the Space nanokernel.
// This file is now a thin dispatch wrapper over the extracted Posix component.
// The component runs in its own domain and services POSIX syscall requests over
// a cross-domain shared page at LINUX_POSIX_VIRT.

const LINUX-POSIX-VIRT = 0xFFFFA000

var posix-domain: Int = 0
var posix-shared-page: Int = 0
var posix-cap-info: Int = 0
var posix-active: Int = 0

fn linux-init() -> void {
  if posix-active != 0 {
    return
  }
  posix-domain = domain-create()
  if posix-domain == 0 {
    posix-domain = 1
  }
  let shared-phys = domain-create-shared-page(0, posix-domain, LINUX-POSIX-VIRT, LINUX-POSIX-VIRT)
  if shared-phys == 0 {
    posix-shared-page = alloc(4096)
  } else {
    posix-shared-page = LINUX-POSIX-VIRT
  }
  let i = 0
  while i < 512 {
    store64(posix-shared-page + i * 8, 0)
    i = i + 1
  }
  posix-cap-info = alloc(24)
  store64(posix-cap-info + 0, cap-count)
  store64(posix-cap-info + 8, cap-table-base)
  store64(posix-cap-info + 16, posix-shared-page)
  component-register("posix", posix-entry, cap-serial() | cap-memory())
  domain-switch(posix-domain)
  posix-init()
  domain-switch(0)
  posix-active = 1
  return
}

fn linux-dispatch(num: Int, a0: Int, a1: Int, a2: Int, a3: Int, a4: Int, a5: Int) -> Int {
  if posix-active == 0 {
    linux-init()
  }
  while load64(posix-shared-page + POSIX-RPC-OFF-REQ) != 0 {
  }
  store64(posix-shared-page + POSIX-RPC-OFF-NUM, num)
  store64(posix-shared-page + POSIX-RPC-OFF-A0, a0)
  store64(posix-shared-page + POSIX-RPC-OFF-A1, a1)
  store64(posix-shared-page + POSIX-RPC-OFF-A2, a2)
  store64(posix-shared-page + POSIX-RPC-OFF-A3, a3)
  store64(posix-shared-page + POSIX-RPC-OFF-A4, a4)
  store64(posix-shared-page + POSIX-RPC-OFF-A5, a5)
  store64(posix-shared-page + POSIX-RPC-OFF-REQ, 1)
  store64(posix-shared-page + POSIX-RPC-OFF-RESP, 0)
  domain-switch(posix-domain)
  posix-service(posix-shared-page)
  domain-switch(0)
  return load64(posix-shared-page + POSIX-RPC-OFF-RES)
}

fn linux-elf-probe(port: Int) -> void {
  if load64(LINUX-ELF-LOAD-ADDR) == LINUX-ELF-MAGIC {
    let rc2 = posix-exec-image(port, LINUX-ELF-LOAD-ADDR, 4096, "space-minimal-elf")
    serial-write-cstr(port, "linux: ELF exec returned ")
    serial-write-dec-wide(port, rc2)
    serial-nl(port)
    return
  }
  let elf = alloc(64)
  let i = 0
  while i < 64 {
    store8(elf + i, 0)
    i = i + 1
  }
  store8(elf + 0, 0x7F)
  store8(elf + 1, 0x45)
  store8(elf + 2, 0x4C)
  store8(elf + 3, 0x46)
  store8(elf + 4, 2)
  store8(elf + 5, 1)
  store8(elf + 6, 1)
  let rc = posix-exec-image(port, elf, 64, "helium-probe")
  serial-write-cstr(port, "linux: ELF execve probe = ")
  serial-write-dec-wide(port, rc)
  if rc == LINUX-ENOEXEC {
    serial-write-cstr(port, " (expected before Linux ELF loader)")
  }
  serial-nl(port)
  return
}

fn linux-demo(port: Int) -> void {
  serial-write-cstr(port, "linux: personality demo starting")
  serial-nl(port)

  let msg = "  hello from linux personality (POSIX write syscall)\n"
  let mlen = 0
  while load8(msg + mlen) != 0 {
    mlen = mlen + 1
  }
  let wrc = linux-dispatch(LINUX-SYS-WRITE, 1, msg, mlen, 0, 0, 0)
  serial-write-cstr(port, "linux: write(1, msg, ")
  serial-write-dec-wide(port, mlen)
  serial-write-cstr(port, ") = ")
  serial-write-dec-wide(port, wrc)
  serial-nl(port)

  let pid = linux-dispatch(LINUX-SYS-GETPID, 0, 0, 0, 0, 0, 0)
  serial-write-cstr(port, "linux: getpid() = ")
  serial-write-dec-wide(port, pid)
  serial-nl(port)

  let fname = "hello.txt"
  let fd = linux-dispatch(LINUX-SYS-OPEN, fname, LINUX-O-CREAT | LINUX-O-RDWR, 0, 0, 0, 0)
  serial-write-cstr(port, "linux: open(hello.txt, O_CREAT|O_RDWR) = ")
  serial-write-dec-wide(port, fd)
  serial-nl(port)

  if fd >= 0 {
    let content = "linux file content"
    let clen = 0
    while load8(content + clen) != 0 {
      clen = clen + 1
    }
    let fwrc = linux-dispatch(LINUX-SYS-WRITE, fd, content, clen, 0, 0, 0)
    serial-write-cstr(port, "linux: write(fd, content, ")
    serial-write-dec-wide(port, clen)
    serial-write-cstr(port, ") = ")
    serial-write-dec-wide(port, fwrc)
    serial-nl(port)

    linux-dispatch(LINUX-SYS-CLOSE, fd, 0, 0, 0, 0, 0)
    serial-write-cstr(port, "linux: close(fd) = 0")
    serial-nl(port)
  }

  let rfd = linux-dispatch(LINUX-SYS-OPEN, fname, LINUX-O-RDONLY, 0, 0, 0, 0)
  serial-write-cstr(port, "linux: open(hello.txt, O_RDONLY) = ")
  serial-write-dec-wide(port, rfd)
  serial-nl(port)

  if rfd >= 0 {
    let rbuf = alloc(256)
    let rlen = linux-dispatch(LINUX-SYS-READ, rfd, rbuf, 255, 0, 0, 0)
    serial-write-cstr(port, "linux: read(fd, buf, 255) = ")
    serial-write-dec-wide(port, rlen)
    serial-write-cstr(port, " -> '")
    let ri = 0
    while ri < rlen {
      serial-put(port, load8(rbuf + ri))
      ri = ri + 1
    }
    serial-write-cstr(port, "'")
    serial-nl(port)

    linux-dispatch(LINUX-SYS-WRITE, 1, rbuf, rlen, 0, 0, 0)
    serial-nl(port)

    linux-dispatch(LINUX-SYS-CLOSE, rfd, 0, 0, 0, 0, 0)
    serial-write-cstr(port, "linux: close(fd) = 0")
    serial-nl(port)
  }

  let statbuf = alloc(LINUX-STAT-SIZE)
  let src = linux-dispatch(LINUX-SYS-STAT, fname, statbuf, 0, 0, 0, 0)
  serial-write-cstr(port, "linux: stat(hello.txt) = ")
  serial-write-dec-wide(port, src)
  if src == 0 {
    let fsize = load64(statbuf + LINUX-STAT-OFF-SIZE)
    serial-write-cstr(port, ", st_size = ")
    serial-write-dec-wide(port, fsize)
    let fblocks = load64(statbuf + LINUX-STAT-OFF-BLOCKS)
    serial-write-cstr(port, ", st_blocks = ")
    serial-write-dec-wide(port, fblocks)
  }
  serial-nl(port)

  let cwdbuf = alloc(64)
  let cwdrc = linux-dispatch(LINUX-SYS-GETCWD, cwdbuf, 64, 0, 0, 0, 0)
  serial-write-cstr(port, "linux: getcwd() = '")
  serial-write-cstr(port, cwdbuf)
  serial-write-cstr(port, "'")
  serial-nl(port)

  let sfd = linux-dispatch(LINUX-SYS-OPEN, fname, LINUX-O-RDONLY, 0, 0, 0, 0)
  if sfd >= 0 {
    let pos = linux-dispatch(LINUX-SYS-LSEEK, sfd, 6, 0, 0, 0, 0)
    serial-write-cstr(port, "linux: lseek(fd, 6, SEEK_SET) = ")
    serial-write-dec-wide(port, pos)
    serial-nl(port)
    let sbuf2 = alloc(64)
    let slen = linux-dispatch(LINUX-SYS-READ, sfd, sbuf2, 63, 0, 0, 0)
    serial-write-cstr(port, "linux: read at offset 6 -> '")
    let si = 0
    while si < slen {
      serial-put(port, load8(sbuf2 + si))
      si = si + 1
    }
    serial-write-cstr(port, "'")
    serial-nl(port)
    linux-dispatch(LINUX-SYS-CLOSE, sfd, 0, 0, 0, 0, 0)
  }

  serial-write-cstr(port, "linux: personality demo complete")
  serial-nl(port)
  return
}
