package space.kernel

// --- syscall trap (int 0x80) ------------------------------------------------
// User programs request kernel services via int 0x80. The assembly stub
// (isr_syscall) saves all 15 GP registers into a frame on the stack and calls
// syscall_dispatch with a pointer to that frame. The dispatch function reads
// the syscall number from RAX (frame offset 112) and the arguments from
// RDI (72), RSI (80), RDX (88), then writes the return value back into the
// RAX slot so the stub's iretq delivers it to the caller.
//
// Frame layout (matches push order in isr_syscall):
//   rax=112 rbx=104 rcx=96 rdx=88 rsi=80 rdi=72 rbp=64
//   r8=56 r9=48 r10=40 r11=32 r12=24 r13=16 r14=8 r15=0

fn sys-write(fd: Int, buf: Int, len: Int) -> Int {
  if fd != 1 {
    return -1
  }
  let port = com1()
  let i = 0
  while i < len {
    serial-put(port, load8(buf + i))
    i = i + 1
  }
  return len
}

// Syscall 1: sys_read(fd, buf, len) — read from serial (fd=0 = stdin, blocking).
// Reads up to len bytes, stopping at a newline, and returns the byte count.
fn sys-read(fd: Int, buf: Int, len: Int) -> Int {
  if fd != 0 {
    return -1
  }
  let port = com1()
  let i = 0
  while i < len {
    let c = serial-read(port)
    store8(buf + i, c)
    i = i + 1
    if c == 10 || c == 13 {
      return i
    }
  }
  return len
}

// Syscall 2: sys_exit(code) — exit the current process/component.
// In kernel context (thread 0) this halts the nanokernel.
fn sys-exit(code: Int) -> Int {
  let port = com1()
  serial-write-cstr(port, "space: sys_exit(code=0x")
  serial-write-hex(port, code)
  serial-write-cstr(port, ") from thread 0x")
  serial-write-hex(port, current-task)
  serial-nl(port)
  cli()
  while true {
    hlt()
  }
  return 0
}

// Syscall 3: sys_yield() — yield CPU to scheduler.
// In kernel context this is a no-op since there is nothing to yield to.
fn sys-yield() -> Int {
  return 0
}

// Syscall 4: sys_getpid() — return current thread ID.
fn sys-getpid() -> Int {
  return current-task
}

// Syscall 5: sys_chan_create(cap) — create a channel with capacity.
fn sys-chan-create(cap: Int) -> Int {
  return chan-new(cap)
}

// Syscall 6: sys_chan_send(ch, msg) — send a message to a channel.
fn sys-chan-send(ch: Int, msg: Int) -> void {
  chan-send(ch, msg)
  return
}

// Syscall 7: sys_chan_recv(ch) — receive a message from a channel.
fn sys-chan-recv(ch: Int) -> Int {
  return chan-recv(ch)
}

// Syscall 8: sys_chan_close(ch) — close/free a channel.
fn sys-chan-close(ch: Int) -> Int {
  chan-heap-free(ch)
  return 0
}

fn sys-cap-mint(target-obj: Int, rights: Int) -> Int {
  return cap-mint(target-obj, rights)
}

fn sys-cap-revoke(idx: Int) -> Int {
  return cap-revoke(idx)
}

fn sys-cap-check(idx: Int, rights: Int) -> Int {
  return cap-check(idx, rights)
}

// Dispatch a syscall based on the number in the saved RAX slot of the frame.
// Writes the return value back into the RAX slot (frame offset 112).
fn syscall-dispatch(frame: Int) -> void {
  let num = load64(frame + 112)
  if num == 0 {
    let fd = load64(frame + 72)
    let buf = load64(frame + 80)
    let len = load64(frame + 88)
    store64(frame + 112, sys-write(fd, buf, len))
  } else if num == 1 {
    let fd = load64(frame + 72)
    let buf = load64(frame + 80)
    let len = load64(frame + 88)
    store64(frame + 112, sys-read(fd, buf, len))
  } else if num == 2 {
    let code = load64(frame + 72)
    store64(frame + 112, sys-exit(code))
  } else if num == 3 {
    store64(frame + 112, sys-yield())
  } else if num == 4 {
    store64(frame + 112, sys-getpid())
  } else if num == 5 {
    let cap = load64(frame + 72)
    store64(frame + 112, sys-chan-create(cap))
  } else if num == 6 {
    let ch = load64(frame + 72)
    let msg = load64(frame + 80)
    sys-chan-send(ch, msg)
    store64(frame + 112, 0)
  } else if num == 7 {
    let ch = load64(frame + 72)
    store64(frame + 112, sys-chan-recv(ch))
  } else if num == 8 {
    let ch = load64(frame + 72)
    store64(frame + 112, sys-chan-close(ch))
  } else if num == 9 {
    let target-obj = load64(frame + 72)
    let rights = load64(frame + 80)
    store64(frame + 112, sys-cap-mint(target-obj, rights))
  } else if num == 10 {
    let idx = load64(frame + 72)
    store64(frame + 112, sys-cap-revoke(idx))
  } else if num == 11 {
    let idx = load64(frame + 72)
    let rights = load64(frame + 80)
    store64(frame + 112, sys-cap-check(idx, rights))
  } else {
    let port = com1()
    serial-write-cstr(port, "space: unknown syscall 0x")
    serial-write-hex(port, num)
    serial-nl(port)
    store64(frame + 112, -1)
  }
  return
}

// Install a 64-bit interrupt gate with DPL=3 so user-mode code can invoke it.
fn idt-set-user(vec: Int, handler: Int) -> void {
  let e = idt-base + vec * 16
  store16(e + 0, handler & 0xFFFF)
  store16(e + 2, 0x08)
  store8(e + 4, 0)
  store8(e + 5, 0xEE)             // present | DPL=3 | interrupt gate
  store16(e + 6, (handler >> 16) & 0xFFFF)
  store32(e + 8, (handler >> 32) & 0xFFFFFFFF)
  store32(e + 12, 0)
  return
}
