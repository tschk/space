package space.kernel

// Windows personality — translator microservice (Win32/NT-shaped surface only).
// Not a kernel ABI and not full Win32/NT. Pattern matches linux.in → posix.in:
// map a small call surface onto Space VFS / process / serial.
//
// Space-local call numbers (not real NT syscall numbers):
//   1  WIN-NtWriteFile / WriteFile
//   2  WIN-GetCurrentProcessId
//   3  WIN-ExitProcess
//   4  WIN-CreateFileA   (path, access: 0=read 1=write/create)
//   5  WIN-ReadFile
//   6  WIN-CloseHandle
//   7  WIN-GetFileSize
//   8  WIN-Sleep         → short pause loop (no thr-yield from shell)
//   9  WIN-GetCurrentThreadId → current-task
//  10  WIN-DeleteFileA   → fs-delete / volume
//  11  WIN-SetFilePointer → vfs-lseek(vfd, off, whence); a0=handle a1=offset a2=whence(0=SET)
//  12  WIN-GetStdHandle  → a0 nStdHandle: -10=stdin→0, -11=stdout→1, -12=stderr→2
//  13  WIN-MoveFileA     → fs-rename; return 1/0
//  14  WIN-FlushFileBuffers → 1 no-op success for open handle
//  15  WIN-CreateDirectoryA → fs-mkdir; return 1/0
//  16  WIN-RemoveDirectoryA → fs-rmdir; return 1/0
//  17  WIN-GetLastError → win-last-error
//  18  WIN-SetLastError → a0 err
//  19  WIN-VirtualAlloc → posix-sys-mmap / alloc; return ptr
//  20  WIN-VirtualFree → posix-sys-munmap stand-in; return 1/0
//  21  WIN-CreateProcessA → proc-spawn-sci; return 100+pid or 0
//  22  WIN-WaitForSingleObject → proc-wait if process handle
//  23  WIN-GetCommandLineA → static "space-windows" cstr ptr
//  24  WIN-WriteConsoleA → WriteFile on stdout/stderr
//  25  WIN-GetModuleFileNameA → copy "space.exe" into buf; return len
//  26  WIN-HeapAlloc → alloc(size) zeroed; a0/a1 heap+flags ignored except size=a2
//  27  WIN-HeapFree → return 1 (bump heap: no real free)
//  28  WIN-CopyFileA → fs-read-file src + fs-write-file dst; return 1/0
//  29  WIN-GetEnvironmentVariableA → PATH→"/", else empty; return len
//  30  WIN-OutputDebugStringA → serial-write-cstr
//
// Honest: not full Win32, not PE loader, not CSRSS, not real NT objects.

const WIN-CALL-WRITEFILE = 1
const WIN-CALL-GETCURRENTPROCESSID = 2
const WIN-CALL-EXITPROCESS = 3
const WIN-CALL-CREATEFILEA = 4
const WIN-CALL-READFILE = 5
const WIN-CALL-CLOSEHANDLE = 6
const WIN-CALL-GETFILESIZE = 7
const WIN-CALL-SLEEP = 8
const WIN-CALL-GETCURRENTTHREADID = 9
const WIN-CALL-DELETEFILEA = 10
const WIN-CALL-SETFILEPOINTER = 11
const WIN-CALL-GETSTDHANDLE = 12
const WIN-CALL-MOVEFILEA = 13
const WIN-CALL-FLUSHFILEBUFFERS = 14
const WIN-CALL-CREATEDIRECTORYA = 15
const WIN-CALL-REMOVEDIRECTORYA = 16
const WIN-CALL-GETLASTERROR = 17
const WIN-CALL-SETLASTERROR = 18
const WIN-CALL-VIRTUALALLOC = 19
const WIN-CALL-VIRTUALFREE = 20
const WIN-CALL-CREATEPROCESSA = 21
const WIN-CALL-WAITFORSINGLEOBJECT = 22
const WIN-CALL-GETCOMMANDLINEA = 23
const WIN-CALL-WRITECONSOLEA = 24
const WIN-CALL-GETMODULEFILENAMEA = 25
const WIN-CALL-HEAPALLOC = 26
const WIN-CALL-HEAPFREE = 27
const WIN-CALL-COPYFILEA = 28
const WIN-CALL-GETENVIRONMENTVARIABLEA = 29
const WIN-CALL-OUTPUTDEBUGSTRINGA = 30

const WIN-MAX-HANDLES = 16
const WIN-INVALID-HANDLE = 0
const WIN-ACCESS-READ = 0
const WIN-ACCESS-WRITE = 1
const WIN-ERROR-FILE-NOT-FOUND = 2
const WIN-ERROR-INVALID-HANDLE = 6
const WIN-PROCESS-HANDLE-BASE = 100

// Handle table: slot 0 unused/free marker space, 1=stdout, 2=stderr reserved.
// Slots 3..15 store a VFS fd (or 0 if free).
// Process handles are fake: WIN-PROCESS-HANDLE-BASE + pid (no table row).
var win-ready: Int = 0
var win-handles: Int = 0
var win-last-error: Int = 0
var win-cmdline: Int = 0

fn win-init() -> void {
  if win-ready != 0 {
    return
  }
  win-handles = alloc(WIN-MAX-HANDLES * 8)
  let i = 0
  while i < WIN-MAX-HANDLES {
    store64(win-handles + i * 8, 0)
    i = i + 1
  }
  // Reserved console handles (no VFS fd backing).
  store64(win-handles + 1 * 8, 1)
  store64(win-handles + 2 * 8, 2)
  // Static command line for GetCommandLineA (not real argv).
  win-cmdline = alloc(16)
  store8(win-cmdline + 0, 115)
  store8(win-cmdline + 1, 112)
  store8(win-cmdline + 2, 97)
  store8(win-cmdline + 3, 99)
  store8(win-cmdline + 4, 101)
  store8(win-cmdline + 5, 45)
  store8(win-cmdline + 6, 119)
  store8(win-cmdline + 7, 105)
  store8(win-cmdline + 8, 110)
  store8(win-cmdline + 9, 100)
  store8(win-cmdline + 10, 111)
  store8(win-cmdline + 11, 119)
  store8(win-cmdline + 12, 115)
  store8(win-cmdline + 13, 0)
  win-last-error = 0
  win-ready = 1
  return
}

fn win-handle-alloc(vfd: Int) -> Int {
  let i = 3
  while i < WIN-MAX-HANDLES {
    if load64(win-handles + i * 8) == 0 {
      store64(win-handles + i * 8, vfd)
      return i
    }
    i = i + 1
  }
  return WIN-INVALID-HANDLE
}

fn win-handle-vfd(handle: Int) -> Int {
  if handle < 3 {
    return -1
  }
  if handle >= WIN-MAX-HANDLES {
    return -1
  }
  let v = load64(win-handles + handle * 8)
  if v == 0 {
    return -1
  }
  return v
}

fn win-handle-free(handle: Int) -> Int {
  if handle < 3 {
    return 0
  }
  if handle >= WIN-MAX-HANDLES {
    return -1
  }
  if load64(win-handles + handle * 8) == 0 {
    return -1
  }
  store64(win-handles + handle * 8, 0)
  return 0
}

fn win-dispatch(port: Int, num: Int, a0: Int, a1: Int, a2: Int, a3: Int) -> Int {
  if win-ready == 0 {
    win-init()
  }
  if num == WIN-CALL-WRITEFILE {
    let handle = a0
    let buf = a1
    let len = a2
    if handle == 1 || handle == 2 {
      let i = 0
      while i < len {
        serial-put(port, load8(buf + i))
        i = i + 1
      }
      win-last-error = 0
      return len
    }
    let vfd = win-handle-vfd(handle)
    if vfd < 0 {
      win-last-error = WIN-ERROR-INVALID-HANDLE
      return 0
    }
    let n = vfs-write(vfd, buf, len)
    if n < 0 {
      win-last-error = WIN-ERROR-INVALID-HANDLE
      return 0
    }
    win-last-error = 0
    return n
  }
  if num == WIN-CALL-GETCURRENTPROCESSID {
    return current-task
  }
  if num == WIN-CALL-EXITPROCESS {
    // Demo only: do not halt the kernel.
    return a0
  }
  if num == WIN-CALL-CREATEFILEA {
    let path = a0
    let access = a1
    let flags = VFS-O-RDONLY
    if access == WIN-ACCESS-WRITE {
      flags = VFS-O-RDWR | VFS-O-CREAT
    }
    let vfd = vfs-open(path, flags)
    if vfd < 0 {
      win-last-error = WIN-ERROR-FILE-NOT-FOUND
      return WIN-INVALID-HANDLE
    }
    let h = win-handle-alloc(vfd)
    if h == WIN-INVALID-HANDLE {
      vfs-close(vfd)
      win-last-error = WIN-ERROR-INVALID-HANDLE
      return WIN-INVALID-HANDLE
    }
    win-last-error = 0
    return h
  }
  if num == WIN-CALL-READFILE {
    let handle = a0
    let buf = a1
    let len = a2
    let vfd = win-handle-vfd(handle)
    if vfd < 0 {
      win-last-error = WIN-ERROR-INVALID-HANDLE
      return 0
    }
    let n = vfs-read(vfd, buf, len)
    if n < 0 {
      win-last-error = WIN-ERROR-INVALID-HANDLE
      return 0
    }
    win-last-error = 0
    return n
  }
  if num == WIN-CALL-CLOSEHANDLE {
    let handle = a0
    if handle == 1 || handle == 2 {
      win-last-error = 0
      return 1
    }
    // Process handles: fake 100+pid — free is no-op success.
    if handle >= WIN-PROCESS-HANDLE-BASE {
      win-last-error = 0
      return 1
    }
    let vfd = win-handle-vfd(handle)
    if vfd < 0 {
      win-last-error = WIN-ERROR-INVALID-HANDLE
      return 0
    }
    vfs-close(vfd)
    win-handle-free(handle)
    win-last-error = 0
    return 1
  }
  if num == WIN-CALL-GETFILESIZE {
    let handle = a0
    let vfd = win-handle-vfd(handle)
    if vfd < 0 {
      win-last-error = WIN-ERROR-INVALID-HANDLE
      return 0
    }
    if vfs-fd-valid(vfd) == 0 {
      win-last-error = WIN-ERROR-INVALID-HANDLE
      return 0
    }
    let base = vfs-fd-table + vfd * 32
    let path = load64(base + 0)
    let sz = vfs-sparkfs-file-size(path)
    if sz < 0 {
      win-last-error = WIN-ERROR-FILE-NOT-FOUND
      return 0
    }
    win-last-error = 0
    return sz
  }
  if num == WIN-CALL-SLEEP {
    // Shell/demo path is not thr- worker stack: thr-yield ctxsw faults.
    // Small busy pause only (honest Sleep stand-in).
    let n = a0
    if n < 1 {
      n = 1
    }
    if n > 64 {
      n = 64
    }
    let i = 0
    while i < n * 256 {
      i = i + 1
    }
    return 0
  }
  if num == WIN-CALL-GETCURRENTTHREADID {
    return current-task
  }
  if num == WIN-CALL-DELETEFILEA {
    let path = a0
    let rc = fs-delete(path)
    if rc != 0 {
      win-last-error = WIN-ERROR-FILE-NOT-FOUND
      return 0
    }
    win-last-error = 0
    return 1
  }
  if num == WIN-CALL-SETFILEPOINTER {
    let handle = a0
    let offset = a1
    let whence = a2
    let vfd = win-handle-vfd(handle)
    if vfd < 0 {
      win-last-error = WIN-ERROR-INVALID-HANDLE
      return -1
    }
    win-last-error = 0
    return vfs-lseek(vfd, offset, whence)
  }
  if num == WIN-CALL-GETSTDHANDLE {
    // Space-local: -10 stdin→0, -11 stdout→1, -12 stderr→2
    if a0 == -10 {
      win-last-error = 0
      return 0
    }
    if a0 == -11 {
      win-last-error = 0
      return 1
    }
    if a0 == -12 {
      win-last-error = 0
      return 2
    }
    win-last-error = WIN-ERROR-INVALID-HANDLE
    return WIN-INVALID-HANDLE
  }
  if num == WIN-CALL-MOVEFILEA {
    let oldp = a0
    let newp = a1
    let rc = fs-rename(oldp, newp)
    if rc != 0 {
      win-last-error = WIN-ERROR-FILE-NOT-FOUND
      return 0
    }
    win-last-error = 0
    return 1
  }
  if num == WIN-CALL-FLUSHFILEBUFFERS {
    let handle = a0
    if handle == 1 || handle == 2 {
      win-last-error = 0
      return 1
    }
    let vfd = win-handle-vfd(handle)
    if vfd < 0 {
      win-last-error = WIN-ERROR-INVALID-HANDLE
      return 0
    }
    // No-op success: VFS writes are already durable enough for this subset.
    win-last-error = 0
    return 1
  }
  if num == WIN-CALL-CREATEDIRECTORYA {
    let path = a0
    let rc = fs-mkdir(path)
    if rc != 0 {
      win-last-error = WIN-ERROR-FILE-NOT-FOUND
      return 0
    }
    win-last-error = 0
    return 1
  }
  if num == WIN-CALL-REMOVEDIRECTORYA {
    let path = a0
    let rc = fs-rmdir(path)
    if rc != 0 {
      win-last-error = WIN-ERROR-FILE-NOT-FOUND
      return 0
    }
    win-last-error = 0
    return 1
  }
  if num == WIN-CALL-GETLASTERROR {
    return win-last-error
  }
  if num == WIN-CALL-SETLASTERROR {
    win-last-error = a0
    return 0
  }
  if num == WIN-CALL-VIRTUALALLOC {
    // a0 preferred addr ignored; a1 size. Not real VirtualAlloc/MEM_*.
    let size = a1
    if size < 1 {
      win-last-error = WIN-ERROR-INVALID-HANDLE
      return 0
    }
    let p = posix-sys-mmap(0, size, 0, 0, -1, 0)
    if p == 0 {
      win-last-error = WIN-ERROR-INVALID-HANDLE
      return 0
    }
    win-last-error = 0
    return p
  }
  if num == WIN-CALL-VIRTUALFREE {
    // a0 addr a1 size. Best-effort munmap stand-in; not real MEM_RELEASE.
    let addr = a0
    let size = a1
    if addr == 0 {
      win-last-error = WIN-ERROR-INVALID-HANDLE
      return 0
    }
    if size < 1 {
      size = 4096
    }
    posix-sys-munmap(addr, size)
    win-last-error = 0
    return 1
  }
  if num == WIN-CALL-CREATEPROCESSA {
    // a0 app path only. Not real CreateProcessA / PE spawn.
    let path = a0
    if path == 0 {
      win-last-error = WIN-ERROR-FILE-NOT-FOUND
      return 0
    }
    if load8(path) == 0 {
      win-last-error = WIN-ERROR-FILE-NOT-FOUND
      return 0
    }
    let status = proc-spawn-sci(port, path)
    if status < 0 {
      win-last-error = WIN-ERROR-FILE-NOT-FOUND
      return 0
    }
    // Fake process handle = 100 + last pid (table grew on success).
    let pid = proc-count - 1
    if pid < 0 {
      pid = 0
    }
    win-last-error = 0
    return WIN-PROCESS-HANDLE-BASE + pid
  }
  if num == WIN-CALL-WAITFORSINGLEOBJECT {
    // Demo: process-like handles only. Not real wait objects / timeouts.
    let handle = a0
    if handle < WIN-PROCESS-HANDLE-BASE {
      win-last-error = WIN-ERROR-INVALID-HANDLE
      return 0
    }
    let pid = handle - WIN-PROCESS-HANDLE-BASE
    let code = proc-wait(pid)
    if code < 0 {
      win-last-error = WIN-ERROR-INVALID-HANDLE
      return 0
    }
    win-last-error = 0
    return 0
  }
  if num == WIN-CALL-GETCOMMANDLINEA {
    if win-cmdline == 0 {
      win-init()
    }
    win-last-error = 0
    return win-cmdline
  }
  if num == WIN-CALL-WRITECONSOLEA {
    // Alias WriteFile on console handles 1/2 only.
    let handle = a0
    let buf = a1
    let len = a2
    if handle != 1 && handle != 2 {
      win-last-error = WIN-ERROR-INVALID-HANDLE
      return 0
    }
    return win-dispatch(port, WIN-CALL-WRITEFILE, handle, buf, len, 0)
  }
  if num == WIN-CALL-GETMODULEFILENAMEA {
    // a0 hModule ignored; a1 buf a2 size. Static module name only.
    let buf = a1
    let size = a2
    if buf == 0 || size < 2 {
      win-last-error = WIN-ERROR-INVALID-HANDLE
      return 0
    }
    let name = "space.exe"
    let nlen = 0
    while load8(name + nlen) != 0 {
      nlen = nlen + 1
    }
    if size <= nlen {
      win-last-error = WIN-ERROR-INVALID-HANDLE
      return 0
    }
    let i = 0
    while i < nlen {
      store8(buf + i, load8(name + i))
      i = i + 1
    }
    store8(buf + nlen, 0)
    win-last-error = 0
    return nlen
  }
  if num == WIN-CALL-HEAPALLOC {
    // a0 heap ignored; a1 flags ignored; a2 size. Bump alloc + zero.
    let size = a2
    if size < 1 {
      win-last-error = WIN-ERROR-INVALID-HANDLE
      return 0
    }
    let p = alloc(size)
    if p == 0 {
      win-last-error = WIN-ERROR-INVALID-HANDLE
      return 0
    }
    let i = 0
    while i < size {
      store8(p + i, 0)
      i = i + 1
    }
    win-last-error = 0
    return p
  }
  if num == WIN-CALL-HEAPFREE {
    // a0 heap a1 flags a2 ptr. Bump heap has no free — success only.
    if a2 == 0 {
      win-last-error = WIN-ERROR-INVALID-HANDLE
      return 0
    }
    win-last-error = 0
    return 1
  }
  if num == WIN-CALL-COPYFILEA {
    // a0 src a1 dst. Whole-file copy via VFS helpers.
    let src = a0
    let dst = a1
    if src == 0 || dst == 0 {
      win-last-error = WIN-ERROR-FILE-NOT-FOUND
      return 0
    }
    let cbuf = alloc(4096)
    let n = fs-read-file(src, cbuf)
    if n < 0 {
      win-last-error = WIN-ERROR-FILE-NOT-FOUND
      return 0
    }
    let wrc = fs-write-file(dst, cbuf, n)
    if wrc != 0 {
      win-last-error = WIN-ERROR-FILE-NOT-FOUND
      return 0
    }
    win-last-error = 0
    return 1
  }
  if num == WIN-CALL-GETENVIRONMENTVARIABLEA {
    // a0 name a1 buf a2 size. PATH → "/"; else empty.
    let name = a0
    let buf = a1
    let size = a2
    if buf == 0 || size < 1 {
      win-last-error = WIN-ERROR-INVALID-HANDLE
      return 0
    }
    let is-path = 0
    if name != 0 {
      if load8(name + 0) == 80 {
        if load8(name + 1) == 65 {
          if load8(name + 2) == 84 {
            if load8(name + 3) == 72 {
              if load8(name + 4) == 0 {
                is-path = 1
              }
            }
          }
        }
      }
    }
    if is-path != 0 {
      if size < 2 {
        win-last-error = WIN-ERROR-INVALID-HANDLE
        return 0
      }
      store8(buf + 0, 47)
      store8(buf + 1, 0)
      win-last-error = 0
      return 1
    }
    store8(buf + 0, 0)
    win-last-error = 0
    return 0
  }
  if num == WIN-CALL-OUTPUTDEBUGSTRINGA {
    let s = a0
    if s == 0 {
      win-last-error = 0
      return 0
    }
    serial-write-cstr(port, s)
    win-last-error = 0
    return 0
  }
  return 0
}

fn win-demo(port: Int) -> void {
  if win-ready == 0 {
    win-init()
  }
  serial-write-cstr(port, "windows: Win32 subset personality registered (translator)")
  serial-nl(port)

  let msg = "  hello from windows personality (WriteFile stdout)\n"
  let mlen = 0
  while load8(msg + mlen) != 0 {
    mlen = mlen + 1
  }
  let wrc = win-dispatch(port, WIN-CALL-WRITEFILE, 1, msg, mlen, 0)
  serial-write-cstr(port, "windows: WriteFile(stdout, msg, ")
  serial-write-dec-wide(port, mlen)
  serial-write-cstr(port, ") = ")
  serial-write-dec-wide(port, wrc)
  serial-nl(port)

  let fname = "win-hello.txt"
  let wh = win-dispatch(port, WIN-CALL-CREATEFILEA, fname, WIN-ACCESS-WRITE, 0, 0)
  serial-write-cstr(port, "windows: CreateFileA(win-hello.txt, write) = ")
  serial-write-dec-wide(port, wh)
  serial-nl(port)

  if wh != WIN-INVALID-HANDLE {
    let content = "windows file content"
    let clen = 0
    while load8(content + clen) != 0 {
      clen = clen + 1
    }
    let fwrc = win-dispatch(port, WIN-CALL-WRITEFILE, wh, content, clen, 0)
    serial-write-cstr(port, "windows: WriteFile(handle, content, ")
    serial-write-dec-wide(port, clen)
    serial-write-cstr(port, ") = ")
    serial-write-dec-wide(port, fwrc)
    serial-nl(port)

    let fsz = win-dispatch(port, WIN-CALL-GETFILESIZE, wh, 0, 0, 0)
    serial-write-cstr(port, "windows: GetFileSize(handle) = ")
    serial-write-dec-wide(port, fsz)
    serial-nl(port)

    let crc = win-dispatch(port, WIN-CALL-CLOSEHANDLE, wh, 0, 0, 0)
    serial-write-cstr(port, "windows: CloseHandle(write) = ")
    serial-write-dec-wide(port, crc)
    serial-nl(port)
  }

  let rh = win-dispatch(port, WIN-CALL-CREATEFILEA, fname, WIN-ACCESS-READ, 0, 0)
  serial-write-cstr(port, "windows: CreateFileA(win-hello.txt, read) = ")
  serial-write-dec-wide(port, rh)
  serial-nl(port)

  if rh != WIN-INVALID-HANDLE {
    let rbuf = alloc(256)
    let rlen = win-dispatch(port, WIN-CALL-READFILE, rh, rbuf, 255, 0)
    serial-write-cstr(port, "windows: ReadFile(handle, buf, 255) = ")
    serial-write-dec-wide(port, rlen)
    serial-write-cstr(port, " -> '")
    let ri = 0
    while ri < rlen {
      serial-put(port, load8(rbuf + ri))
      ri = ri + 1
    }
    serial-write-cstr(port, "'")
    serial-nl(port)
    win-dispatch(port, WIN-CALL-CLOSEHANDLE, rh, 0, 0, 0)
  }

  // Patch mid-file, rename, std handle write, flush (subset only).
  let ph = win-dispatch(port, WIN-CALL-CREATEFILEA, fname, WIN-ACCESS-WRITE, 0, 0)
  serial-write-cstr(port, "windows: CreateFileA(win-hello.txt, write reopen) = ")
  serial-write-dec-wide(port, ph)
  serial-nl(port)
  if ph != WIN-INVALID-HANDLE {
    let spos = win-dispatch(port, WIN-CALL-SETFILEPOINTER, ph, 8, 0, 0)
    serial-write-cstr(port, "windows: SetFilePointer(handle, 8, SET) = ")
    serial-write-dec-wide(port, spos)
    serial-nl(port)
    let patch = "PATCH"
    let plen = 5
    let pwrc = win-dispatch(port, WIN-CALL-WRITEFILE, ph, patch, plen, 0)
    serial-write-cstr(port, "windows: WriteFile(handle, PATCH, 5) = ")
    serial-write-dec-wide(port, pwrc)
    serial-nl(port)
    let frc = win-dispatch(port, WIN-CALL-FLUSHFILEBUFFERS, ph, 0, 0, 0)
    serial-write-cstr(port, "windows: FlushFileBuffers(handle) = ")
    serial-write-dec-wide(port, frc)
    serial-nl(port)
    win-dispatch(port, WIN-CALL-CLOSEHANDLE, ph, 0, 0, 0)
  }

  let fname2 = "win-hello2.txt"
  let mrc = win-dispatch(port, WIN-CALL-MOVEFILEA, fname, fname2, 0, 0)
  serial-write-cstr(port, "windows: MoveFileA(win-hello.txt, win-hello2.txt) = ")
  serial-write-dec-wide(port, mrc)
  serial-nl(port)

  let stdout-h = win-dispatch(port, WIN-CALL-GETSTDHANDLE, -11, 0, 0, 0)
  serial-write-cstr(port, "windows: GetStdHandle(STD_OUTPUT_HANDLE) = ")
  serial-write-dec-wide(port, stdout-h)
  serial-nl(port)
  let smsg = "  hello via GetStdHandle+WriteFile\n"
  let slen = 0
  while load8(smsg + slen) != 0 {
    slen = slen + 1
  }
  let swrc = win-dispatch(port, WIN-CALL-WRITEFILE, stdout-h, smsg, slen, 0)
  serial-write-cstr(port, "windows: WriteFile(GetStdHandle, msg, ")
  serial-write-dec-wide(port, slen)
  serial-write-cstr(port, ") = ")
  serial-write-dec-wide(port, swrc)
  serial-nl(port)

  let pid = win-dispatch(port, WIN-CALL-GETCURRENTPROCESSID, 0, 0, 0, 0)
  serial-write-cstr(port, "windows: GetCurrentProcessId() = ")
  serial-write-dec-wide(port, pid)
  serial-nl(port)

  let tid = win-dispatch(port, WIN-CALL-GETCURRENTTHREADID, 0, 0, 0, 0)
  serial-write-cstr(port, "windows: GetCurrentThreadId() = ")
  serial-write-dec-wide(port, tid)
  serial-nl(port)

  win-dispatch(port, WIN-CALL-SLEEP, 1, 0, 0, 0)
  serial-write-cstr(port, "windows: Sleep(1) mapped (pause loop)")
  serial-nl(port)

  let drc = win-dispatch(port, WIN-CALL-DELETEFILEA, fname2, 0, 0, 0)
  serial-write-cstr(port, "windows: DeleteFileA(win-hello2.txt) = ")
  serial-write-dec-wide(port, drc)
  serial-nl(port)
  // Cleanup either name if rename failed mid-demo.
  win-dispatch(port, WIN-CALL-DELETEFILEA, fname, 0, 0, 0)

  // Directory + nested file (subset only).
  let dname = "win-dir"
  let mdrc = win-dispatch(port, WIN-CALL-CREATEDIRECTORYA, dname, 0, 0, 0)
  serial-write-cstr(port, "windows: CreateDirectoryA(win-dir) = ")
  serial-write-dec-wide(port, mdrc)
  serial-nl(port)
  let nested = "win-dir/nested.txt"
  let nh = win-dispatch(port, WIN-CALL-CREATEFILEA, nested, WIN-ACCESS-WRITE, 0, 0)
  serial-write-cstr(port, "windows: CreateFileA(win-dir/nested.txt, write) = ")
  serial-write-dec-wide(port, nh)
  serial-nl(port)
  if nh != WIN-INVALID-HANDLE {
    let nmsg = "nested"
    win-dispatch(port, WIN-CALL-WRITEFILE, nh, nmsg, 6, 0)
    win-dispatch(port, WIN-CALL-CLOSEHANDLE, nh, 0, 0, 0)
  }
  win-dispatch(port, WIN-CALL-DELETEFILEA, nested, 0, 0, 0)
  let rdrc = win-dispatch(port, WIN-CALL-REMOVEDIRECTORYA, dname, 0, 0, 0)
  serial-write-cstr(port, "windows: RemoveDirectoryA(win-dir) = ")
  serial-write-dec-wide(port, rdrc)
  serial-nl(port)

  // GetLastError after missing CreateFileA.
  let bad = "win-missing-no-such.txt"
  let bh = win-dispatch(port, WIN-CALL-CREATEFILEA, bad, WIN-ACCESS-READ, 0, 0)
  serial-write-cstr(port, "windows: CreateFileA(missing) = ")
  serial-write-dec-wide(port, bh)
  serial-nl(port)
  let glerr = win-dispatch(port, WIN-CALL-GETLASTERROR, 0, 0, 0, 0)
  serial-write-cstr(port, "windows: GetLastError() after missing CreateFileA = ")
  serial-write-dec-wide(port, glerr)
  serial-nl(port)

  // GetCommandLineA → static "space-windows".
  let cl = win-dispatch(port, WIN-CALL-GETCOMMANDLINEA, 0, 0, 0, 0)
  serial-write-cstr(port, "windows: GetCommandLineA() = '")
  if cl != 0 {
    serial-write-cstr(port, cl)
  }
  serial-write-cstr(port, "'")
  serial-nl(port)

  // VirtualAlloc / VirtualFree stand-ins.
  let va = win-dispatch(port, WIN-CALL-VIRTUALALLOC, 0, 64, 0, 0)
  serial-write-cstr(port, "windows: VirtualAlloc(0, 64) = ")
  serial-write-hex(port, va)
  serial-nl(port)
  if va != 0 {
    store8(va + 0, 65)
    let vfrc = win-dispatch(port, WIN-CALL-VIRTUALFREE, va, 64, 0, 0)
    serial-write-cstr(port, "windows: VirtualFree(ptr, 64) = ")
    serial-write-dec-wide(port, vfrc)
    serial-nl(port)
  }

  // WriteConsoleA → WriteFile on stdout.
  let cmsg = "  hello via WriteConsoleA\n"
  let clen = 0
  while load8(cmsg + clen) != 0 {
    clen = clen + 1
  }
  let cwrc = win-dispatch(port, WIN-CALL-WRITECONSOLEA, 1, cmsg, clen, 0)
  serial-write-cstr(port, "windows: WriteConsoleA(stdout, msg, ")
  serial-write-dec-wide(port, clen)
  serial-write-cstr(port, ") = ")
  serial-write-dec-wide(port, cwrc)
  serial-nl(port)

  // CreateProcessA on missing path → fail + GetLastError.
  let missapp = "no-such-space-app.sci"
  let cprc = win-dispatch(port, WIN-CALL-CREATEPROCESSA, missapp, 0, 0, 0)
  serial-write-cstr(port, "windows: CreateProcessA(missing) = ")
  serial-write-dec-wide(port, cprc)
  serial-nl(port)
  let perr = win-dispatch(port, WIN-CALL-GETLASTERROR, 0, 0, 0, 0)
  serial-write-cstr(port, "windows: GetLastError() after CreateProcessA = ")
  serial-write-dec-wide(port, perr)
  serial-nl(port)

  // HeapAlloc / HeapFree.
  let hp = win-dispatch(port, WIN-CALL-HEAPALLOC, 0, 0, 32, 0)
  serial-write-cstr(port, "windows: HeapAlloc(0, 0, 32) = ")
  serial-write-hex(port, hp)
  serial-nl(port)
  if hp != 0 {
    store8(hp + 0, 90)
    let hfrc = win-dispatch(port, WIN-CALL-HEAPFREE, 0, 0, hp, 0)
    serial-write-cstr(port, "windows: HeapFree(ptr) = ")
    serial-write-dec-wide(port, hfrc)
    serial-nl(port)
  }

  // GetModuleFileNameA → "space.exe".
  let mbuf = alloc(64)
  let mlen = win-dispatch(port, WIN-CALL-GETMODULEFILENAMEA, 0, mbuf, 64, 0)
  serial-write-cstr(port, "windows: GetModuleFileNameA() = ")
  serial-write-dec-wide(port, mlen)
  serial-write-cstr(port, " '" )
  if mlen > 0 {
    serial-write-cstr(port, mbuf)
  }
  serial-write-cstr(port, "'")
  serial-nl(port)

  // Rebuild win-hello2 for CopyFileA, then copy + delete both.
  let src2 = "win-hello2.txt"
  let dst2 = "win-copy.txt"
  let sh = win-dispatch(port, WIN-CALL-CREATEFILEA, src2, WIN-ACCESS-WRITE, 0, 0)
  if sh != WIN-INVALID-HANDLE {
    let sc = "copy-src"
    win-dispatch(port, WIN-CALL-WRITEFILE, sh, sc, 8, 0)
    win-dispatch(port, WIN-CALL-CLOSEHANDLE, sh, 0, 0, 0)
  }
  let cprc2 = win-dispatch(port, WIN-CALL-COPYFILEA, src2, dst2, 0, 0)
  serial-write-cstr(port, "windows: CopyFileA(win-hello2.txt, win-copy.txt) = ")
  serial-write-dec-wide(port, cprc2)
  serial-nl(port)
  win-dispatch(port, WIN-CALL-DELETEFILEA, src2, 0, 0, 0)
  win-dispatch(port, WIN-CALL-DELETEFILEA, dst2, 0, 0, 0)

  // OutputDebugStringA.
  let dmsg = "windows: OutputDebugStringA ok\n"
  win-dispatch(port, WIN-CALL-OUTPUTDEBUGSTRINGA, dmsg, 0, 0, 0)

  // GetEnvironmentVariableA PATH → "/".
  let ebuf = alloc(16)
  let elen = win-dispatch(port, WIN-CALL-GETENVIRONMENTVARIABLEA, "PATH", ebuf, 16, 0)
  serial-write-cstr(port, "windows: GetEnvironmentVariableA(PATH) = ")
  serial-write-dec-wide(port, elen)
  serial-write-cstr(port, " '" )
  if elen > 0 {
    serial-write-cstr(port, ebuf)
  }
  serial-write-cstr(port, "'")
  serial-nl(port)

  let erc = win-dispatch(port, WIN-CALL-EXITPROCESS, 0, 0, 0, 0)
  serial-write-cstr(port, "windows: ExitProcess(0) mapped (demo status ")
  serial-write-dec-wide(port, erc)
  serial-write-cstr(port, ", no halt)")
  serial-nl(port)

  serial-write-cstr(port, "windows: personality demo complete")
  serial-nl(port)
  return
}
