package space.bootstrap

component BootstrapSupervisor {
  target "x86_64-space"
  deterministic true
  checkpoint object_graph

  import kernel: KernelControl
  export supervisor: SupervisorControl

  capability load_component: ComponentLoader(load, start)
  capability grant: CapabilityTable(grant, attenuate)
  capability graph: ObjectGraph(create_root, transact)
  capability log: DebugConsole(write)
}

struct ComponentSpec {
  image_id: ComponentImageId
  realm: RealmId
  restart: RestartPolicy
}

interface SupervisorControl {
  fn activate(spec: ComponentSpec) -> ComponentId
}

fn activate(spec: ComponentSpec) -> ComponentId {
  let component = load_component.load(spec.image_id, spec.realm)
  grant.attenuate(component, "bootstrap")
  load_component.start(component)
  log.write("space: component activated\n")
  return component
}
