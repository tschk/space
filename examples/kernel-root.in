package space.kernel

component KernelRoot {
  target "x86_64-space"
  deterministic true
  checkpoint none

  export boot: BootEntry

  capability serial: DebugConsole(write)
  capability memory: PhysicalMemory(discover, map)
  capability tables: PageTables(create, activate)
  capability traps: TrapTable(install)
  capability caps: CapabilityTable(create_root, mint_kernel)
}

struct BootInfo {
  memory_map: MemoryMap
  framebuffer: Optional[FramebufferInfo]
  bootloader_name: String
}

struct KernelState {
  root_realm: RealmId
  root_capability_table: CapabilityTableId
  first_object_id: ObjectId
}

interface BootEntry {
  fn start(info: BootInfo) -> KernelState
}

fn start(info: BootInfo) -> KernelState {
  let root_table = caps.create_root()
  let root_realm = caps.mint_kernel(root_table, "bootstrap-realm")
  serial.write("space: kernel root entered\n")
  memory.discover(info.memory_map)
  tables.create()
  traps.install()
  return KernelState {
    root_realm: root_realm,
    root_capability_table: root_table,
    first_object_id: 1,
  }
}
