// Cross-domain channel fabric.
// Builds on Phase 0 domain_create_shared_page to enable IPC between isolated
// memory domains. Each cross-domain channel endpoint is a shared physical page
// mapped into both domains' page tables. The ring buffer protocol uses atomic-
// free polling (thr_yield) since .in has no CAS yet.
// ponytail: polling with yield, per-account wait queues when throughput matters.

// Shared page layout (4096 bytes, all Int = 8 bytes):
// [head(8)][tail(8)][capacity(8)][msg_size(8)]...[msg data ring(4096-32)]
const CROSS_PAGE_HEADER_SIZE = 32
const CROSS_PAGE_RING_OFFSET = 32

// Create a cross-domain channel endpoint on an existing shared page.
// shared_page is the physical address from domain_create_shared_page.
// local_domain is the local domain ID.
// Returns a channel handle (for chan_cross_send / chan_cross_recv).
fn chan_cross_bind(shared_page: Int, local_domain: Int, capacity: Int) -> Int {
  // Allocate channel control block in kernel domain
  let ch = alloc(CROSS_PAGE_HEADER_SIZE)
  store64(ch + 0, shared_page)
  store64(ch + 8, local_domain)
  store64(ch + 16, 0)  // reserved

  // Initialize shared page header (sender = first user)
  store64(shared_page + 0, 0)    // head = 0
  store64(shared_page + 8, 0)    // tail = 0
  store64(shared_page + 16, capacity)
  store64(shared_page + 24, 8)   // msg_size = 8 (single Int)
  return ch
}

// Send an Int message over a cross-domain channel.
// Blocks (yields) if the ring buffer is full.
fn chan_cross_send(ch: Int, msg: Int) -> void {
  let page = load64(ch + 0)
  let capacity = load64(page + 16)
  let ring_size = capacity * 8

  // Wait until there's room. Simple approach: check if tail more than
  // a capacity behind head (ring full). With capacity 16, full when
  // head - tail == 16 regardless of wrap.
  // ponytail: assumes capacity << 2^63 so head-tail is always positive.
  while load64(page + 0) - load64(page + 8) >= capacity {
    thr_yield()
  }

  let head = load64(page + 0)
  let slot = CROSS_PAGE_RING_OFFSET + (head % capacity) * 8
  store64(page + slot, msg)
  store64(page + 0, head + 1)
  // ponytail: no remote notification, receiver polls. Add IPI cross-domain
  // notification when scheduler runs on remote domain's threads.
  return
}

// Receive an Int message over a cross-domain channel.
// Blocks (yields) if the ring buffer is empty.
fn chan_cross_recv(ch: Int) -> Int {
  let page = load64(ch + 0)
  let capacity = load64(page + 16)

  // Wait until there's data (head != tail)
  while load64(page + 0) == load64(page + 8) {
    thr_yield()
  }

  let tail = load64(page + 8)
  let slot = CROSS_PAGE_RING_OFFSET + (tail % capacity) * 8
  let msg = load64(page + slot)
  store64(page + 8, tail + 1)
  return msg
}

// Transfer a capability from current domain to target domain.
// Returns new slot index, 0 on failure.
fn chan_transfer_cap(ch: Int, cap_index: Int, tgt_base: Int, tgt_count: Int) -> Int {
  let rights = load64(tgt_base + cap_index * 16 + 8)
  if rights >= 0 { return 0 }
  let i = 0
  while i < tgt_count {
    let target_ptr = load64(tgt_base + i * 16 + 0)
    if target_ptr == 0 {
      let src_target = load64(tgt_base + cap_index * 16 + 0)
      store64(tgt_base + i * 16 + 0, src_target)
      store64(tgt_base + i * 16 + 8, rights & 0x7FFFFFFF)
      return i + 1
    }
    i = i + 1
  }
  return 0
}

// --- cross-domain channel IPC demo -----------------------------------------

// Test: two threads in same domain communicate cross-domain style.
fn test_cross_channel() -> Int {
  // Create a shared page within the same domain for testing
  let page = alloc(4096)

  // Bind sender and receiver endpoints
  let ch_a = chan_cross_bind(page, 0, 16)
  let ch_b = chan_cross_bind(page, 0, 16)

  // Send a test value
  chan_cross_send(ch_a, 42)

  // Receive it
  let result = chan_cross_recv(ch_b)
  return result
}

// Test: capability transfer across domains (same-domain sim).
fn test_cross_cap_transfer() -> Int {
  // Simplified: scan self cap table, transfer first cap to a free slot
  let count = cap_count
  let base = cap_table_base
  let i = 0
  while i < count {
    let target = load64(base + i * 16 + 0)
    if target != 0 {
      // Found a live cap, attempt transfer
      let new_slot = chan_transfer_cap(0, i, base, count)
      if new_slot > 0 {
        return i + 1  // cap transferred successfully
      }
      return 0  // no free slot
    }
    i = i + 1
  }
  return 0
}
