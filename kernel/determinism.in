package space.kernel

// Deterministic-execution subsystem, split into its own `.in` module and pulled
// into the nanokernel with `import`. In a deterministic region all
// nondeterminism is capability-mediated and seeded, so the same seed reproduces
// the same execution exactly. det_next is a xorshift64 PRNG (logical shifts).
// The serial_* helpers it calls live in the importing module; the compiler
// merges all imported modules into one program and resolves calls across them.
fn det_next(s: Int) -> Int {
  let x = s
  x = x ^ (x << 13)
  x = x ^ (x >> 7)
  x = x ^ (x << 17)
  return x
}

// A deterministic workload: 64 seeded "scheduling decisions" folded into a
// checksum. Pure function of the seed -- no clock, no ambient state.
fn det_workload(seed: Int) -> Int {
  let s = seed
  let checksum = 0
  for i in 0..64 {
    s = det_next(s)
    let pick = s & 0x7
    checksum = (checksum * 31 + pick) & 0xFFFFFFFF
  }
  return checksum
}

fn run_determinism(port: Int) -> void {
  let r1 = det_workload(0x12345678)
  let r2 = det_workload(0x12345678)
  let r3 = det_workload(0x12345679)
  serial_write_cstr(port, "  det run1 (seed 0x12345678) 0x")
  serial_write_hex(port, r1)
  serial_put(port, 10)
  serial_write_cstr(port, "  det run2 (seed 0x12345678) 0x")
  serial_write_hex(port, r2)
  serial_put(port, 10)
  if r1 == r2 {
    serial_write_cstr(port, "  DETERMINISTIC: identical result for identical seed\n")
  } else {
    serial_write_cstr(port, "  NONDETERMINISTIC: results differ\n")
  }
  serial_write_cstr(port, "  det altseed (0x12345679) 0x")
  serial_write_hex(port, r3)
  serial_write_cstr(port, " (differs, as expected)\n")
  return
}
