package space.guest

// SCI component loading demo. Validates its own manifest against realm grants.
component GuestService {
  target "x86_64-unknown-none"
  deterministic true
  checkpoint none

  capability serial: DebugConsole(write)
}

fn g-wait(port: Int) -> void {
  while (inb(port + 5) & 0x20) == 0 { }
  return
}

fn g-put(port: Int, ch: Int) -> void {
  g-wait(port)
  outb(port, ch)
  return
}

// Validate SCI manifest against realm's capability table.
fn sci-validate-manifest(sci-ptr: Int, realm-cap-info: Int) -> Int {
  let magic = load64(sci-ptr + 0)
  if magic != 0x5343490000000001 {
    return 0
  }
  let cap-count = load64(realm-cap-info + 0)
  let cap-table = load64(realm-cap-info + 8)
  let required = load64(sci-ptr + 8)
  let granted = 0
  let i = 0
  while i < cap-count {
    let rights = load64(cap-table + i * 16 + 8)
    granted = granted | rights
    i = i + 1
  }
  let missing = required & (-1 ^ granted)
  if missing != 0 {
    return 0
  }
  return 1
}

// Component entry: validate manifest, then return success code.
fn guest-entry(realm-cap-info: Int) -> Int {
  let sci-ptr = 0x40000000
  if sci-validate-manifest(sci-ptr, realm-cap-info) == 0 {
    return 0xDEAD
  }
  return 0x1042
}
