package space.guest

// SCI component loading demo. Validates its own manifest against realm grants.
component GuestService {
  target "x86_64-unknown-none"
  deterministic true
  checkpoint none

  export svc: GuestApi

  capability serial: DebugConsole(write)
}

interface GuestApi {
  fn run(arg: Int) -> Int
}

fn g_wait(port: Int) -> void {
  while (inb(port + 5) & 0x20) == 0 { }
  return
}

fn g_put(port: Int, ch: Int) -> void {
  g_wait(port)
  outb(port, ch)
  return
}

fn g_hex(port: Int, value: Int) -> void {
  let shift = 60
  while shift >= 0 {
    let nibble = (value >> shift) & 0xF
    if nibble < 10 {
      g_put(port, 48 + nibble)
    } else {
      g_put(port, 87 + nibble)
    }
    shift = shift - 4
  }
  return
}

// Validate SCI manifest against realm's capability table.
fn sci_validate_manifest(sci_ptr: Int, realm_cap_info: Int) -> Int {
  let magic = load64(sci_ptr + 0)
  if magic != 0x5343490000000001 {
    return 0
  }
  let cap_count = load64(realm_cap_info + 0)
  let cap_table = load64(realm_cap_info + 8)
  let required = load64(sci_ptr + 8)
  let granted = 0
  let i = 0
  while i < cap_count {
    let rights = load64(cap_table + i * 16 + 8)
    granted = granted | rights
    i = i + 1
  }
  let missing = required & (-1 ^ granted)
  if missing != 0 {
    return 0
  }
  return 1
}

// Component entry: validate manifest, then return success code.
fn guest_entry(realm_cap_info: Int) -> Int {
  let sci_ptr = 0x40000000
  if sci_validate_manifest(sci_ptr, realm_cap_info) == 0 {
    return 0xDEAD
  }
  return 0x1042
}
