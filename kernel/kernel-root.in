// The nanokernel root component.
component KernelRoot {
  target "x86_64-unknown-none"
  deterministic true
  checkpoint none

  export boot: BootEntry

  capability serial: DebugConsole(write)
  capability memory: PhysicalMemory(discover, map)
  capability tables: PageTables(create, activate)
  capability traps: TrapTable(install)
  capability caps: CapabilityTable(create_root, mint_kernel)
  capability storage: BlockStorage(read, write)
  capability input: InputDevice(publish)
  capability network: NetworkDevice(tx, rx, configure)
  capability display: DisplayDevice(map, present)
  capability volume: Volume(read, write)
}

struct KernelState {
  Int root_table_id
  Int realm_id
  Bool cpu_ready
}

interface BootEntry {
  fn start(mb_info: Int) -> Int
}

interface DebugConsole {
  fn write(msg: String) -> void
}

interface BlockStorage {
  fn read(lba: Int, count: Int, buf: Int) -> Int
  fn write(lba: Int, count: Int, buf: Int) -> Int
}

interface InputDevice {
  fn publish(evt: Int) -> void
}

interface NetworkDevice {
  fn tx(len: Int) -> void
  fn rx() -> Int
  fn configure() -> Int
}

interface DisplayDevice {
  fn map(phys: Int, size: Int) -> void
  fn present() -> void
}

interface Volume {
  fn read(fd: Int, buf: Int, count: Int) -> Int
  fn write(fd: Int, buf: Int, count: Int) -> Int
}

// --- nanokernel state -------------------------------------------------------
var heap_next: Int = 0
var heap_end: Int = 0
var total_ram: Int = 0
var region_count: Int = 0
var obj_counter: Int = 0
var cap_table_base: Int = 0
var cap_count: Int = 0
var root_realm: Int = 0
var ticks: Int = 0
var idt_base: Int = 0
var realm_grants: Int = 0
var ptasks: Int = 0
var pcount: Int = 0
var pcurrent: Int = 0
var preempt_deadline: Int = 0
var work_a: Int = 0
var work_b: Int = 0

const MAX_PREEMPT_COMPS = 8
var preempt_entry: Int = 0
var preempt_cap_info: Int = 0
var preempt_domain: Int = 0
var preempt_pml4: Int = 0
var preempt_count: Int = 0

// --- PRNG and determinism ---------------------------------------------------
fn det_next(s: Int) -> Int {
  let x = s
  x = x ^ (x << 13)
  x = x ^ (x >> 7)
  x = x ^ (x << 17)
  return x
}

fn det_workload(seed: Int) -> Int {
  let s = seed
  let sum = 0
  for i in 0..1000 {
    s = det_next(s)
    sum = sum + (s & 0xFF)
  }
  return sum
}

fn run_determinism(port: Int) -> void {
  serial_write_cstr(port, "space: determinism test starting")
  serial_nl(port)
  let sum1 = det_workload(42)
  let sum2 = det_workload(42)
  serial_write_cstr(port, "space: seed 42 run 1 sum 0x")
  serial_write_hex(port, sum1)
  serial_write_cstr(port, " run 2 sum 0x")
  serial_write_hex(port, sum2)
  serial_nl(port)
  return
}

// --- component supervisor ---------------------------------------------------
fn component_register(name: Int, entry: Int, required: Int) -> Int {
  let c = obj_bump(56)
  obj_counter = obj_counter + 1
  store64(c + 0, obj_counter)
  store64(c + 8, 5)
  store64(c + 16, entry)
  store64(c + 24, required)
  store64(c + 32, name)
  store64(c + 40, 0)
  store64(c + 48, 0)
  return c
}

fn supervisor_activate(port: Int, c: Int) -> void {
  let name = load64(c + 32)
  let entry = load64(c + 16)
  let required = load64(c + 24)
  let missing = required & (-1 ^ realm_grants)
  serial_write_cstr(port, "space: supervisor evaluating ")
  serial_write_cstr(port, name)
  if missing != 0 {
    serial_write_cstr(port, " -> DENIED undeclared cap 0x")
    serial_write_hex(port, missing)
    serial_nl(port)
    return
  }
  cap_mint(c, required)
  serial_write_cstr(port, " -> ACTIVATING")
  serial_nl(port)
  let status = invoke(entry)
  serial_write_cstr(port, "space:   ")
  serial_write_cstr(port, name)
  serial_write_cstr(port, " returned status 0x")
  serial_write_hex(port, status)
  serial_nl(port)
  return
}

fn svc_heartbeat() -> Int {
  let port = com1()
  serial_write_cstr(port, "space:   [heartbeat] observed ticks 0x")
  serial_write_hex(port, ticks)
  serial_nl(port)
  return 0
}

fn svc_logger() -> Int {
  let port = com1()
  serial_write_cstr(port, "space:   [logger] objects 0x")
  serial_write_hex(port, obj_counter)
  serial_write_cstr(port, " caps 0x")
  serial_write_hex(port, cap_count)
  serial_nl(port)
  return 0
}

fn svc_pager() -> Int {
  return 0xDEAD
}

fn run_supervisor(port: Int) -> void {
  realm_grants = cap_serial() | cap_timer() | cap_graph() | cap_memory() | cap_display() | cap_storage() | cap_input() | cap_network() | cap_volume()
  let c1 = component_register("heartbeat", svc_heartbeat, cap_serial())
  let c2 = component_register("logger", svc_logger, cap_serial() | cap_graph())
  let c3 = component_register("pager", svc_pager, cap_memory())
  serial_write_cstr(port, "space: supervisor activating component graph")
  serial_nl(port)
  supervisor_activate(port, c1)
  supervisor_activate(port, c2)
  supervisor_activate(port, c3)
  return
}

// --- preemptive scheduler ---------------------------------------------------
fn build_preempt_task(entry: Int, stack_top: Int, arg: Int) -> Int {
  let sp = stack_top - 160
  for i in 0..15 {
    store64(sp + i * 8, 0)
  }
  // The isr_timer_preempt stub pushes RAX,RBX,RCX,RDX,RSI,RDI,RBP,R8-R15 and
  // pops them in reverse order (R15..RAX), so the saved-register layout is:
  // sp+0 = R15, sp+8 = R14, ..., sp+72 = RDI, ..., sp+112 = RAX.
  store64(sp + 72, arg)       // RDI slot: first argument to the entry function
  store64(sp + 120, entry)    // RIP
  store64(sp + 128, 0x08)     // CS
  store64(sp + 136, 0x202)    // RFLAGS (interrupts enabled; component stub cli's before switching)
  store64(sp + 144, stack_top) // RSP
  store64(sp + 152, 0x10)     // SS
  return sp
}

fn schedule_tick(ctx: Int) -> Int {
  ticks = ticks + 1
  outb(0x20, 0x20)
  store64(ptasks + pcurrent * 8, ctx)
  pcurrent = (pcurrent + 1) % pcount
  if preempt_pml4 != 0 {
    let pml4 = load64(preempt_pml4 + pcurrent * 8)
    if pml4 != 0 {
      invoke1(load64(0x4060), pml4)
    }
  }
  return load64(ptasks + pcurrent * 8)
}

fn preempt_register_component(port: Int, entry: Int, cap_info: Int, domain: Int, stack_top: Int) -> Int {
  let i = pcount
  store64(preempt_entry + i * 8, entry)
  store64(preempt_cap_info + i * 8, cap_info)
  store64(preempt_domain + i * 8, domain)
  store64(preempt_pml4 + i * 8, load64(domain_table + domain * 24))
  let ctx = build_preempt_task(load64(0x4080), stack_top, i)
  store64(ptasks + i * 8, ctx)
  pcount = pcount + 1
  preempt_count = preempt_count + 1
  serial_write_cstr(port, "  preempt: registered component i=0x")
  serial_write_hex(port, i)
  serial_write_cstr(port, " pcount=0x")
  serial_write_hex(port, pcount)
  serial_write_cstr(port, " ctx=0x")
  serial_write_hex(port, ctx)
  serial_nl(port)
  return i
}

fn preempt_start(port: Int) -> void {
  ptasks = alloc((MAX_PREEMPT_COMPS + 1) * 8)
  pcount = 1
  pcurrent = 0
  preempt_count = 0
  preempt_entry = alloc((MAX_PREEMPT_COMPS + 1) * 8)
  preempt_cap_info = alloc((MAX_PREEMPT_COMPS + 1) * 8)
  preempt_domain = alloc((MAX_PREEMPT_COMPS + 1) * 8)
  preempt_pml4 = alloc((MAX_PREEMPT_COMPS + 1) * 8)
  store64(ptasks, 0)
  store64(preempt_domain, 0)
  store64(preempt_pml4, load64(0x40B8))
  store64(0x40A0, preempt_entry)
  store64(0x40A8, preempt_cap_info)
  store64(0x40B0, preempt_pml4)
  store64(0x40C0, load64(0x40B8))
  cli()
  store64(0x4028, schedule_tick)
  idt_set(32, load64(0x4020))
  sti()
  serial_write_cstr(port, "space: preemptive scheduler active")
  serial_nl(port)
  return
}

fn preempt_worker_a() -> Int {
  while true {
    work_a = work_a + 1
    pause()
  }
  return 0
}

fn preempt_worker_b() -> Int {
  while true {
    work_b = work_b + 1
    pause()
  }
  return 0
}

fn run_preemptive(port: Int) -> void {
  serial_write_cstr(port, "space: preemptive scheduler (timer-driven)")
  serial_nl(port)
  ptasks = alloc(3 * 8)
  pcount = 3
  pcurrent = 0
  store64(ptasks + 0, 0)
  let sa = alloc(16384)
  let sb = alloc(16384)
  let ctx_a = build_preempt_task(preempt_worker_a, sa + 16384)
  let ctx_b = build_preempt_task(preempt_worker_b, sb + 16384)
  store64(ptasks + 8, ctx_a)
  store64(ptasks + 16, ctx_b)
  preempt_deadline = ticks + 10
  cli()
  store64(0x4028, schedule_tick)
  idt_set(32, load64(0x4020))
  sti()
  while ticks < preempt_deadline {
    hlt()
  }
  cli()
  idt_set(32, load64(0x4008))
  sti()
  serial_write_cstr(port, "space: preemption ended; worker A iters 0x")
  serial_write_hex(port, work_a)
  serial_write_cstr(port, " worker B iters 0x")
  serial_write_hex(port, work_b)
  serial_nl(port)
  return
}

// --- SCI component loader ---------------------------------------------------
const SCI_MAGIC = 0x5343490000000001

const COMP_GNOME_DESKTOP = 0x001E1E2E
const COMP_GNOME_PANEL = 0x00181825
const COMP_GNOME_PANEL_LINE = 0x00333040
const COMP_GNOME_TITLE = 0x002A2A3A
const COMP_GNOME_TITLE_ACTIVE = 0x003584E4
const COMP_GNOME_BORDER = 0x003D3846
const COMP_GNOME_ACCENT = 0x003584E4
const COMP_GNOME_TERM_BG = 0x00121015
const COMP_GNOME_TERM_TEXT = 0x00C8D4E0
const COMP_GNOME_BTN_CLOSE = 0x00C01C28
const COMP_CURSOR_H = 16
const COMP_CURSOR_W = 16

// Runtime-loaded components get an isolated heap and a cross-domain shared
// page mapped at the same virtual address in both domains.
const COMP_HEAP_VIRT = 0x80000000
const COMP_HEAP_SIZE = 0x200000
const COMP_SHARED_VIRT = 0x70000000

var comp_entry_arg: Int = 0
var comp_cap_info_arg: Int = 0
var comp_domain_arg: Int = 0

fn comp_thread_wrapper() -> Int {
  domain_switch(comp_domain_arg)
  return invoke1(comp_entry_arg, comp_cap_info_arg)
}

fn sci_load_runtime_component(port: Int, load_addr: Int, name: Int) -> Int {
  serial_write_cstr(port, "  SCI: loading ")
  serial_write_cstr(port, name)
  serial_nl(port)
  if load_addr == 0 {
    serial_write_cstr(port, "  SCI: null load address")
    serial_nl(port)
    return -1
  }
  let magic = load64(load_addr + 0)
  if magic != SCI_MAGIC {
    serial_write_cstr(port, "  SCI: no valid component manifest at 0x")
    serial_write_hex(port, load_addr)
    serial_nl(port)
    return -1
  }
  let required = load64(load_addr + 8)
  let entry = load64(load_addr + 16)
  let image_size = load64(load_addr + 24)
  serial_write_cstr(port, "  SCI: manifest ok entry 0x")
  serial_write_hex(port, entry)
  serial_nl(port)

  let missing = required & (-1 ^ realm_grants)
  if missing != 0 {
    serial_write_cstr(port, "  SCI: DENIED undeclared cap 0x")
    serial_write_hex(port, missing)
    serial_nl(port)
    return -1
  }
  let domain = domain_create()
  if domain == 0 {
    serial_write_cstr(port, "  SCI: domain_create failed")
    serial_nl(port)
    return -1
  }
  serial_write_cstr(port, "  SCI: domain created")
  serial_nl(port)

  let component = component_register(name, entry, required)
  let virt_load = entry - 32
  let image_pages = (image_size + 4096 - 1) / 4096
  let i = 0
  while i < image_pages {
    domain_map(domain, virt_load + i * 4096, load_addr + i * 4096, 0x7)
    i = i + 1
  }
  serial_write_cstr(port, "  SCI: image mapped")
  serial_nl(port)

  // Allocate and map a 2 MiB heap for the component.
  let heap_pages = COMP_HEAP_SIZE / 4096
  let j = 0
  while j < heap_pages {
    let p = frame_alloc()
    domain_map(domain, COMP_HEAP_VIRT + j * 4096, p, 0x7)
    j = j + 1
  }
  serial_write_cstr(port, "  SCI: heap mapped")
  serial_nl(port)

  // Create a cross-domain shared page and initialize it as a ring channel.
  let shared = domain_create_shared_page(0, domain, COMP_SHARED_VIRT, COMP_SHARED_VIRT)
  store64(shared + 0, 0)   // head
  store64(shared + 8, 0)   // tail
  store64(shared + 16, 508)  // capacity
  store64(shared + 24, 8)      // msg_size
  let k = 0
  while k < 504 {
    store64(shared + 32 + k * 8, 0)
    k = k + 1
  }
  serial_write_cstr(port, "  SCI: shared page mapped")
  serial_nl(port)

  store64(component + 40, domain)
  obj_link(root_realm, component)

  let cap_info = alloc(64)
  store64(cap_info + 0, cap_count)
  store64(cap_info + 8, cap_table_base)
  store64(cap_info + 16, COMP_HEAP_VIRT)
  store64(cap_info + 24, COMP_HEAP_SIZE)
  store64(cap_info + 32, COMP_SHARED_VIRT)
  store64(cap_info + 40, domain)
  store64(cap_info + 48, 800)
  store64(cap_info + 56, 600)

  serial_write_cstr(port, "  SCI: starting ")
  serial_write_cstr(port, name)
  serial_nl(port)
  comp_entry_arg = entry
  comp_cap_info_arg = cap_info
  comp_domain_arg = domain
  let tid = thr_create(comp_thread_wrapper)
  store64(component + 48, tid)
  let stack = alloc(65536)
  preempt_register_component(port, entry, cap_info, domain, stack + 65536)
  serial_write_cstr(port, "  SCI: ")
  serial_write_cstr(port, name)
  serial_write_cstr(port, " thread 0x")
  serial_write_hex(port, tid)
  serial_nl(port)
  return 0
}

fn sci_load(port: Int, load_addr: Int) -> Int {
  if load_addr == 0 || load_addr > 0x200000 {
    serial_write_cstr(port, "  SCI: load address out of range 0x")
    serial_write_hex(port, load_addr)
    serial_nl(port)
    return -1
  }
  let magic = load64(load_addr + 0)
  if magic != SCI_MAGIC {
    serial_write_cstr(port, "  SCI: no valid component manifest at 0x")
    serial_write_hex(port, load_addr)
    serial_nl(port)
    return -1
  }
  let required = load64(load_addr + 8)
  let entry = load64(load_addr + 16)
  let image_size = load64(load_addr + 24)
  serial_write_cstr(port, "  SCI: manifest ok, caps 0x")
  serial_write_hex(port, required)
  serial_write_cstr(port, " entry 0x")
  serial_write_hex(port, entry)
  serial_nl(port)
  let missing = required & (-1 ^ realm_grants)
  if missing != 0 {
    serial_write_cstr(port, "  SCI: DENIED undeclared cap 0x")
    serial_write_hex(port, missing)
    serial_nl(port)
    return -1
  }
  let domain = domain_create()
  if domain == 0 {
    serial_write_cstr(port, "  SCI: domain_create failed")
    serial_nl(port)
    return -1
  }
  let component = component_register("sci-guest", entry, required)
  let virt_load = entry - 32
  let image_pages = (image_size + 4095) / 4096
  let i = 0
  while i < image_pages {
    domain_map(domain, virt_load + i * 4096, load_addr + i * 4096, 0x7)
    i = i + 1
  }
  serial_write_cstr(port, "  SCI: domain 0x")
  serial_write_hex(port, domain)
  serial_write_cstr(port, ", mapped 0x")
  serial_write_hex(port, image_pages)
  serial_write_cstr(port, " pages, cap check passed")
  serial_nl(port)
  store64(component + 40, domain)
  obj_link(root_realm, component)
  serial_write_cstr(port, "  SCI: registered component object id 0x")
  serial_write_hex(port, obj_id(component))
  serial_nl(port)
  let cap_info = alloc(16)
  store64(cap_info + 0, cap_count)
  store64(cap_info + 8, cap_table_base)
  domain_switch(domain)
  let status = invoke1(entry, cap_info)
  domain_switch(0)
  store64(component + 48, status)
  serial_write_cstr(port, "  SCI: component returned status 0x")
  serial_write_hex(port, status)
  serial_nl(port)
  return status
}

// --- syscall demo -----------------------------------------------------------
fn run_syscall_demo(port: Int) -> void {
  serial_write_cstr(port, "space: syscall demo -- calling sys_write via int 0x80")
  serial_nl(port)
  let demo = load64(0x4078)
  let msg = "  hello from syscall (int 0x80)!\n"
  let len = 0
  while load8(msg + len) != 0 {
    len = len + 1
  }
  let result = invoke2(demo, msg, len)
  serial_write_cstr(port, "space: sys_write returned 0x")
  serial_write_hex(port, result)
  serial_nl(port)
  return
}

// --- kernel entry -----------------------------------------------------------
fn kernel_entry(mb_info: Int) -> Int {
  let port = com1()
  serial_init(port)
  serial_write_cstr(port, "space: kernel root entered")
  serial_nl(port)

  // Zero the compiler's global data area before any globals are read.
  // The bootloader loads the kernel image but does not guarantee this
  // region is cleared, and the multiboot info structure may overlap it.
  let g = 0
  while g < 0x10000 {
    store64(0x200000 + g, 0)
    g = g + 8
  }

  discover_memory(mb_info)
  serial_write_cstr(port, "space: available RAM bytes 0x")
  serial_write_hex(port, total_ram)
  serial_write_cstr(port, " across regions 0x")
  serial_write_hex(port, region_count)
  serial_nl(port)
  serial_write_cstr(port, "space: heap window 0x")
  serial_write_hex(port, heap_next)
  serial_write_cstr(port, " .. 0x")
  serial_write_hex(port, heap_end)
  serial_nl(port)

  obj_arena_init(65536)
  cap_table_init(64)
  let cap_table_obj = obj_alloc(2)
  root_realm = obj_alloc(1)
  store64(root_realm + 16, cap_table_obj)
  let kernel_cap = cap_mint(root_realm, 0xF)

  serial_write_cstr(port, "space: bootstrap realm object id 0x")
  serial_write_hex(port, obj_id(root_realm))
  serial_nl(port)
  serial_write_cstr(port, "space: root cap table at 0x")
  serial_write_hex(port, cap_table_base)
  serial_write_cstr(port, " caps 0x")
  serial_write_hex(port, cap_count)
  serial_nl(port)
  serial_write_cstr(port, "space: objects allocated 0x")
  serial_write_hex(port, obj_counter)
  serial_nl(port)

  domain_init()
  serial_write_cstr(port, "space: domain subsystem init, ")
  serial_write_dec_wide(port, domain_count)
  serial_write_cstr(port, " domains (kernel + ")
  let available_domains = 63
  serial_write_dec_wide(port, available_domains)
  serial_write_cstr(port, " available)")
  serial_nl(port)

  interrupts_init()
  serial_write_cstr(port, "space: interrupts enabled (PIC remapped, PIT 100Hz)")
  serial_nl(port)

  let shown = 0
  while shown < 1 {
    hlt()
    if ticks >= (shown + 1) * 20 {
      serial_write_cstr(port, "space: timer ticks 0x")
      serial_write_hex(port, ticks)
      serial_nl(port)
      shown = shown + 1
    }
  }

  run_supervisor(port)
  run_scheduler(port)
  run_channels(port)
  run_preemptive(port)

  if load64(0x180000) == SCI_MAGIC {
    sci_load(port, 0x180000)
  }


  proc_init(16)
  serial_write_cstr(port, "space: process table initialized (max 16)")
  serial_nl(port)

  proc_selftest()

  net_component_start(port)

  let nvme_rc = nvme_init()
  if nvme_rc == 0 {
    serial_write_cstr(port, "space: NVMe controller initialized")
    serial_nl(port)
  } else {
    serial_write_cstr(port, "space: NVMe not found")
    serial_nl(port)
  }

  let usb_rc = xhci_init()
  if usb_rc == 0 {
    serial_write_cstr(port, "space: USB xHCI controller initialized")
    serial_nl(port)
  } else {
    serial_write_cstr(port, "space: USB xHCI not found")
    serial_nl(port)
  }

  load_arena_init(4 * 1024 * 1024)
  serial_write_cstr(port, "space: load arena reserved (4 MiB) at 0x")
  serial_write_hex(port, load_arena_base)
  serial_nl(port)

  fs_init()
  serial_write_cstr(port, "space: filesystem initialized")
  serial_nl(port)
  if sf_mem_disk != 0 {
    serial_write_cstr(port, "space: sparkfs mem volume at 0x")
    serial_write_hex(port, sf_mem_disk)
    serial_nl(port)
  } else {
    serial_write_cstr(port, "space: sparkfs nvme volume")
    serial_nl(port)
  }

  vfs_init()
  test_sci_loader(port)



  linux_init()
  serial_write_cstr(port, "space: Linux personality initialized (POSIX syscall layer)")
  serial_nl(port)

  let fb_rc = fb_init(mb_info)
  if fb_rc == 0 {
    serial_write_cstr(port, "space: framebuffer initialized")
    fb_info(port)
  } else {
    serial_write_cstr(port, "space: framebuffer not available (no VBE info)")
    serial_nl(port)
  }

  if fb_ready != 0 {
    let mouse_rc = mouse_init()
    if mouse_rc == 0 {
      serial_write_cstr(port, "space: PS/2 mouse initialized")
      serial_nl(port)
    } else {
      serial_write_cstr(port, "space: PS/2 mouse not found")
      serial_nl(port)
    }
    if ps2_kbd_init() == 0 {
      serial_write_cstr(port, "space: PS/2 keyboard initialized")
      serial_nl(port)
    }
  }

  if usb_rc == 0 {
    let kbd_rc = usb_kbd_init()
    if kbd_rc == 0 {
      serial_write_cstr(port, "space: USB HID keyboard ready")
      serial_nl(port)
    }
  }

  comp_init()
  serial_write_cstr(port, "space: compositor initialized")
  serial_nl(port)

  // Optional runtime-loaded Display / Input components (probed at fixed
  // physical addresses). If present, they are started in isolated domains.
  preempt_start(port)

  let display_load = load64(0x1a0000)
  if display_load == SCI_MAGIC {
    sci_load_runtime_component(port, 0x1a0000, "display")
  }

  let input_load = load64(0x1e0000)
  if input_load == SCI_MAGIC {
    sci_load_runtime_component(port, 0x1e0000, "input")
  }

  shell(port)

  serial_write_cstr(port, "space: nanokernel ready, total ticks 0x")
  serial_write_hex(port, ticks)
  serial_nl(port)
  serial_write_cstr(port, "space: halting")
  serial_nl(port)
  cli()
  while true {
    hlt()
  }
  return 0
}
