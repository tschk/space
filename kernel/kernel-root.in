package space.kernel

// PCI configuration-space access and bus enumeration.
import "pci.in"
// Cross-domain channel fabric.
import "channel.in"
// Intel e1000 NIC driver.
import "net.in"
// Memory domain subsystem (Phase 0).
import "domain.in"
// PS/2 keyboard driver.
import "keyboard.in"
// VGA text mode console.
import "vga.in"
// ATA/PIO disk driver (primary master IDE).
import "ata.in"
// Minimal userspace runtime / libc (string, I/O, memory, conversion utils).
import "libc.in"
// Process abstraction layer (domain + component + thread).
import "process.in"

// The nanokernel root component. The component, interface, and struct
// declarations are the Space contract surface the loader and SCI metadata are
// built from; the functions below are the lowerable nanokernel control flow
// that runs after the boot trampoline enters long mode.
component KernelRoot {
  target "x86_64-unknown-none"
  deterministic true
  checkpoint none

  export boot: BootEntry

  capability serial: DebugConsole(write)
  capability memory: PhysicalMemory(discover, map)
  capability tables: PageTables(create, activate)
  capability traps: TrapTable(install)
  capability caps: CapabilityTable(create_root, mint_kernel)
}

struct KernelState {
  Int root_table_id
  Int realm_id
  Bool cpu_ready
}

interface BootEntry {
  fn start(mb_info: Int) -> Int
}

interface DebugConsole {
  fn write(msg: String) -> void
}

// --- nanokernel state -------------------------------------------------------
var heap_next: Int = 0
var heap_end: Int = 0
var total_ram: Int = 0
var region_count: Int = 0
var obj_counter: Int = 0
var cap_table_base: Int = 0
var cap_count: Int = 0
var root_realm: Int = 0
var ticks: Int = 0
var idt_base: Int = 0
var realm_grants: Int = 0
var ctxsw: Int = 0
var kernel_slot: Int = 0
var line: Int = 0
var ptasks: Int = 0
var pcount: Int = 0
var pcurrent: Int = 0
var preempt_deadline: Int = 0
var work_a: Int = 0
var work_b: Int = 0

// --- thread system (M:N cooperative threading, goroutine-like) --------------
// Threads are lightweight, stackful execution contexts switched via ctxsw.
// Unlike the old task model, threads support blocking (wait queues), waking,
// and automatic round-robin scheduling. The main kernel context is thread 0.
const THR_RUNNABLE = 0
const THR_BLOCKED = 1
const THR_DONE = 2

var thread_sp: Int = 0      // array[t]: saved stack pointer
var thread_state: Int = 0   // array[t]: state (RUNNABLE/BLOCKED/DONE)
var thread_count: Int = 0
var current_task: Int = 0

fn thr_init(max: Int) -> void {
  thread_sp = alloc(max * 8)
  thread_state = alloc(max * 8)
  thread_count = 1  // thread 0 = main kernel context
  for i in 0..max {
    store64(thread_state + i * 8, THR_DONE)
    store64(thread_sp + i * 8, 0)
  }
  store64(thread_state + 0, THR_RUNNABLE)
  return
}

fn thr_create(entry: Int) -> Int {
  let t = thread_count
  let stack = alloc(16384)
  let sp = stack + 16384 - 64  // 6 callee-saved regs + entry + exit cleanup
  store64(sp + 0, 0)       // RBX
  store64(sp + 8, 0)       // RBP
  store64(sp + 16, 0)      // R12
  store64(sp + 24, 0)      // R13
  store64(sp + 32, 0)      // R14
  store64(sp + 40, 0)      // R15
  store64(sp + 48, entry)  // ret addr → first function
  store64(sp + 56, thr_exit)  // entry's ret → cleanup
  store64(thread_sp + t * 8, sp)
  store64(thread_state + t * 8, THR_RUNNABLE)
  thread_count = thread_count + 1
  return t
}

// Called when a thread's entry function returns. Marks as DONE and yields back
// to the kernel scheduler, which will skip it in thr_next().
fn thr_exit() -> void {
  store64(thread_state + current_task * 8, THR_DONE)
  invoke2(ctxsw, thread_sp + current_task * 8, load64(kernel_slot))
  // ponytail: unreachable after yield
  return
}

// Thread callback: switch to and run this thread.
fn thr_switch(t: Int) -> void {
  current_task = t
  invoke2(ctxsw, kernel_slot, load64(thread_sp + t * 8))
  return
}

// Yield voluntarily (mark RUNNABLE, switch back to scheduler).
fn thr_yield() -> void {
  store64(thread_state + current_task * 8, THR_RUNNABLE)
  invoke2(ctxsw, thread_sp + current_task * 8, load64(kernel_slot))
  return
}

// Block until woken (mark BLOCKED, switch back to scheduler).
fn thr_block() -> void {
  store64(thread_state + current_task * 8, THR_BLOCKED)
  invoke2(ctxsw, thread_sp + current_task * 8, load64(kernel_slot))
  return
}

// Wake a blocked thread.
fn thr_wake(tid: Int) -> void {
  store64(thread_state + tid * 8, THR_RUNNABLE)
  return
}

// Run all runnable threads; return when all are DONE (HLT if temporarily idle).
// Uses fair round-robin: scan from the last dispatched thread.
var thr_last: Int = 0

fn thr_run() -> void {
  thr_last = 1
  while true {
    let t = thr_next(thr_last)
    if t >= 0 {
      thr_last = (t + 1) % thread_count
      thr_switch(t)
    } else if thr_all_done() != 0 {
      return
    } else {
      sti()
      while thr_next(thr_last) < 0 && thr_all_done() == 0 {
        hlt()
      }
      cli()
    }
  }
  return
}

fn thr_next(start: Int) -> Int {
  let n = start
  let tries = 0
  while tries < thread_count {
    if n == 0 {
      n = 1
    }
    if n < thread_count {
      if load64(thread_state + n * 8) == THR_RUNNABLE {
        return n
      }
    }
    n = n + 1
    if n >= thread_count {
      n = 0
    }
    tries = tries + 1
  }
  return -1
}

// Returns 1 when all non-main threads are THR_DONE.
fn thr_all_done() -> Int {
  let t = 1
  while t < thread_count {
    if load64(thread_state + t * 8) != THR_DONE {
      return 0
    }
    t = t + 1
  }
  return 1
}

// --- serial console (COM1) --------------------------------------------------
const COM1_PORT = 0x3F8

fn com1() -> Int {
  return COM1_PORT
}

fn serial_init(port: Int) -> void {
  outb(port + 1, 0x00)
  outb(port + 3, 0x80)
  outb(port + 0, 0x03)
  outb(port + 1, 0x00)
  outb(port + 3, 0x03)
  outb(port + 2, 0xC7)
  outb(port + 4, 0x0B)
  return
}

fn serial_wait_tx(port: Int) -> void {
  while (inb(port + 5) & 0x20) == 0 {
  }
  return
}

fn serial_put(port: Int, ch: Int) -> void {
  serial_wait_tx(port)
  outb(port, ch)
  return
}

fn serial_nl(port: Int) -> void {
  serial_put(port, 10)
  return
}

fn serial_write_cstr(port: Int, addr: Int) -> void {
  let i = 0
  let c = load8(addr + i)
  while c != 0 {
    serial_put(port, c)
    i = i + 1
    c = load8(addr + i)
  }
  return
}

fn serial_write_dec_wide(port: Int, value: Int) -> void {
  // ponytail: simple 20-digit buffer approach
  let buf = alloc(20)
  let i = 0
  let n = value
  if n < 0 {
    serial_put(port, 45)  // '-'
    n = -n
  }
  // Store digits in reverse order
  if n == 0 {
    buf[0] = 48  // '0'
    i = 1
  } else {
    while n > 0 {
      buf[i] = 48 + n % 10
      n = n / 10
      i = i + 1
    }
  }
  // Print in correct order
  while i > 0 {
    i = i - 1
    serial_put(port, buf[i])
  }
  return
}

fn serial_write_hex(port: Int, value: Int) -> void {
  let shift = 60
  while shift >= 0 {
    let nibble = (value >> shift) & 0xF
    if nibble < 10 {
      serial_put(port, 48 + nibble)
    } else {
      serial_put(port, 87 + nibble)
    }
    shift = shift - 4
  }
  return
}

// --- deterministic execution subsystem --------------------------------------
// xorshift64 PRNG: same seed reproduces same execution exactly.
fn det_next(s: Int) -> Int {
  let x = s
  x = x ^ (x << 13)
  x = x ^ (x >> 7)
  x = x ^ (x << 17)
  return x
}

fn det_workload(seed: Int) -> Int {
  let s = seed
  let checksum = 0
  for i in 0..64 {
    s = det_next(s)
    let pick = s & 0x7
    checksum = (checksum * 31 + pick) & 0xFFFFFFFF
  }
  return checksum
}

fn run_determinism(port: Int) -> void {
  let r1 = det_workload(0x12345678)
  let r2 = det_workload(0x12345678)
  let r3 = det_workload(0x12345679)
  serial_write_cstr(port, "  det run1 (seed 0x12345678) 0x")
  serial_write_hex(port, r1)
  serial_put(port, 10)
  serial_write_cstr(port, "  det run2 (seed 0x12345678) 0x")
  serial_write_hex(port, r2)
  serial_put(port, 10)
  if r1 == r2 {
    serial_write_cstr(port, "  DETERMINISTIC: identical result for identical seed\n")
  } else {
    serial_write_cstr(port, "  NONDETERMINISTIC: results differ\n")
  }
  serial_write_cstr(port, "  det altseed (0x12345679) 0x")
  serial_write_hex(port, r3)
  serial_write_cstr(port, " (differs, as expected)\n")
  return
}

// --- bump heap allocator ----------------------------------------------------
fn alloc(n: Int) -> Int {
  let aligned = (n + 15) & -16
  let p = heap_next
  heap_next = heap_next + aligned
  return p
}

// --- physical memory discovery (Multiboot1 memory map) ----------------------
fn discover_memory(mb: Int) -> void {
  let flags = load32(mb)
  if (flags & 0x40) == 0 {
    return
  }
  let mmap_len = load32(mb + 44)
  let mmap_addr = load32(mb + 48)
  let end = mmap_addr + mmap_len
  let entry = mmap_addr
  let best_base = 0
  let best_len = 0
  let total = 0
  let count = 0
  while entry < end {
    let size = load32(entry)
    let base = load64(entry + 4)
    let len = load64(entry + 12)
    let kind = load32(entry + 20)
    if kind == 1 {
      total = total + len
      count = count + 1
      if len > best_len {
        best_base = base
        best_len = len
      }
    }
    entry = entry + size + 4
  }
  total_ram = total
  region_count = count
  // Place the heap above the first 16 MiB so it cannot clobber the kernel
  // image (loaded at 1 MiB) or low memory used by the boot trampoline.
  let hstart = best_base
  if hstart < 0x1000000 {
    hstart = 0x1000000
  }
  heap_next = hstart
  heap_end = best_base + best_len
  return
}

// --- virtual memory management ----------------------------------------------
// The boot trampoline identity-maps the first 1 GiB with 2 MiB pages. These
// helpers allocate fresh 4 KiB-aligned frames and install new 4 KiB mappings by
// walking and growing the page tables, the foundation for realm memory domains.
fn frame_alloc() -> Int {
  let p = (heap_next + 4095) & -4096
  heap_next = p + 4096
  for i in 0..512 {
    store64(p + i * 8, 0)
  }
  return p
}

fn pt_index(virt: Int, shift: Int) -> Int {
  return (virt >> shift) & 0x1FF
}

// Walk PML4 -> PDPT -> PD -> PT, creating tables as needed, then map one 4 KiB
// page. The active PML4 is at physical 0x1000 (set up by the trampoline).
fn map_page(virt: Int, phys: Int, flags: Int) -> void {
  let pml4 = 0x1000
  let i4 = pt_index(virt, 39)
  let i3 = pt_index(virt, 30)
  let i2 = pt_index(virt, 21)
  let i1 = pt_index(virt, 12)
  let e4 = load64(pml4 + i4 * 8)
  if (e4 & 1) == 0 {
    let np = frame_alloc()
    store64(pml4 + i4 * 8, np | 3)
    e4 = np | 3
  }
  let pdpt = e4 & -4096
  let e3 = load64(pdpt + i3 * 8)
  if (e3 & 1) == 0 {
    let np = frame_alloc()
    store64(pdpt + i3 * 8, np | 3)
    e3 = np | 3
  }
  let pd = e3 & -4096
  let e2 = load64(pd + i2 * 8)
  if (e2 & 1) == 0 {
    let np = frame_alloc()
    store64(pd + i2 * 8, np | 3)
    e2 = np | 3
  }
  let pt = e2 & -4096
  store64(pt + i1 * 8, phys | flags)
  invlpg(virt)
  return
}

// --- object graph v0 --------------------------------------------------------
// The object graph lives in a dedicated arena so it can be checkpointed and
// restored independently of kernel scratch allocations.
var obj_arena: Int = 0
var obj_arena_next: Int = 0
var obj_arena_size: Int = 0

fn obj_arena_init(size: Int) -> void {
  obj_arena = alloc(size)
  obj_arena_next = obj_arena
  obj_arena_size = size
  return
}

fn obj_bump(n: Int) -> Int {
  let p = obj_arena_next
  obj_arena_next = obj_arena_next + ((n + 15) & -16)
  return p
}

// Object record (32 bytes): [id][type_tag][ref0][ref1].
fn obj_alloc(type_tag: Int) -> Int {
  let p = obj_bump(32)
  obj_counter = obj_counter + 1
  store64(p + 0, obj_counter)
  store64(p + 8, type_tag)
  store64(p + 16, 0)
  store64(p + 24, 0)
  return p
}

fn obj_id(obj: Int) -> Int {
  return load64(obj + 0)
}

// Object graph edge: single link in slot 1 (ref1). ref0 reserved for future use.
fn obj_link(src: Int, dst: Int) -> void {
  store64(src + 24, dst)
  return
}

// --- object-graph checkpoint / restore --------------------------------------
// Snapshotting is a Space primitive: capture a consistent copy of the object
// graph and its allocator/counter state, and restore the graph to it later.
var snap_buf: Int = 0
var snap_obj_next: Int = 0
var snap_obj_counter: Int = 0
var snap_cap_count: Int = 0

fn checkpoint_save() -> void {
  if snap_buf == 0 {
    snap_buf = alloc(obj_arena_size)
  }
  let words = (obj_arena_next - obj_arena) / 8
  for k in 0..words {
    store64(snap_buf + k * 8, load64(obj_arena + k * 8))
  }
  snap_obj_next = obj_arena_next
  snap_obj_counter = obj_counter
  snap_cap_count = cap_count
  return
}

fn checkpoint_restore() -> void {
  let words = (snap_obj_next - obj_arena) / 8
  for k in 0..words {
    store64(obj_arena + k * 8, load64(snap_buf + k * 8))
  }
  obj_arena_next = snap_obj_next
  obj_counter = snap_obj_counter
  cap_count = snap_cap_count
  return
}

// --- capability table v0 ----------------------------------------------------
// Capability slot (16 bytes): [target_object_ptr][rights].
fn cap_table_init(capacity: Int) -> void {
  cap_table_base = alloc(capacity * 16)
  cap_count = 0
  return
}

fn cap_mint(target_obj: Int, rights: Int) -> Int {
  let idx = cap_count
  let slot = cap_table_base + idx * 16
  store64(slot + 0, target_obj)
  store64(slot + 8, rights)
  cap_count = cap_count + 1
  return idx
}

// --- interrupts: IDT, PIC, PIT timer ---------------------------------------
// Interrupt dispatcher, called from the assembly timer stub with the vector in
// the first argument. Counts ticks and acknowledges the interrupt controller.
fn isr_dispatch(vector: Int) -> void {
  ticks = ticks + 1
  outb(0x20, 0x20)
  return
}

// CPU exception handler. Reports the fault and halts the nanokernel rather than
// letting an unhandled fault triple-fault the machine.
fn exception_handler(vector: Int, error_code: Int, rip: Int) -> void {
  let port = com1()
  serial_nl(port)
    serial_write_cstr(port, "space: *** CPU EXCEPTION vector 0x")
  serial_write_hex(port, vector)
  serial_write_cstr(port, " error 0x")
  serial_write_hex(port, error_code)
  serial_write_cstr(port, " rip 0x")
  serial_write_hex(port, rip)
  serial_nl(port)
  if vector == 14 {
    serial_write_cstr(port, "space:     page fault address CR2 0x")
    serial_write_hex(port, read_cr2())
    serial_nl(port)
  }
    serial_write_cstr(port, "space: nanokernel fault handler halting")
  serial_nl(port)
  cli()
  while true {
    hlt()
  }
  return
}

// Install a 64-bit interrupt gate into the IDT.
fn idt_set(vec: Int, handler: Int) -> void {
  let e = idt_base + vec * 16
  store16(e + 0, handler & 0xFFFF)
  store16(e + 2, 0x08)
  store8(e + 4, 0)
  store8(e + 5, 0x8E)
  store16(e + 6, (handler >> 16) & 0xFFFF)
  store32(e + 8, (handler >> 32) & 0xFFFFFFFF)
  store32(e + 12, 0)
  return
}

// Remap the 8259 PICs so hardware IRQs land on vectors 32..47, then mask
// everything except IRQ0 (the timer).
fn pic_remap() -> void {
  outb(0x20, 0x11)
  outb(0xA0, 0x11)
  outb(0x21, 0x20)
  outb(0xA1, 0x28)
  outb(0x21, 0x04)
  outb(0xA1, 0x02)
  outb(0x21, 0x01)
  outb(0xA1, 0x01)
  outb(0x21, 0xFE)
  outb(0xA1, 0xFF)
  return
}

// Program PIT channel 0 to ~100 Hz.
fn pit_init() -> void {
  let divisor = 11932
  outb(0x43, 0x36)
  outb(0x40, divisor & 0xFF)
  outb(0x40, (divisor >> 8) & 0xFF)
  return
}

fn interrupts_init() -> void {
  store64(0x4000, isr_dispatch)
  let timer_stub = load64(0x4008)
  let default_stub = load64(0x4010)
  idt_base = alloc(256 * 16)
  for i in 0..256 {
    idt_set(i, default_stub)
  }
  idt_set(32, timer_stub)
  // Wire CPU exception vectors to the fault handler.
  store64(0x4050, exception_handler)
  idt_set(0, load64(0x4030))
  idt_set(6, load64(0x4038))
  idt_set(13, load64(0x4040))
  idt_set(14, load64(0x4048))
  // Wire the syscall trap (int 0x80) with DPL=3 so user-mode code can invoke it.
  store64(0x4070, syscall_dispatch)
  idt_set_user(0x80, load64(0x4068))
  let idtr = alloc(16)
  store16(idtr + 0, 256 * 16 - 1)
  store64(idtr + 2, idt_base)
  lidt(idtr)
  pic_remap()
  pit_init()
  sti()
  return
}

// --- syscall trap (int 0x80) ------------------------------------------------
// User programs request kernel services via int 0x80. The assembly stub
// (isr_syscall) saves all 15 GP registers into a frame on the stack and calls
// syscall_dispatch with a pointer to that frame. The dispatch function reads
// the syscall number from RAX (frame offset 112) and the arguments from
// RDI (72), RSI (80), RDX (88), then writes the return value back into the
// RAX slot so the stub's iretq delivers it to the caller.
//
// Frame layout (matches push order in isr_syscall):
//   rax=112 rbx=104 rcx=96 rdx=88 rsi=80 rdi=72 rbp=64
//   r8=56 r9=48 r10=40 r11=32 r12=24 r13=16 r14=8 r15=0

// Syscall 0: sys_write(fd, buf, len) — write to serial console (fd=1 = stdout).
fn sys_write(fd: Int, buf: Int, len: Int) -> Int {
  if fd != 1 {
    return -1
  }
  let port = com1()
  let i = 0
  while i < len {
    serial_put(port, load8(buf + i))
    i = i + 1
  }
  return len
}

// Syscall 1: sys_read(fd, buf, len) — read from serial (fd=0 = stdin, blocking).
// Reads up to len bytes, stopping at a newline, and returns the byte count.
fn sys_read(fd: Int, buf: Int, len: Int) -> Int {
  if fd != 0 {
    return -1
  }
  let port = com1()
  let i = 0
  while i < len {
    let c = serial_read(port)
    store8(buf + i, c)
    i = i + 1
    if c == 10 || c == 13 {
      return i
    }
  }
  return len
}

// Syscall 2: sys_exit(code) — exit the current process/component.
// In kernel context (thread 0) this halts the nanokernel.
fn sys_exit(code: Int) -> Int {
  let port = com1()
  serial_write_cstr(port, "space: sys_exit(code=0x")
  serial_write_hex(port, code)
  serial_write_cstr(port, ") from thread 0x")
  serial_write_hex(port, current_task)
  serial_nl(port)
  cli()
  while true {
    hlt()
  }
  return 0
}

// Syscall 3: sys_yield() — yield CPU to scheduler.
// In kernel context this is a no-op since there is nothing to yield to.
fn sys_yield() -> Int {
  return 0
}

// Syscall 4: sys_getpid() — return current thread ID.
fn sys_getpid() -> Int {
  return current_task
}

// Dispatch a syscall based on the number in the saved RAX slot of the frame.
// Writes the return value back into the RAX slot (frame offset 112).
fn syscall_dispatch(frame: Int) -> void {
  let num = load64(frame + 112)
  if num == 0 {
    let fd = load64(frame + 72)
    let buf = load64(frame + 80)
    let len = load64(frame + 88)
    store64(frame + 112, sys_write(fd, buf, len))
  } else if num == 1 {
    let fd = load64(frame + 72)
    let buf = load64(frame + 80)
    let len = load64(frame + 88)
    store64(frame + 112, sys_read(fd, buf, len))
  } else if num == 2 {
    let code = load64(frame + 72)
    store64(frame + 112, sys_exit(code))
  } else if num == 3 {
    store64(frame + 112, sys_yield())
  } else if num == 4 {
    store64(frame + 112, sys_getpid())
  } else {
    let port = com1()
    serial_write_cstr(port, "space: unknown syscall 0x")
    serial_write_hex(port, num)
    serial_nl(port)
    store64(frame + 112, -1)
  }
  return
}

// Install a 64-bit interrupt gate with DPL=3 so user-mode code can invoke it.
fn idt_set_user(vec: Int, handler: Int) -> void {
  let e = idt_base + vec * 16
  store16(e + 0, handler & 0xFFFF)
  store16(e + 2, 0x08)
  store8(e + 4, 0)
  store8(e + 5, 0xEE)             ; present | DPL=3 | interrupt gate
  store16(e + 6, (handler >> 16) & 0xFFFF)
  store32(e + 8, (handler >> 32) & 0xFFFFFFFF)
  store32(e + 12, 0)
  return
}

// --- component supervisor ---------------------------------------------------
// Capability bits a realm can grant to a component.
fn cap_serial() -> Int { return 1 }
fn cap_timer() -> Int { return 2 }
fn cap_memory() -> Int { return 4 }
fn cap_graph() -> Int { return 8 }

// Register a component as an object in the graph (56 bytes):
// [id][type=5][entry_addr][required_caps][name_addr][domain_id][last_status].
fn component_register(name: Int, entry: Int, required: Int) -> Int {
  let c = obj_bump(56)
  obj_counter = obj_counter + 1
  store64(c + 0, obj_counter)
  store64(c + 8, 5)
  store64(c + 16, entry)
  store64(c + 24, required)
  store64(c + 32, name)
  store64(c + 40, 0)
  store64(c + 48, 0)
  return c
}

// The SCI loader rule, enforced live: a component may only be activated if the
// authority it declares is a subset of what its realm grants. Components that
// request undeclared capabilities are denied before their entry ever runs.
fn supervisor_activate(port: Int, c: Int) -> void {
  let name = load64(c + 32)
  let entry = load64(c + 16)
  let required = load64(c + 24)
  let missing = required & (-1 ^ realm_grants)
  serial_write_cstr(port, "space: supervisor evaluating ")
  serial_write_cstr(port, name)
  if missing != 0 {
    serial_write_cstr(port, " -> DENIED undeclared cap 0x")
    serial_write_hex(port, missing)
    serial_nl(port)
    return
  }
  cap_mint(c, required)
    serial_write_cstr(port, " -> ACTIVATING")
  serial_nl(port)
  let status = invoke(entry)
  serial_write_cstr(port, "space:   ")
  serial_write_cstr(port, name)
  serial_write_cstr(port, " returned status 0x")
  serial_write_hex(port, status)
  serial_nl(port)
  return
}

// --- sample service components ----------------------------------------------
fn svc_heartbeat() -> Int {
  let port = com1()
  serial_write_cstr(port, "space:   [heartbeat] observed ticks 0x")
  serial_write_hex(port, ticks)
  serial_nl(port)
  return 0
}

fn svc_logger() -> Int {
  let port = com1()
  serial_write_cstr(port, "space:   [logger] objects 0x")
  serial_write_hex(port, obj_counter)
  serial_write_cstr(port, " caps 0x")
  serial_write_hex(port, cap_count)
  serial_nl(port)
  return 0
}

fn svc_pager() -> Int {
  return 0xDEAD
}

fn run_supervisor(port: Int) -> void {
  realm_grants = cap_serial() | cap_timer() | cap_graph()
  let c1 = component_register("heartbeat", svc_heartbeat, cap_serial())
  let c2 = component_register("logger", svc_logger, cap_serial() | cap_graph())
  let c3 = component_register("pager", svc_pager, cap_memory())
    serial_write_cstr(port, "space: supervisor activating component graph")
  serial_nl(port)
  supervisor_activate(port, c1)
  supervisor_activate(port, c2)
  supervisor_activate(port, c3)
  return
}

// --- thread-based cooperative scheduler (M:N goroutine-like) ----------------
// Threads replace the old flat task array. Each thread has its own stack and
// is scheduled round-robin via ctxsw. Threads can block on channels (wait
// queues) and be woken by other threads. The main kernel context is thread 0.
fn scheduler_init(max_tasks: Int) -> void {
  ctxsw = load64(0x4018)
  if kernel_slot == 0 {
    kernel_slot = alloc(8)
  }
  thr_init(max_tasks)
  return
}

// --- worker threads ---------------------------------------------------------
fn worker_a() -> Int {
  let round = 0
  while round < 3 {
    let port = com1()
    serial_write_cstr(port, "space:   <worker A> round 0x")
    serial_write_hex(port, round)
    serial_nl(port)
    round = round + 1
    thr_yield()
  }
  return 0
}

fn worker_b() -> Int {
  let round = 0
  while round < 3 {
    let port = com1()
    serial_write_cstr(port, "space:   <worker B> round 0x")
    serial_write_hex(port, round)
    serial_nl(port)
    round = round + 1
    thr_yield()
  }
  return 0
}

fn worker_c() -> Int {
  let round = 0
  while round < 3 {
    let port = com1()
    serial_write_cstr(port, "space:   <worker C> round 0x")
    serial_write_hex(port, round)
    serial_nl(port)
    round = round + 1
    thr_yield()
  }
  return 0
}

fn run_scheduler(port: Int) -> void {
  scheduler_init(8)
  thr_create(worker_a)
  thr_create(worker_b)
  thr_create(worker_c)
    serial_write_cstr(port, "space: scheduler running 3 threads, round-robin")
  serial_nl(port)
  thr_run()
    serial_write_cstr(port, "space: scheduler quiesced after 3 round-robin passes")
  serial_nl(port)
  return
}

// --- preemptive scheduler ---------------------------------------------------
// Build a full interrupt-frame for a new task: 15 saved GP registers followed
// by the iretq frame (RIP, CS, RFLAGS with IF set, RSP, SS).
fn build_preempt_task(entry: Int, stack_top: Int) -> Int {
  let sp = stack_top - 160
  for i in 0..15 {
    store64(sp + i * 8, 0)
  }
  store64(sp + 120, entry)
  store64(sp + 128, 0x08)
  store64(sp + 136, 0x202)
  store64(sp + 144, stack_top)
  store64(sp + 152, 0x10)
  return sp
}

// Invoked from the preemptive timer ISR with a pointer to the interrupted
// task's saved context. Saves it, advances round-robin, and returns the next
// task's saved stack pointer for the ISR to resume.
fn schedule_tick(ctx: Int) -> Int {
  ticks = ticks + 1
  outb(0x20, 0x20)
  store64(ptasks + pcurrent * 8, ctx)
  if ticks >= preempt_deadline {
    pcurrent = 0
    return load64(ptasks)
  }
  pcurrent = (pcurrent + 1) % pcount
  return load64(ptasks + pcurrent * 8)
}

fn preempt_worker_a() -> Int {
  while true {
    work_a = work_a + 1
    pause()
  }
  return 0
}

fn preempt_worker_b() -> Int {
  while true {
    work_b = work_b + 1
    pause()
  }
  return 0
}

fn run_preemptive(port: Int) -> void {
    serial_write_cstr(port, "space: preemptive scheduler (timer-driven)")
  serial_nl(port)
  // Task 0 is this kernel context, captured on the first preemption. Tasks 1
  // and 2 are independent workers with pre-built interrupt frames.
  ptasks = alloc(3 * 8)
  pcount = 3
  pcurrent = 0
  store64(ptasks + 0, 0)
  let sa = alloc(16384)
  let sb = alloc(16384)
  store64(ptasks + 8, build_preempt_task(preempt_worker_a, sa + 16384))
  store64(ptasks + 16, build_preempt_task(preempt_worker_b, sb + 16384))
  preempt_deadline = ticks + 10
  cli()
  store64(0x4028, schedule_tick)
  idt_set(32, load64(0x4020))
  sti()
  while ticks < preempt_deadline {
    hlt()
  }
  cli()
  idt_set(32, load64(0x4008))
  sti()
  serial_write_cstr(port, "space: preemption ended; worker A iters 0x")
  serial_write_hex(port, work_a)
  serial_write_cstr(port, " worker B iters 0x")
  serial_write_hex(port, work_b)
  serial_nl(port)
  return
}

// --- typed channels with blocking (CSP-style) ------------------------------
// Channels are ring buffers with non-busy polling. A thread that tries to send
// on a full channel or recv from an empty one yields until room/data appears.
// ponytail: polling with yield is correct for small thread counts; add proper
// wait queues with atomic flags when M:N threading is in place.
var chan0: Int = 0

fn chan_new(cap: Int) -> Int {
  let c = alloc(40 + cap * 8)
  store64(c + 0, cap)
  store64(c + 8, 0)
  store64(c + 16, 0)
  store64(c + 24, 0)
  store64(c + 32, 0)  // reserved for future wait queue
  return c
}

fn chan_count(c: Int) -> Int {
  return load64(c + 8)
}

// IPC wait queues for channel operations. Each channel has a wait queue of
// blocked threads. Since we don't have atomics (no CAS instruction in .in),
// we use poll-with-yield as before (wait queues are a struct for future atomics).
// ponytail: poll-with-yield, upgrade to atomic CAS when .in has inline asm.

// Send to channel: poll until room, then write and return.
fn chan_send(c: Int, msg: Int) -> void {
  let cap = load64(c + 0)
  while load64(c + 8) >= cap {
    thr_yield()
  }
  let wpos = load64(c + 24)
  let buf = c + 40
  buf[wpos] = msg
  store64(c + 24, (wpos + 1) % cap)
  store64(c + 8, load64(c + 8) + 1)
  return
}

// Recv from channel: poll until data, then read and return.
fn chan_recv(c: Int) -> Int {
  while load64(c + 8) == 0 {
    thr_yield()
  }
  let cap = load64(c + 0)
  let rpos = load64(c + 16)
  let buf = c + 40
  let msg = buf[rpos]
  store64(c + 16, (rpos + 1) % cap)
  store64(c + 8, load64(c + 8) - 1)
  return msg
}

// --- channel IPC demo (blocking producer / consumer) ------------------------
fn task_producer() -> Int {
  let i = 0
  while i < 8 {
    chan_send(chan0, 0x100 + i)
    let port = com1()
    serial_write_cstr(port, "space:   <producer> sent 0x")
    serial_write_hex(port, 0x100 + i)
    serial_nl(port)
    i = i + 1
    thr_yield()
  }
  return 0
}

fn task_consumer() -> Int {
  let m = 0
  while m < 8 {
    let v = chan_recv(chan0)
    let port = com1()
    serial_write_cstr(port, "space:   <consumer> recv 0x")
    serial_write_hex(port, v)
    serial_nl(port)
    m = m + 1
  }
  return 0
}

fn run_channels(port: Int) -> void {
    serial_write_cstr(port, "space: channel IPC demo (blocking producer -> consumer)")
  serial_nl(port)
  scheduler_init(8)
  chan0 = chan_new(4)
  thr_create(task_consumer)  // thread 1 = consumer
  thr_create(task_producer)  // thread 2 = producer
    serial_write_cstr(port, "space:   running threads...")
  serial_nl(port)
  thr_run()
  let cnt = chan_count(chan0)
  serial_write_cstr(port, "space: channel demo complete, remaining 0x")
  serial_write_hex(port, cnt)
  serial_nl(port)
  return
}

// --- SCI component loader ---------------------------------------------------
// Load a separately-compiled component from a binary SCI manifest in memory:
// [magic][required_caps][entry][reserved] followed by the component's code.
// The loader validates the declared authority against the realm's grants
// before transferring control -- the SCI loader rule, applied to real loaded
// code rather than an in-image component.
const SCI_MAGIC = 0x5343490000000001

fn sci_load(port: Int, load_addr: Int) -> Int {
  let magic = load64(load_addr + 0)
  if magic != SCI_MAGIC {
    serial_write_cstr(port, "  SCI: no valid component manifest at 0x")
    serial_write_hex(port, load_addr)
    serial_nl(port)
    return -1
  }
  let required = load64(load_addr + 8)
  let entry = load64(load_addr + 16)
  let image_size = load64(load_addr + 24)
  serial_write_cstr(port, "  SCI: manifest ok, caps 0x")
  serial_write_hex(port, required)
  serial_write_cstr(port, " entry 0x")
  serial_write_hex(port, entry)
  serial_nl(port)
  let missing = required & (-1 ^ realm_grants)
  if missing != 0 {
    serial_write_cstr(port, "  SCI: DENIED undeclared cap 0x")
    serial_write_hex(port, missing)
    serial_nl(port)
    return -1
  }
  // Phase 0: create a domain record for the component
  let domain = domain_create()
  if domain == 0 {
    serial_write_cstr(port, "  SCI: domain_create failed")
    serial_nl(port)
    return -1
  }
  let component = component_register("sci-guest", entry, required)
  let virt_load = entry - 32
  let image_pages = (image_size + 4095) / 4096
  let i = 0
  while i < image_pages {
    domain_map(domain, virt_load + i * 4096, load_addr + i * 4096, 0x7)
    i = i + 1
  }
  serial_write_cstr(port, "  SCI: domain 0x")
  serial_write_hex(port, domain)
  serial_write_cstr(port, ", mapped 0x")
  serial_write_hex(port, image_pages)
  serial_write_cstr(port, " pages, cap check passed")
  serial_nl(port)
  store64(component + 40, domain)
  obj_link(root_realm, component)
  serial_write_cstr(port, "  SCI: registered component object id 0x")
  serial_write_hex(port, obj_id(component))
  serial_nl(port)
  // Pack realm cap table info for guest: [cap_count][cap_table_base].
  let cap_info = alloc(16)
  store64(cap_info + 0, cap_count)
  store64(cap_info + 8, cap_table_base)
  domain_switch(domain)
  let status = invoke1(entry, cap_info)
  domain_switch(0)
  store64(component + 48, status)
  serial_write_cstr(port, "  SCI: component returned status 0x")
  serial_write_hex(port, status)
  serial_nl(port)
  return status
}

// --- syscall demo -----------------------------------------------------------
// Demonstrates calling sys_write via the int 0x80 trap from kernel context.
// The assembly helper syscall_write_demo (published at [0x4078]) rearranges
// its arguments into the syscall register convention and executes int 0x80,
// which traps into isr_syscall -> syscall_dispatch -> sys_write.
fn run_syscall_demo(port: Int) -> void {
  serial_write_cstr(port, "space: syscall demo -- calling sys_write via int 0x80")
  serial_nl(port)
  let demo = load64(0x4078)
  let msg = "  hello from syscall (int 0x80)!\n"
  let len = 0
  while load8(msg + len) != 0 {
    len = len + 1
  }
  let result = invoke2(demo, msg, len)
  serial_write_cstr(port, "space: sys_write returned 0x")
  serial_write_hex(port, result)
  serial_nl(port)
  return
}

// --- interactive serial shell ----------------------------------------------
fn serial_has_byte(port: Int) -> Int {
  return inb(port + 5) & 1
}

fn serial_read(port: Int) -> Int {
  while serial_has_byte(port) == 0 {
  }
  return inb(port + 0)
}

// Read one line into the `line` buffer, echoing input. Returns its length.
fn read_line(port: Int) -> Int {
  let len = 0
  while true {
    let c = serial_read(port)
    if (c == 13) || (c == 10) {
      serial_nl(port)
      store8(line + len, 0)
      return len
    }
    if (c == 8) || (c == 127) {
      if len > 0 {
        len = len - 1
        serial_put(port, 8)
        serial_put(port, 32)
        serial_put(port, 8)
      }
    } else {
      serial_put(port, c)
      store8(line + len, c)
      len = len + 1
    }
  }
  return len
}

// Parse a hex string at addr into an integer.
// ponytail: stops at first non-hex char; no overflow check.
fn str_to_hex(addr: Int) -> Int {
  let result = 0
  let i = 0
  while true {
    let c = load8(addr + i)
    if (c >= 48) && (c <= 57) {  // 0-9
      result = result * 16 + c - 48
    } else if (c >= 65) && (c <= 70) {  // A-F
      result = result * 16 + c - 55
    } else if (c >= 97) && (c <= 102) {  // a-f
      result = result * 16 + c - 87
    } else {
      return result
    }
    i = i + 1
  }
  return 0
}

// Compare the line buffer against a NUL-terminated command string.
fn line_eq(cmd: Int) -> Int {
  let i = 0
  while true {
    let a = load8(line + i)
    let b = load8(cmd + i)
    if a != b {
      return 0
    }
    if a == 0 {
      return 1
    }
    i = i + 1
  }
  return 0
}

// If the line begins with `prefix`, return the index just past it, else -1.
fn line_prefix(prefix: Int) -> Int {
  let i = 0
  while load8(prefix + i) != 0 {
    if load8(line + i) != load8(prefix + i) {
      return -1
    }
    i = i + 1
  }
  return i
}

// A self-test of array indexing: sum of squares 0..7 == 140 (0x8C).
fn array_selftest() -> Int {
  let a = alloc(64)
  for i in 0..8 {
    a[i] = i * i
  }
  let sum = 0
  for j in 0..8 {
    sum = sum + a[j]
  }
  return sum
}

fn shell(port: Int) -> void {
  line = alloc(256)
  serial_nl(port)
    serial_write_cstr(port, "space interactive shell -- type 'help'")
  serial_nl(port)
  while true {
    serial_write_cstr(port, "space> ")
    let n = read_line(port)
    if line_eq("help") != 0 {
        serial_write_cstr(port, "commands: help status mem ticks ps test libc det domain chan pci net disk [lba] snapshot spawn restore map sci fault divzero echo <x> peek <addr> poke <addr> <val> proc <name> format ls write <name> <text> read <name> rm <name> key vga uptime syscall halt")
      serial_nl(port)
    } else if line_eq("snapshot") != 0 {
      checkpoint_save()
      serial_write_cstr(port, "  object-graph checkpoint captured at objects 0x")
      serial_write_hex(port, obj_counter)
      serial_nl(port)
    } else if line_eq("spawn") != 0 {
      let o = obj_alloc(3)
      serial_write_cstr(port, "  spawned object id 0x")
      serial_write_hex(port, obj_id(o))
      serial_write_cstr(port, " (objects now 0x")
      serial_write_hex(port, obj_counter)
        serial_write_cstr(port, ")")
      serial_nl(port)
    } else if line_eq("restore") != 0 {
      checkpoint_restore()
      serial_write_cstr(port, "  restored to checkpoint; objects now 0x")
      serial_write_hex(port, obj_counter)
      serial_nl(port)
    } else if line_eq("pci") != 0 {
      pci_scan(port)
    } else if line_eq("net") != 0 {
      run_net(port)
    } else if line_eq("disk") != 0 {
      ata_shell(port, 0)
    } else if line_eq("det") != 0 {
      run_determinism(port)
    } else if line_eq("domain") != 0 {
      let d = domain_create()
      serial_write_cstr(port, "  created domain 0x")
      serial_write_hex(port, d)
      serial_write_cstr(port, " (total 0x")
      serial_write_hex(port, domain_count)
      serial_write_cstr(port, ")")
      serial_nl(port)
    } else if line_eq("chan") != 0 {
      let d1 = domain_create()
      let d2 = domain_create()
      if d1 > 0 && d2 > 0 {
        let phys = domain_create_shared_page(d1, d2, 0xFFFF8000, 0xFFFF9000)
        if phys != 0 {
          // Init ring buffer header via chan_cross_bind (avoids manual header setup)
          let ch = chan_cross_bind(phys, d1, 16)
          // Manual send (no thr_yield in shell context): slot 0
          store64(phys + 32, 0xCAFE)
          store64(phys + 0, 1)  // head = 1
          // Manual recv
          let msg = load64(phys + 32)
          store64(phys + 8, 1)  // tail = 1
          serial_write_cstr(port, "  chan: domain 0x")
          serial_write_hex(port, d1)
          serial_write_cstr(port, " <-> domain 0x")
          serial_write_hex(port, d2)
          serial_write_cstr(port, " shared phys 0x")
          serial_write_hex(port, phys)
          serial_write_cstr(port, " msg 0x")
          serial_write_hex(port, msg)
          serial_write_cstr(port, " OK")
          serial_nl(port)
        } else {
          serial_write_cstr(port, "  chan: shared page allocation failed")
          serial_nl(port)
        }
      } else {
        serial_write_cstr(port, "  chan: domain creation failed")
        serial_nl(port)
      }
    } else if line_eq("sci") != 0 {
      sci_load(port, 0x140000)
    } else if line_eq("map") != 0 {
      let frame = frame_alloc()
      map_page(0x40000000, frame, 3)
      store64(0x40000000, 0xCAFEBABE)
      serial_write_cstr(port, "  mapped virt 0x40000000 -> phys 0x")
      serial_write_hex(port, frame)
      serial_write_cstr(port, " readback 0x")
      serial_write_hex(port, load64(0x40000000))
      serial_nl(port)
    } else if line_eq("fault") != 0 {
        serial_write_cstr(port, "  triggering a page fault at 0x50000000...")
      serial_nl(port)
      store64(0x50000000, 1)
    } else if line_eq("divzero") != 0 {
        serial_write_cstr(port, "  triggering divide-by-zero...")
      serial_nl(port)
      let z = ticks - ticks
      let q = 100 / z
      serial_write_hex(port, q)
      serial_nl(port)
    } else if line_eq("status") != 0 {
      serial_write_cstr(port, "  realm object id 0x")
      serial_write_hex(port, obj_id(root_realm))
      serial_write_cstr(port, " objects 0x")
      serial_write_hex(port, obj_counter)
      serial_write_cstr(port, " caps 0x")
      serial_write_hex(port, cap_count)
      serial_nl(port)
    } else if line_eq("mem") != 0 {
      serial_write_cstr(port, "  RAM 0x")
      serial_write_hex(port, total_ram)
      serial_write_cstr(port, " heap_next 0x")
      serial_write_hex(port, heap_next)
      serial_write_cstr(port, " heap_end 0x")
      serial_write_hex(port, heap_end)
      serial_nl(port)
    } else if line_eq("ticks") != 0 {
      serial_write_cstr(port, "  timer ticks 0x")
      serial_write_hex(port, ticks)
      serial_nl(port)
    } else if line_eq("ps") != 0 {
      proc_list(port)
    } else if line_eq("test") != 0 {
      serial_write_cstr(port, "  array selftest sum 0x")
      serial_write_hex(port, array_selftest())
        serial_write_cstr(port, " (expect 0x8C)")
      serial_nl(port)
    } else if line_eq("libc") != 0 {
      puts("libc test")
    } else if line_eq("halt") != 0 {
        serial_write_cstr(port, "  halting on request")
      serial_nl(port)
      return
    } else if line_eq("key") != 0 {
      keyboard_key_cmd(port)
    } else if line_eq("vga") != 0 {
      vga_cmd(port)
    } else if line_eq("uptime") != 0 {
      serial_write_cstr(port, "  ")
      serial_write_dec_wide(port, ticks)
        serial_write_cstr(port, " ticks since boot")
      serial_nl(port)
    } else if line_eq("format") != 0 {
      fs_format()
      serial_write_cstr(port, "  disk formatted (superblock + empty file table written)")
      serial_nl(port)
    } else if line_eq("ls") != 0 {
      fs_list(port)
    } else {
      let rest = line_prefix("echo ")
      if rest >= 0 {
        serial_write_cstr(port, line + rest)
        serial_nl(port)
      } else {
        let rest = line_prefix("peek ")
        if rest >= 0 {
          let addr = str_to_hex(line + rest)
          serial_write_cstr(port, "  [0x")
          serial_write_hex(port, addr)
          serial_write_cstr(port, "] = 0x")
          serial_write_hex(port, load64(addr))
          serial_nl(port)
        } else {
          let rest = line_prefix("poke ")
          if rest >= 0 {
            let space_pos = 0
            while load8(line + rest + space_pos) > 32 {
              space_pos = space_pos + 1
            }
            let addr = str_to_hex(line + rest)
            let val = str_to_hex(line + rest + space_pos + 1)
            store64(addr, val)
            serial_write_cstr(port, "  [0x")
            serial_write_hex(port, addr)
            serial_write_cstr(port, "] := 0x")
            serial_write_hex(port, load64(addr))
            serial_nl(port)
          } else {
            let rest = line_prefix("disk ")
            if rest >= 0 {
              let lba = str_to_hex(line + rest)
              ata_shell(port, lba)
            } else {
              let rest = line_prefix("proc ")
              if rest >= 0 {
                let pid = proc_create(line + rest, proc_dummy_entry, cap_serial())
                if pid < 0 {
                  serial_write_cstr(port, "  proc: process table full")
                  serial_nl(port)
                } else {
                  serial_write_cstr(port, "  proc: created process ")
                  serial_write_dec_wide(port, pid)
                  serial_write_cstr(port, " (")
                  serial_write_cstr(port, line + rest)
                  serial_write_cstr(port, "), running...")
                  serial_nl(port)
                  thr_run()
                  serial_write_cstr(port, "  proc: process ")
                  serial_write_dec_wide(port, pid)
                  serial_write_cstr(port, " exited with code ")
                  serial_write_dec_wide(port, proc_wait(pid))
                  serial_nl(port)
                }
              } else {
                let rest = line_prefix("write ")
                if rest >= 0 {
                  // Parse "<name> <text>" — find the space separating them
                  let sp = 0
                  while load8(line + rest + sp) > 32 {
                    sp = sp + 1
                  }
                  store8(line + rest + sp, 0)
                  let name_addr = line + rest
                  let text_addr = line + rest + sp + 1
                  let tlen = 0
                  while load8(text_addr + tlen) != 0 {
                    tlen = tlen + 1
                  }
                  let rc = fs_write_file(name_addr, text_addr, tlen)
                  if rc != 0 {
                    serial_write_cstr(port, "  write: failed (table full or disk error)")
                    serial_nl(port)
                  } else {
                    serial_write_cstr(port, "  write: wrote ")
                    serial_write_dec_wide(port, tlen)
                    serial_write_cstr(port, " bytes to ")
                    serial_write_cstr(port, name_addr)
                    serial_nl(port)
                  }
                } else {
                  let rest = line_prefix("read ")
                  if rest >= 0 {
                    let rbuf = alloc(4096)
                    let rsize = fs_read_file(line + rest, rbuf)
                    if rsize < 0 {
                      serial_write_cstr(port, "  read: file not found")
                      serial_nl(port)
                    } else {
                      serial_write_cstr(port, "  ")
                      let ri = 0
                      while ri < rsize {
                        serial_put(port, load8(rbuf + ri))
                        ri = ri + 1
                      }
                      serial_nl(port)
                    }
                  } else {
                    let rest = line_prefix("rm ")
                    if rest >= 0 {
                      let rc = fs_delete(line + rest)
                      if rc != 0 {
                        serial_write_cstr(port, "  rm: file not found")
                        serial_nl(port)
                      } else {
                        serial_write_cstr(port, "  rm: deleted")
                        serial_nl(port)
                      }
                    } else if n != 0 {
                      serial_write_cstr(port, "  unknown command (try 'help')")
                      serial_nl(port)
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
  return
}

// --- kernel entry -----------------------------------------------------------
fn kernel_entry(mb_info: Int) -> Int {
  let port = com1()
  serial_init(port)
    serial_write_cstr(port, "space: kernel root entered")
  serial_nl(port)

  discover_memory(mb_info)
  serial_write_cstr(port, "space: available RAM bytes 0x")
  serial_write_hex(port, total_ram)
  serial_write_cstr(port, " across regions 0x")
  serial_write_hex(port, region_count)
  serial_nl(port)
  serial_write_cstr(port, "space: heap window 0x")
  serial_write_hex(port, heap_next)
  serial_write_cstr(port, " .. 0x")
  serial_write_hex(port, heap_end)
  serial_nl(port)

  // Capability root, bootstrap realm, and root capability table object.
  obj_arena_init(65536)
  cap_table_init(64)
  let cap_table_obj = obj_alloc(2)
  root_realm = obj_alloc(1)
  store64(root_realm + 16, cap_table_obj)
  let kernel_cap = cap_mint(root_realm, 0xF)

  serial_write_cstr(port, "space: bootstrap realm object id 0x")
  serial_write_hex(port, obj_id(root_realm))
  serial_nl(port)
  serial_write_cstr(port, "space: root cap table at 0x")
  serial_write_hex(port, cap_table_base)
  serial_write_cstr(port, " caps 0x")
  serial_write_hex(port, cap_count)
  serial_nl(port)
  serial_write_cstr(port, "space: objects allocated 0x")
  serial_write_hex(port, obj_counter)
  serial_nl(port)

  // Initialize memory domain subsystem (Phase 0).
  domain_init()
  serial_write_cstr(port, "space: domain subsystem init, ")
  serial_write_dec_wide(port, domain_count)
  serial_write_cstr(port, " domains (kernel + ")
  let available_domains = 63
  serial_write_dec_wide(port, available_domains)
  serial_write_cstr(port, " available)")
  serial_nl(port)

  // Bring up interrupts and run the timer for a short, observable window.
  interrupts_init()
    serial_write_cstr(port, "space: interrupts enabled (PIC remapped, PIT 100Hz)")
  serial_nl(port)

  let shown = 0
  while shown < 1 {
    hlt()
    if ticks >= (shown + 1) * 20 {
      serial_write_cstr(port, "space: timer ticks 0x")
      serial_write_hex(port, ticks)
      serial_nl(port)
      shown = shown + 1
    }
  }

  // Hand the running system to the component supervisor.
  run_supervisor(port)

  // Run the cooperative multitasking scheduler.
  run_scheduler(port)

  // Demonstrate typed-channel IPC between scheduled components.
  run_channels(port)

  // Demonstrate timer-driven preemptive multitasking.
  run_preemptive(port)

  if load64(0x140000) == SCI_MAGIC {
    sci_load(port, 0x140000)
  }

  // Initialize the process abstraction layer.
  proc_init(16)
  serial_write_cstr(port, "space: process table initialized (max 16)")
  serial_nl(port)

  // Initialize the flat filesystem (loads file table from disk if formatted).
  fs_init()
  serial_write_cstr(port, "space: filesystem initialized")
  serial_nl(port)

  // Initialize PS/2 keyboard driver and VGA text mode console.
  keyboard_init()
  serial_write_cstr(port, "space: PS/2 keyboard driver initialized (polling)")
  serial_nl(port)
  vga_clear()
  vga_puts("Space OS v0.0.1\n")
  serial_write_cstr(port, "space: VGA text mode console initialized")
  serial_nl(port)

  // Drop into the interactive serial shell.
  shell(port)

    serial_write_cstr(port, "space: nanokernel ready, total ticks 0x")
  serial_write_hex(port, ticks)
  serial_nl(port)
    serial_write_cstr(port, "space: halting")
  serial_nl(port)
  cli()
  while true {
    hlt()
  }
  return 0
}
