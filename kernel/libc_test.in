package space.kernel

fn libc-check(cond: Int, msg: Int) -> Int {
  let port = com1()
  if cond != 0 {
    serial-write-cstr(port, "  ok: ")
    serial-write-cstr(port, msg)
    serial-nl(port)
    return 1
  }
  serial-write-cstr(port, "  FAIL: ")
  serial-write-cstr(port, msg)
  serial-nl(port)
  return 0
}

fn libc-selftest-string() -> Int {
  let pass = 1

  // --- string functions ---
  let s1 = "hello"
  let s2 = malloc(16)
  strlcpy(s2, s1, 16)
  pass = pass & libc-check(strlen(s1) == 5, "strlen basic")
  pass = pass & libc-check(strlen("") == 0, "strlen empty string")
  pass = pass & libc-check(strlen("hello world") == 11, "strlen long")
  pass = pass & libc-check(strlen("a b c") == 5, "strlen with spaces")

  pass = pass & libc-check(strlen("a") == 1, "strlen single char")

  let dyn-str = malloc(8)
  store8(dyn-str, 65)
  store8(dyn-str + 1, 66)
  store8(dyn-str + 2, 0)
  pass = pass & libc-check(strlen(dyn-str) == 2, "strlen dynamic buffer")

  let n-str = malloc(8)
  store8(n-str, 65) // 'A'
  store8(n-str + 1, 0) // NUL
  store8(n-str + 2, 66) // 'B'
  store8(n-str + 3, 0) // NUL
  pass = pass & libc-check(strlen(n-str) == 1, "strlen embedded NUL")

  pass = pass & libc-check(strcmp(s2, s1) == 0, "strlcpy/strcmp equal")
  pass = pass & libc-check(strcmp("abc", "abd") < 0, "strcmp less")
  pass = pass & libc-check(strcmp("abd", "abc") > 0, "strcmp greater")

  let s3 = malloc(16)
  strncpy(s3, "abc", 5)
  pass = pass & libc-check(strncmp(s3, "abc", 3) == 0, "strncpy/strncmp")
  pass = pass & libc-check(load8(s3 + 3) == 0, "strncpy NUL pad")

  let s3-zero = malloc(16)
  memset(s3-zero, 65, 16)
  strncpy(s3-zero, "abc", 0)
  pass = pass & libc-check(load8(s3-zero) == 65, "strncpy zero length")

  let s3-trunc = malloc(16)
  memset(s3-trunc, 65, 16)
  strncpy(s3-trunc, "abcdef", 3)
  pass = pass & libc-check(strncmp(s3-trunc, "abc", 3) == 0, "strncpy truncate")
  pass = pass & libc-check(load8(s3-trunc + 3) == 65, "strncpy truncate no NUL")

  pass = pass & libc-check(strncmp("abc", "abd", 3) < 0, "strncmp less")
  pass = pass & libc-check(strncmp("abc", "abc", 5) == 0, "strncmp equal past NUL")

  let s5 = malloc(32)
  strlcpy(s5, "foo", 32)
  strncat(s5, "barbaz", 3)
  pass = pass & libc-check(strcmp(s5, "foobar") == 0, "strncat")

  pass = pass & libc-check(strchr("hello", 101) == "hello" + 1, "strchr 'e'")
  pass = pass & libc-check(strchr("hello", 122) == 0, "strchr not found")
  pass = pass & libc-check(strchr("hello", 0) == "hello" + 5, "strchr NUL")

  pass = pass & libc-check(strrchr("hello", 108) == "hello" + 3, "strrchr 'l'")
  pass = pass & libc-check(strrchr("hello", 122) == 0, "strrchr not found")

  pass = pass & libc-check(strstr("hello world", "world") == "hello world" + 6, "strstr found")
  pass = pass & libc-check(strstr("hello", "xyz") == 0, "strstr not found")
  pass = pass & libc-check(strstr("hello", "") == "hello", "strstr empty needle")

  let s6 = strdup("copyme")
  pass = pass & libc-check(strcmp(s6, "copyme") == 0, "strdup")

  let s7 = malloc(16)
  strlcpy(s7, "reverse", 16)
  strrev(s7)
  pass = pass & libc-check(strcmp(s7, "esrever") == 0, "strrev")

  return pass
}

fn libc-selftest-memory() -> Int {
  let pass = 1

  // --- memory functions ---
  let m1 = malloc(16)
  memset(m1, 65, 8)
  pass = pass & libc-check(load8(m1 + 0) == 65 && load8(m1 + 7) == 65, "memset")
  pass = pass & libc-check(load8(m1 + 8) == 0, "memset bounds")

  let m2 = malloc(16)
  memset(m2, 0, 16)
  memcpy(m2, m1, 8)
  pass = pass & libc-check(memcmp(m2, m1, 8) == 0, "memcpy/memcmp equal")
  // Set m1[8] to a non-zero value so memcmp at 9 bytes differs.
  store8(m1 + 8, 66)
  pass = pass & libc-check(memcmp(m2, m1, 9) != 0, "memcmp differ at 9")

  // memcmp return value tests
  let c1 = malloc(8)
  let c2 = malloc(8)
  memcpy(c1, "abc", 3)
  memcpy(c2, "abc", 3)
  pass = pass & libc-check(memcmp(c1, c2, 3) == 0, "memcmp equal")
  store8(c2 + 2, 100) // 'd'
  pass = pass & libc-check(memcmp(c1, c2, 3) < 0, "memcmp less than")
  pass = pass & libc-check(memcmp(c2, c1, 3) > 0, "memcmp greater than")
  pass = pass & libc-check(memcmp(c1, c2, 0) == 0, "memcmp zero length")

  pass = pass & libc-check(memcmp(c1, c1, 8) == 0, "memcmp identical pointers")

  let u1 = malloc(8)
  let u2 = malloc(8)
  memset(u1, 0, 8)
  memset(u2, 0, 8)
  store8(u1, 0xFF)
  store8(u2, 0x7F)
  pass = pass & libc-check(memcmp(u1, u2, 1) > 0, "memcmp unsigned char comparison")

  let d1 = malloc(16)
  let d2 = malloc(16)
  memset(d1, 65, 16)
  memset(d2, 65, 16)
  store8(d2 + 15, 66)
  pass = pass & libc-check(memcmp(d1, d2, 16) < 0, "memcmp diff at last byte")

  // memmove overlapping: copy forward (dst < src).
  let m3 = malloc(16)
  memset(m3, 0, 16)
  store8(m3 + 0, 1)
  store8(m3 + 1, 2)
  store8(m3 + 2, 3)
  store8(m3 + 3, 4)
  memmove(m3 + 1, m3, 3)
  pass = pass & libc-check(load8(m3 + 1) == 1 && load8(m3 + 2) == 2 && load8(m3 + 3) == 3, "memmove forward overlap")

  // memmove overlapping: copy backward (dst > src).
  let m4 = malloc(16)
  memset(m4, 0, 16)
  store8(m4 + 0, 1)
  store8(m4 + 1, 2)
  store8(m4 + 2, 3)
  store8(m4 + 3, 4)
  memmove(m4, m4 + 1, 3)
  pass = pass & libc-check(load8(m4 + 0) == 2 && load8(m4 + 1) == 3 && load8(m4 + 2) == 4, "memmove backward overlap")

  return pass
}

fn libc-selftest-ctype() -> Int {
  let pass = 1

  // --- ctype functions ---
  pass = pass & libc-check(isalpha(65) != 0, "isalpha 'A'")
  pass = pass & libc-check(isalpha(97) != 0, "isalpha 'a'")
  pass = pass & libc-check(isalpha(48) == 0, "isalpha '0' false")
  pass = pass & libc-check(isdigit(48) != 0, "isdigit '0'")
  pass = pass & libc-check(isdigit(65) == 0, "isdigit 'A' false")
  pass = pass & libc-check(isalnum(65) != 0, "isalnum 'A'")
  pass = pass & libc-check(isalnum(48) != 0, "isalnum '0'")
  pass = pass & libc-check(isalnum(32) == 0, "isalnum ' ' false")
  pass = pass & libc-check(isspace(32) != 0, "isspace ' '")
  pass = pass & libc-check(isspace(10) != 0, "isspace newline")
  pass = pass & libc-check(isspace(65) == 0, "isspace 'A' false")
  pass = pass & libc-check(isupper(65) != 0, "isupper 'A'")
  pass = pass & libc-check(isupper(97) == 0, "isupper 'a' false")
  pass = pass & libc-check(islower(97) != 0, "islower 'a'")
  pass = pass & libc-check(islower(65) == 0, "islower 'A' false")
  pass = pass & libc-check(isprint(65) != 0, "isprint 'A'")
  pass = pass & libc-check(isprint(31) == 0, "isprint 0x1F false")
  pass = pass & libc-check(toupper(97) == 65, "toupper 'a'->'A'")
  pass = pass & libc-check(tolower(65) == 97, "tolower 'A'->'a'")
  pass = pass & libc-check(toupper(65) == 65, "toupper 'A' unchanged")

  return pass
}

fn libc-selftest-conversion() -> Int {
  let pass = 1

  // --- conversion functions ---
  pass = pass & libc-check(atoi("42") == 42, "atoi 42")
  pass = pass & libc-check(atoi("-7") == -7, "atoi -7")
  pass = pass & libc-check(atoi("  123") == 123, "atoi whitespace skip")
  pass = pass & libc-check(atoi("+99") == 99, "atoi +99")
  pass = pass & libc-check(atol("12345") == 12345, "atol 12345")

  let ibuf = malloc(32)
  let ilen = itoa(42, ibuf, 10)
  pass = pass & libc-check(ilen == 2 && strcmp(ibuf, "42") == 0, "itoa 42 base 10")

  let ilen2 = itoa(-7, ibuf, 10)
  pass = pass & libc-check(ilen2 == 2 && strcmp(ibuf, "-7") == 0, "itoa -7 base 10")

  let ilen3 = itoa(255, ibuf, 16)
  pass = pass & libc-check(ilen3 == 2 && strcmp(ibuf, "FF") == 0, "itoa 255 base 16")

  let ilen4 = itoa(10, ibuf, 2)
  pass = pass & libc-check(ilen4 == 4 && strcmp(ibuf, "1010") == 0, "itoa 10 base 2")

  let ilen5 = itoa(0, ibuf, 10)
  pass = pass & libc-check(ilen5 == 1 && strcmp(ibuf, "0") == 0, "itoa 0 base 10")

  let hbuf = malloc(20)
  let hlen = htoa(0xDEAD, hbuf)
  pass = pass & libc-check(hlen == 18 && strcmp(hbuf, "0x000000000000dead") == 0, "htoa 0xDEAD")

  let ubuf = malloc(21)
  let ulen = utoa(12345, ubuf)
  pass = pass & libc-check(ulen == 5 && strcmp(ubuf, "12345") == 0, "utoa 12345")

  let ulen2 = utoa(0, ubuf)
  pass = pass & libc-check(ulen2 == 1 && strcmp(ubuf, "0") == 0, "utoa 0")

  return pass
}

fn libc-selftest-printf() -> Int {
  let port = com1()
  // --- printf tests ---
  serial-write-cstr(port, "  printf tests (visual check):")
  serial-nl(port)
  serial-write-cstr(port, "    ")
  printf("str=%s dec=%d hex=%x char=%c pct=%%", "test", 42, 255, 65)
  serial-nl(port)
  serial-write-cstr(port, "    ")
  printf("pad: %08x | %8d | %d", 0xCAFE, 42, -7)
  serial-nl(port)
  serial-write-cstr(port, "    ")
  printf("bin=%b u=%u", 10, 100)
  serial-nl(port)
  return 1
}

fn libc-selftest-math() -> Int {
  let pass = 1

  // --- math functions ---
  pass = pass & libc-check(abs(-5) == 5, "abs -5")
  pass = pass & libc-check(abs(5) == 5, "abs 5")
  pass = pass & libc-check(max(3, 7) == 7, "max 3 7")
  pass = pass & libc-check(min(3, 7) == 3, "min 3 7")
  pass = pass & libc-check(pow(2, 10) == 1024, "pow 2^10")
  pass = pass & libc-check(pow(3, 0) == 1, "pow 3^0")
  pass = pass & libc-check(gcd(12, 18) == 6, "gcd 12 18")
  pass = pass & libc-check(gcd(17, 5) == 1, "gcd 17 5")
  pass = pass & libc-check(lcm(4, 6) == 12, "lcm 4 6")
  pass = pass & libc-check(lcm(0, 5) == 0, "lcm 0 5")

  return pass
}

fn libc-selftest-time() -> Int {
  let pass = 1

  // --- time functions ---
  let t0 = time-ticks()
  pass = pass & libc-check(t0 >= 0, "time_ticks non-negative")
  let up = time-uptime-ms()
  pass = pass & libc-check(up == t0 * 10, "time_uptime_ms")
  // Brief sleep test (10ms = 1 tick at 100Hz).
  time-sleep-ms(10)
  let t1 = time-ticks()
  pass = pass & libc-check(t1 > t0, "time_sleep_ms advanced ticks")

  return pass
}

fn libc-selftest-utility() -> Int {
  let port = com1()
  // --- utility functions ---
  // hex_dump visual test.
  serial-write-cstr(port, "  hex_dump test (visual check):")
  serial-nl(port)
  hex-dump("Hello, World!", 14)
  return 1
}

fn libc-selftest-panic() -> Int {
  let pass = 1

  panic-test-mode = 1
  panic-test-msg = 0
  panic-test-halted = 0

  panic("test panic message")

  pass = pass & libc-check(panic-test-halted == 1, "panic early exit in test mode")
  pass = pass & libc-check(strcmp(panic-test-msg, "test panic message") == 0, "panic stores correct message")

  panic-test-mode = 0
  return pass
}

fn libc-selftest-malloc() -> Int {
  let pass = 1

  // --- memory allocation ---
  let a1 = malloc(100)
  memset(a1, 0xAB, 100)
  pass = pass & libc-check(load8(a1 + 50) == 0xAB, "malloc + memset 100 bytes")
  pass = pass & libc-check(malloc(-1) == 0, "malloc bounds check negative")
  pass = pass & libc-check(malloc(0x7FFFFFFFFFFFFFF1) == 0, "malloc bounds check overflow")

  let a2 = calloc(10, 8)
  pass = pass & libc-check(load8(a2 + 0) == 0 && load8(a2 + 79) == 0, "calloc zeroed")

  let a3 = malloc(8)
  store64(a3, 0x12345678)
  let a4 = realloc(a3, 16)
  pass = pass & libc-check(load64(a4) == 0x12345678, "realloc preserves data")

  let a5 = malloc(16)
  store64(a5, 0x11223344)
  store64(a5 + 8, 0x55667788)
  let a6 = realloc(a5, 8)
  pass = pass & libc-check(load64(a6) == 0x11223344, "realloc truncates data")

  let a7 = realloc(0, 8)
  store64(a7, 0x99AABBCC)
  pass = pass & libc-check(load64(a7) == 0x99AABBCC, "realloc from null acts as malloc")

  return pass
}

// Run a battery of tests for every libc function. Prints diagnostic output
// and "libc self-test passed" on success. Returns 1 on pass, 0 on fail.

fn libc-selftest-fmt-unsigned-base() -> Int {
  let pass = 1
  let buf = malloc(64)
  let len = 0

  // val = 0
  len = fmt-unsigned-base(0, 10, buf)
  pass = pass & libc-check(len == 1, "fmt_unsigned_base 0 length")
  pass = pass & libc-check(strcmp(buf, "0") == 0, "fmt_unsigned_base 0 value")

  // base 10
  len = fmt-unsigned-base(12345, 10, buf)
  pass = pass & libc-check(len == 5, "fmt_unsigned_base base 10 length")
  pass = pass & libc-check(strcmp(buf, "12345") == 0, "fmt_unsigned_base base 10 value")

  // base 16
  len = fmt-unsigned-base(255, 16, buf)
  pass = pass & libc-check(len == 2, "fmt_unsigned_base base 16 length")
  pass = pass & libc-check(strcmp(buf, "ff") == 0, "fmt_unsigned_base base 16 value")

  // base 2
  len = fmt-unsigned-base(10, 2, buf)
  pass = pass & libc-check(len == 4, "fmt_unsigned_base base 2 length")
  pass = pass & libc-check(strcmp(buf, "1010") == 0, "fmt_unsigned_base base 2 value")

  // negative value (treated as absolute by current implementation)
  len = fmt-unsigned-base(-42, 10, buf)
  pass = pass & libc-check(len == 2, "fmt_unsigned_base negative length")
  pass = pass & libc-check(strcmp(buf, "42") == 0, "fmt_unsigned_base negative value")

  // large base
  len = fmt-unsigned-base(35, 36, buf)
  pass = pass & libc-check(len == 1, "fmt_unsigned_base base 36 length")
  pass = pass & libc-check(strcmp(buf, "z") == 0, "fmt_unsigned_base base 36 value")

  free(buf)
  return pass
}

fn libc-selftest() -> Int {
  let port = com1()
  serial-write-cstr(port, "libc: running comprehensive self-test")
  serial-nl(port)
  let pass = 1

  pass = pass & libc-selftest-string()
  pass = pass & libc-selftest-memory()
  pass = pass & libc-selftest-ctype()
  pass = pass & libc-selftest-conversion()
  pass = pass & libc-selftest-printf()
  pass = pass & libc-selftest-fmt-unsigned-base()
  pass = pass & libc-selftest-math()
  pass = pass & libc-selftest-time()
  pass = pass & libc-selftest-utility()
  pass = pass & libc-selftest-panic()
  pass = pass & libc-selftest-malloc()

  if pass != 0 {
    serial-write-cstr(port, "libc self-test passed")
    serial-nl(port)
    return 1
  }
  serial-write-cstr(port, "libc self-test FAILED")
  serial-nl(port)
  return 0
}

fn test-sci-loader(port: Int) -> Int {
  let buf = alloc(40)
  store64(buf + 0, SCI-MAGIC)
  store64(buf + 8, 1) // required_caps (serial)
  store64(buf + 16, 0x40000020) // entry
  store64(buf + 24, 40) // image_size

  // Write guest machine code: mov rax, 0x42; ret
  // 48 c7 c0 42 00 00 00 c3
  store8(buf + 32, 0x48)
  store8(buf + 33, 0xC7)
  store8(buf + 34, 0xC0)
  store8(buf + 35, 0x42)
  store8(buf + 36, 0x00)
  store8(buf + 37, 0x00)
  store8(buf + 38, 0x00)
  store8(buf + 39, 0xC3)

  // Write the file to flat filesystem
  let wrc = fs-write-file("test.sci", buf, 40)
  if wrc != 0 {
    serial-write-cstr(port, "test_sci_loader: write failed")
    serial-nl(port)
    return 0
  }

  // Now load and run it via sci_load_file!
  let status = sci-load-file(port, "test.sci")
  if status == 0x42 {
    serial-write-cstr(port, "test_sci_loader: PASS")
    serial-nl(port)
    return 1
  }
  serial-write-cstr(port, "test_sci_loader: FAIL (status = 0x")
  serial-write-hex(port, status)
  serial-write-cstr(port, ")")
  serial-nl(port)
  return 0
}
