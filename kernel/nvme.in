package space.kernel

import "../components/storage.in"

// Kernel-side stub for the extracted Storage component. The real NVMe driver
// lives in components/storage.in and runs in its own isolated domain. This file
// starts the component and forwards NVMe read/write requests over the
// cross-domain mailbox shared page.

var nvme-ready: Int = 0

fn nvme-start-storage-component(port: Int) -> Int {
  if storage-started != 0 {
    return 0
  }
  storage-domain = domain-create()
  if storage-domain == 0 {
    storage-domain = 1
  }

  let shared-mailbox = domain-create-shared-page(0, storage-domain, STORAGE-MAILBOX-VIRT, STORAGE-MAILBOX-VIRT)
  if shared-mailbox == 0 {
    storage-mailbox = alloc(4096)
  } else {
    storage-mailbox = STORAGE-MAILBOX-VIRT
  }
  let shared-data = domain-create-shared-page(0, storage-domain, STORAGE-DATA-VIRT, STORAGE-DATA-VIRT)
  if shared-data == 0 {
    storage-data-page = alloc(4096)
    storage-data-phys = storage-data-page
  } else {
    storage-data-page = STORAGE-DATA-VIRT
    storage-data-phys = shared-data
  }

  let i = 0
  while i < 512 {
    store64(storage-mailbox + i * 8, 0)
    i = i + 1
  }

  storage-cap-info = alloc(24)
  store64(storage-cap-info + 0, cap-count)
  store64(storage-cap-info + 8, cap-table-base)
  store64(storage-cap-info + 16, storage-mailbox)

  let comp = component-register("storage", storage-entry, cap-storage() | cap-memory() | cap-serial())
  cap-mint(comp, cap-storage() | cap-memory() | cap-serial())
  domain-switch(storage-domain)
  storage-entry(storage-cap-info)
  domain-switch(0)
  storage-started = 1

  if storage-ready != 1 {
    serial-write-cstr(port, "  storage: component failed to become ready")
    serial-nl(port)
    return -1
  }
  return 0
}

fn nvme-submit(op: Int, lba: Int, count: Int) -> Int {
  while load64(storage-mailbox + STORAGE-OP-OFF) != 0 {
  }
  store64(storage-mailbox + STORAGE-LBA-OFF, lba)
  store64(storage-mailbox + STORAGE-COUNT-OFF, count)
  store64(storage-mailbox + STORAGE-STATUS-OFF, 0)
  store64(storage-mailbox + STORAGE-OP-OFF, op)
  // Save caller domain so nested RPC from Volume (or POSIX) restores CR3
  // correctly instead of always dropping back to domain 0.
  let prev = domain-get-current()
  domain-switch(storage-domain)
  storage-service()
  domain-switch(prev)
  return load64(storage-mailbox + STORAGE-STATUS-OFF)
}

fn nvme-init() -> Int {
  if nvme-ready != 0 {
    return 0
  }
  let port = com1()
  if nvme-start-storage-component(port) != 0 {
    return -1
  }
  nvme-ready = 1
  serial-write-cstr(port, "  nvme: storage component ready")
  serial-nl(port)
  return 0
}

fn nvme-read(lba: Int, count: Int, buf: Int) -> Int {
  if nvme-ready == 0 {
    if nvme-init() != 0 {
      return -1
    }
  }
  let rc = nvme-submit(STORAGE-OP-READ, lba, count)
  if rc == 0 && buf != storage-data-page {
    let i = 0
    while i < count * 512 {
      store8(buf + i, load8(storage-data-page + i))
      i = i + 1
    }
  }
  return rc
}

fn nvme-write(lba: Int, count: Int, buf: Int) -> Int {
  if nvme-ready == 0 {
    if nvme-init() != 0 {
      return -1
    }
  }
  if buf != storage-data-page {
    let i = 0
    while i < count * 512 {
      store8(storage-data-page + i, load8(buf + i))
      i = i + 1
    }
  }
  return nvme-submit(STORAGE-OP-WRITE, lba, count)
}

fn nvme-dump16(port: Int, buf: Int) -> void {
  return
}

fn nvme-dump(port: Int, buf: Int, n: Int) -> void {
  return
}

fn nvme-shell(port: Int) -> void {
  serial-write-cstr(port, "  nvme: storage component shell not implemented")
  serial-nl(port)
  return
}

fn nvme-shell-read(port: Int, lba: Int) -> void {
  serial-write-cstr(port, "  nvme: storage component shell read not implemented")
  serial-nl(port)
  return
}
