package space.kernel

// --- serial console (COM1) --------------------------------------------------
const COM1-PORT = 0x3F8
const SPACE-VERSION-MAJOR = 0
const SPACE-VERSION-MINOR = 2
const SPACE-VERSION-PATCH = 75

fn com1() -> Int {
  return COM1-PORT
}

fn serial-init(port: Int) -> void {
  outb(port + 1, 0x00)
  outb(port + 3, 0x80)
  outb(port + 0, 0x03)
  outb(port + 1, 0x00)
  outb(port + 3, 0x03)
  outb(port + 2, 0xC7)
  outb(port + 4, 0x0B)
  return
}

fn serial-wait-tx(port: Int) -> void {
  while (inb(port + 5) & 0x20) == 0 {
  }
  return
}

fn serial-put(port: Int, ch: Int) -> void {
  serial-wait-tx(port)
  outb(port, ch)
  return
}

fn serial-nl(port: Int) -> void {
  serial-put(port, 10)
  return
}

fn serial-write-cstr(port: Int, addr: Int) -> void {
  let i = 0
  let c = load8(addr + i)
  while c != 0 {
    serial-put(port, c)
    i = i + 1
    c = load8(addr + i)
  }
  return
}

fn serial-write-dec-wide(port: Int, value: Int) -> void {
  let n = value
  if n < 0 {
    serial-put(port, 45)  // '-'
    n = -n
  }
  if n == 0 {
    serial-put(port, 48)  // '0'
    return
  }
  let div = 1
  while n / div >= 10 {
    div = div * 10
  }
  while div > 0 {
    serial-put(port, 48 + (n / div) % 10)
    div = div / 10
  }
  return
}

fn serial-write-hex(port: Int, value: Int) -> void {
  let shift = 60
  while shift >= 0 {
    let nibble = (value >> shift) & 0xF
    if nibble < 10 {
      serial-put(port, 48 + nibble)
    } else {
      serial-put(port, 87 + nibble)
    }
    shift = shift - 4
  }
  return
}
