package space.kernel

// USB xHCI and HID keyboard driver stub.
// The full driver logic has moved to components/input.in. This file preserves
// the public symbols so kernel-root.in and compositor.in continue to compile.

fn xhci-init() -> Int {
  return -1
}

fn usb-kbd-init() -> Int {
  return -1
}

fn usb-kbd-ready() -> Int {
  return 0
}

fn usb-kbd-getchar() -> Int {
  return -1
}

fn usb-kbd-wait-key() -> Int {
  return -1
}

fn usb-kbd-cmd(port: Int) -> void {
  serial-write-cstr(port, "  no keyboard")
  serial-nl(port)
  return
}

fn xhci-kbd-poll() -> Int {
  return 0
}

fn hid-to-ascii(usage: Int) -> Int {
  return 0
}
