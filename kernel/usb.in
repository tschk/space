package space.kernel

// USB xHCI and HID keyboard driver stub.
// The full driver logic has moved to components/input.in. This file preserves
// the public symbols so kernel-root.in and compositor.in continue to compile.

fn xhci_init() -> Int {
  return -1
}

fn usb_kbd_init() -> Int {
  return -1
}

fn usb_kbd_ready() -> Int {
  return 0
}

fn usb_kbd_getchar() -> Int {
  return -1
}

fn usb_kbd_wait_key() -> Int {
  return -1
}

fn usb_kbd_cmd(port: Int) -> void {
  serial_write_cstr(port, "  no keyboard")
  serial_nl(port)
  return
}

fn xhci_kbd_poll() -> Int {
  return 0
}

fn hid_to_ascii(usage: Int) -> Int {
  return 0
}
