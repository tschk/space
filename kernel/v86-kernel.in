package space.kernel

// Minimal 32-bit v86 kernel: serial shell on COM1, keyboard input via PS/2.

const COM1_PORT = 0x3F8
const KBD_TABLE = 0x3000

const FILE_README = "README.md"
const DATA_README = "Space 32-bit v86 kernel\n\nThis kernel is written in .in, the native language of the Inauguration compiler, and lowered to bare i386 machine code. It boots inside the browser via the v86 emulator with a PS/2 keyboard and serial console.\n\nTry: help, ls, cat README.md, echo hello, about\n"

const FILE_ABOUT = "ABOUT.md"
const DATA_ABOUT = "Why Space is different\n\nSpace is a component-based operating system. The native model is component + capability + object + execution graph, not process + file + syscall + user.\n\n       .in          native language\n       Inauguration  compiler\n       SCI           component image format\n       Space         OS runtime\n       Nanokernel    hardware enforcement\n\nThere is no POSIX in the kernel. Linux, Darwin, and Windows compatibility are .in microservices that translate legacy concepts into Space primitives.\n"

const FILE_NOTES = "notes.txt"
const DATA_NOTES = "This is a scratch file. Use the 'edit' command to change it.\n"

const EDIT_BUF = 0x6000
const EDIT_BUF_SIZE = 1024

const HIST_BUF = 0x7500
const HIST_MAX = 16
const HIST_ENTRY_SIZE = 80

var edit_len: Int = 0
var hist_count: Int = 0
var boot_tick: Int = 0

fn kernel_entry(mb_info: Int) -> Int {
  keyboard_init()
  serial_init()

  edit_len = cstr_copy(EDIT_BUF, DATA_NOTES, EDIT_BUF_SIZE - 1)

  print_welcome()

  let running = true
  while running {
    serial_put(62)
    serial_put(32)
    let len = read_line()
    if len == 0 {
      continue
    }
    history_add(LINE_BUF)
    if match_command("help") {
      cmd_help()
    } else if match_command("about") {
      cmd_cat(FILE_ABOUT)
    } else if match_command("info") {
      serial_write_cstr("v86 32-bit protected mode")
      serial_nl()
      serial_write_cstr("mb_info: 0x")
      serial_write_hex32(mb_info)
      serial_nl()
    } else if match_command("ls") {
      cmd_ls()
    } else if match_command("cat") {
      cmd_cat(arg_at(1))
    } else if match_command("echo") {
      cmd_echo(arg_at(1))
    } else if match_command("pwd") {
      serial_write_cstr("/")
      serial_nl()
    } else if match_command("whoami") {
      serial_write_cstr("space")
      serial_nl()
    } else if match_command("clear") {
      serial_write_cstr("\x1b[2J\x1b[H")
    } else if match_command("edit") || match_command("vro") {
      cmd_edit(arg_at(1))
    } else if match_command("history") {
      cmd_history()
    } else if match_command("uname") {
      serial_write_cstr("Space v86 32-bit .in kernel")
      serial_nl()
    } else if match_command("reset") {
      serial_write_cstr("resetting")
      serial_nl()
      outb(0x64, 0xFE)
    } else if match_command("halt") {
      serial_write_cstr("halting")
      serial_nl()
      cli()
      while true {
        hlt()
      }
    } else {
      serial_write_cstr("unknown command: ")
      serial_write_cstr(LINE_BUF)
      serial_nl()
    }
  }
  return 0
}

fn print_welcome() -> void {
  serial_write_cstr("Space 32-bit v86")
  serial_nl()
  serial_write_cstr("A microkernel shell running in the browser, written in .in and compiled to i386.")
  serial_nl()
  serial_write_cstr("Type 'help' for commands, 'about' for the pitch, or 'ls' to see root files.")
  serial_nl()
  serial_nl()
  return
}

fn cmd_help() -> void {
  serial_write_cstr("help    - this message")
  serial_nl()
  serial_write_cstr("about   - what Space is and why it is different")
  serial_nl()
  serial_write_cstr("info    - show boot info")
  serial_nl()
  serial_write_cstr("ls      - list root files")
  serial_nl()
  serial_write_cstr("cat     - print a file")
  serial_nl()
  serial_write_cstr("echo    - print text")
  serial_nl()
  serial_write_cstr("clear   - clear the screen")
  serial_nl()
  serial_write_cstr("pwd     - print working directory")
  serial_nl()
  serial_write_cstr("whoami  - print current user")
  serial_nl()
  serial_write_cstr("edit    - edit notes.txt")
  serial_nl()
  serial_write_cstr("vro     - same as edit")
  serial_nl()
  serial_write_cstr("history - show previous commands")
  serial_nl()
  serial_write_cstr("uname   - print kernel name")
  serial_nl()
  serial_write_cstr("reset   - reboot the machine")
  serial_nl()
  serial_write_cstr("halt    - stop the cpu")
  serial_nl()
  return
}

fn cmd_ls() -> void {
  serial_write_cstr(FILE_README)
  serial_nl()
  serial_write_cstr(FILE_ABOUT)
  serial_nl()
  serial_write_cstr(FILE_NOTES)
  serial_nl()
  return
}

fn cmd_cat(name: Int) -> void {
  if name == 0 {
    serial_write_cstr("usage: cat <file>")
    serial_nl()
    return
  }
  if cstr_eq(name, FILE_README) {
    serial_write_cstr(DATA_README)
    return
  }
  if cstr_eq(name, FILE_ABOUT) {
    serial_write_cstr(DATA_ABOUT)
    return
  }
  if cstr_eq(name, FILE_NOTES) {
    serial_write_cstr(EDIT_BUF)
    return
  }
  serial_write_cstr("cat: ")
  serial_write_cstr(name)
  serial_write_cstr(": no such file")
  serial_nl()
  return
}

fn cmd_echo(text: Int) -> void {
  if text != 0 {
    serial_write_cstr(text)
  }
  serial_nl()
  return
}

fn cmd_edit(name: Int) -> void {
  if name == 0 {
    name = FILE_NOTES
  }
  if !cstr_eq(name, FILE_NOTES) {
    serial_write_cstr("edit: only ")
    serial_write_cstr(FILE_NOTES)
    serial_write_cstr(" is editable")
    serial_nl()
    return
  }
  serial_write_cstr("VRO editor: type lines, Backspace to correct, '.exit' to save, '.cancel' to discard.")
  serial_nl()
  serial_write_cstr("Current content:")
  serial_nl()
  serial_write_cstr(EDIT_BUF)
  serial_write_cstr("---")
  serial_nl()
  while true {
    serial_put(43)
    serial_put(32)
    let len = read_line()
    if len == 0 {
      continue
    }
    if cstr_eq(LINE_BUF, ".exit") {
      break
    }
    if cstr_eq(LINE_BUF, ".cancel") {
      edit_len = cstr_copy(EDIT_BUF, DATA_NOTES, EDIT_BUF_SIZE - 1)
      serial_write_cstr("discarded")
      serial_nl()
      return
    }
    let i = 0
    while i < len && edit_len < EDIT_BUF_SIZE - 2 {
      store8(EDIT_BUF + edit_len, load8(LINE_BUF + i))
      edit_len = edit_len + 1
      i = i + 1
    }
    store8(EDIT_BUF + edit_len, 10)
    edit_len = edit_len + 1
    store8(EDIT_BUF + edit_len, 0)
  }
  serial_write_cstr("saved ")
  serial_write_num(edit_len)
  serial_write_cstr(" bytes")
  serial_nl()
  return
}

fn history_add(cmd: Int) -> void {
  if hist_count >= HIST_MAX {
    let i = 0
    while i < HIST_MAX - 1 {
      cstr_copy(HIST_BUF + i * HIST_ENTRY_SIZE, HIST_BUF + (i + 1) * HIST_ENTRY_SIZE, HIST_ENTRY_SIZE - 1)
      i = i + 1
    }
    hist_count = HIST_MAX - 1
  }
  let slot = HIST_BUF + hist_count * HIST_ENTRY_SIZE
  cstr_copy(slot, cmd, HIST_ENTRY_SIZE - 1)
  hist_count = hist_count + 1
  return
}

fn cmd_history() -> void {
  serial_write_cstr("command history:")
  serial_nl()
  let i = 0
  while i < hist_count {
    let slot = HIST_BUF + i * HIST_ENTRY_SIZE
    serial_write_num(i + 1)
    serial_write_cstr("  ")
    serial_write_cstr(slot)
    serial_nl()
    i = i + 1
  }
  return
}

fn cstr_eq(a: Int, b: Int) -> Bool {
  let i = 0
  while true {
    let ca = load8(a + i)
    let cb = load8(b + i)
    if ca != cb {
      return false
    }
    if ca == 0 {
      return true
    }
    i = i + 1
  }
  return false
}

fn cstr_copy(dst: Int, src: Int, max: Int) -> Int {
  let i = 0
  while i < max {
    let ch = load8(src + i)
    store8(dst + i, ch)
    if ch == 0 {
      return i
    }
    i = i + 1
  }
  store8(dst + max, 0)
  return max
}

fn arg_at(idx: Int) -> Int {
  let i = 0
  let n = 0
  while n < idx {
    while load8(LINE_BUF + i) != 0 && load8(LINE_BUF + i) != 32 {
      i = i + 1
    }
    while load8(LINE_BUF + i) == 32 {
      i = i + 1
    }
    n = n + 1
  }
  if load8(LINE_BUF + i) == 0 {
    return 0
  }
  return LINE_BUF + i
}

// PS/2 keyboard scancode set 1 -> ASCII lookup table.
fn keyboard_init() -> void {
  // Enable keyboard scanning on the PS/2 controller and discard the 0xFA ACK.
  outb(0x60, 0xF4)
  while (inb(0x64) & 0x01) == 0 {
    outb(0x80, 0)
  }
  inb(0x60)

  let i = 0
  while i < 128 {
    store8(KBD_TABLE + i, 0)
    i = i + 1
  }
  store8(KBD_TABLE + 0x02, 49)
  store8(KBD_TABLE + 0x03, 50)
  store8(KBD_TABLE + 0x04, 51)
  store8(KBD_TABLE + 0x05, 52)
  store8(KBD_TABLE + 0x06, 53)
  store8(KBD_TABLE + 0x07, 54)
  store8(KBD_TABLE + 0x08, 55)
  store8(KBD_TABLE + 0x09, 56)
  store8(KBD_TABLE + 0x0A, 57)
  store8(KBD_TABLE + 0x0B, 48)
  store8(KBD_TABLE + 0x0C, 45)
  store8(KBD_TABLE + 0x0D, 61)
  store8(KBD_TABLE + 0x10, 113)
  store8(KBD_TABLE + 0x11, 119)
  store8(KBD_TABLE + 0x12, 101)
  store8(KBD_TABLE + 0x13, 114)
  store8(KBD_TABLE + 0x14, 116)
  store8(KBD_TABLE + 0x15, 121)
  store8(KBD_TABLE + 0x16, 117)
  store8(KBD_TABLE + 0x17, 105)
  store8(KBD_TABLE + 0x18, 111)
  store8(KBD_TABLE + 0x19, 112)
  store8(KBD_TABLE + 0x1E, 97)
  store8(KBD_TABLE + 0x1F, 115)
  store8(KBD_TABLE + 0x20, 100)
  store8(KBD_TABLE + 0x21, 102)
  store8(KBD_TABLE + 0x22, 103)
  store8(KBD_TABLE + 0x23, 104)
  store8(KBD_TABLE + 0x24, 106)
  store8(KBD_TABLE + 0x25, 107)
  store8(KBD_TABLE + 0x26, 108)
  store8(KBD_TABLE + 0x2C, 122)
  store8(KBD_TABLE + 0x2D, 120)
  store8(KBD_TABLE + 0x2E, 99)
  store8(KBD_TABLE + 0x2F, 118)
  store8(KBD_TABLE + 0x30, 98)
  store8(KBD_TABLE + 0x31, 110)
  store8(KBD_TABLE + 0x32, 109)
  store8(KBD_TABLE + 0x33, 44)
  store8(KBD_TABLE + 0x34, 46)
  store8(KBD_TABLE + 0x35, 47)
  store8(KBD_TABLE + 0x39, 32)
  store8(KBD_TABLE + 0x1C, 13)
  store8(KBD_TABLE + 0x0E, 8)
  return
}

fn keyboard_get() -> Int {
  while (inb(0x64) & 0x01) == 0 {
    outb(0x80, 0)
  }
  let scancode = inb(0x60)
  if scancode >= 128 {
    return 0
  }
  return load8(KBD_TABLE + scancode)
}

// Line buffer in low bss-free scratch (trampoline reserves 0..0x1000; use 0x5000).
const LINE_BUF = 0x5000

fn read_line() -> Int {
  let line_len = 0
  while true {
    let ch = keyboard_get()
    if ch == 0 {
      continue
    }
    if ch == 13 || ch == 10 {
      store8(LINE_BUF + line_len, 0)
      serial_nl()
      return line_len
    }
    if ch == 8 || ch == 127 {
      if line_len > 0 {
        line_len = line_len - 1
        serial_put(8)
        serial_put(32)
        serial_put(8)
      }
    } else if ch >= 32 && ch < 127 {
      if line_len < 79 {
        store8(LINE_BUF + line_len, ch)
        line_len = line_len + 1
        serial_put(ch)
      }
    }
  }
  return 0
}

fn match_command(cmd: Int) -> Bool {
  let i = 0
  while true {
    let c = load8(cmd + i)
    let b = load8(LINE_BUF + i)
    if c == 0 {
      return b == 0 || b == 32 || b == 10 || b == 13
    }
    if c != b {
      return false
    }
    i = i + 1
  }
  return false
}

fn serial_init() -> void {
  outb(COM1_PORT + 1, 0x00)
  outb(COM1_PORT + 3, 0x80)
  outb(COM1_PORT + 0, 0x03)
  outb(COM1_PORT + 1, 0x00)
  outb(COM1_PORT + 3, 0x03)
  outb(COM1_PORT + 2, 0x07)
  outb(COM1_PORT + 4, 0x0B)
  return
}

fn serial_wait_tx() -> void {
  while (inb(COM1_PORT + 5) & 0x20) == 0 {
    pause()
  }
  return
}

fn serial_put(ch: Int) -> void {
  serial_wait_tx()
  outb(COM1_PORT, ch)
  return
}

fn serial_nl() -> void {
  serial_put(10)
  return
}

fn serial_write_cstr(addr: Int) -> void {
  let i = 0
  let c = load8(addr + i)
  while c != 0 {
    serial_put(c)
    i = i + 1
    c = load8(addr + i)
  }
  return
}

fn serial_write_hex32(value: Int) -> void {
  let shift = 28
  while shift >= 0 {
    let nibble = (value >> shift) & 0xF
    if nibble < 10 {
      serial_put(48 + nibble)
    } else {
      serial_put(87 + nibble)
    }
    shift = shift - 4
  }
  return
}

fn serial_write_num(value: Int) -> void {
  if value == 0 {
    serial_put(48)
    return
  }
  let buf = 0x7000
  let i = 0
  let v = value
  while v > 0 {
    store8(buf + i, 48 + (v % 10))
    v = v / 10
    i = i + 1
  }
  while i > 0 {
    i = i - 1
    serial_put(load8(buf + i))
  }
  return
}
