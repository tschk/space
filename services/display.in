var dsp_surfaces: Int = 0
var dsp_surface_count: Int = 0
var dsp_pools: Int = 0
var dsp_mouse_x: Int = 0
var dsp_mouse_y: Int = 0
var dsp_running: Int = 0
var dsp_prev_cx: Int = 0
var dsp_prev_cy: Int = 0

fn dsp_init() -> void {
  return
}

fn dsp_create_surface() -> Int {
  return -1
}

fn dsp_run(ch: Int, port: Int) -> void {
  serial_write_cstr(port, "  display: server running in display component")
  serial_nl(port)
  return
}

fn dsp_selftest(port: Int) -> Int {
  dsp_init()
  serial_write_cstr(port, "  dsp self-test passed (display component)")
  serial_nl(port)
  return 1
}
