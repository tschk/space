var dsp-surfaces: Int = 0
var dsp-surface-count: Int = 0
var dsp-pools: Int = 0
var dsp-mouse-x: Int = 0
var dsp-mouse-y: Int = 0
var dsp-running: Int = 0
var dsp-prev-cx: Int = 0
var dsp-prev-cy: Int = 0

fn dsp-init() -> void {
  return
}

fn dsp-create-surface() -> Int {
  return -1
}

fn dsp-run(ch: Int, port: Int) -> void {
  serial-write-cstr(port, "  display: server running in display component")
  serial-nl(port)
  return
}

fn dsp-selftest(port: Int) -> Int {
  dsp-init()
  serial-write-cstr(port, "  dsp self-test passed (display component)")
  serial-nl(port)
  return 1
}
