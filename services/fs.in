// Filesystem microservice.
// In-memory flat file store using component-local memory only.
// ponytail: no kernel alloc, no hardware access. Files are Int values
// stored in local variables. Real impl uses loader heap + block device.
component FileSystem {
  target "x86_64-space"
  deterministic true
  checkpoint none

  export svc: FileSystemApi

  capability serial: DebugConsole(write)
}

interface FileSystemApi {
  fn open(id: Int) -> Int
  fn read(fd: Int, offset: Int) -> Int
  fn write(fd: Int, offset: Int, value: Int) -> Int
}

var fs_file1_data: Int = 0
var fs_file1_len: Int = 0
var fs_file1_open: Int = 0

var fs_file2_data: Int = 0
var fs_file2_len: Int = 0
var fs_file2_open: Int = 0

fn fs_open(file_id: Int) -> Int {
  if file_id == 1 { fs_file1_open = 1; return 1 }
  if file_id == 2 { fs_file2_open = 1; return 2 }
  return 0
}

fn fs_read(fd: Int, offset: Int) -> Int {
  if fd == 1 { return fs_file1_data }
  if fd == 2 && fs_file2_open != 0 { return fs_file2_data }
  return -1
}

fn fs_write(fd: Int, offset: Int, value: Int) -> Int {
  if fd == 1 { fs_file1_data = value; fs_file1_len = 1; return 1 }
  if fd == 2 { fs_file2_data = value; fs_file2_len = 1; return 1 }
  return 0
}

fn fs_entry(shared_page: Int) -> Int {
  // ponytail: service contract. Real IPC uses shared page mapped by
  // kernel SCI loader. Until loader maps shared pages into component
  // domains, the service returns fixed values.
  return 1
}
