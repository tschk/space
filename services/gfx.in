// Graphics compositor microservice.
// ponytail: wraps kernel compositor. Surface management and blitting
// moved here when channel IPC is ready.

fn gfx_init(port: Int) -> void {
  serial_write_cstr(port, "  gfx: compositor available via 'desktop' command")
  serial_nl(port)
}

fn gfx_info(port: Int) -> void {
  fb_info(port)
}
