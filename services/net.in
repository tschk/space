// Network microservice.
// Provides socket-like abstractions over the kernel NIC driver.
// ponytail: stub IPC routing, real NIC driver in kernel/kernel-root.in.
component NetService {
  target "x86_64-unknown-none"
  deterministic false
  checkpoint none

  export svc: NetApi

  capability serial: DebugConsole(write)
}

interface NetApi {
  fn socket(family: Int, type: Int) -> Int
  fn connect(fd: Int, addr: Int) -> Int
  fn send(fd: Int, buf: Int, len: Int) -> Int
  fn recv(fd: Int, buf: Int, len: Int) -> Int
}

// ponytail: stub socket table. Real impl uses driver-managed connection table.
var net_sockets: Int = 0
var net_socket_count: Int = 0

fn n_put(port: Int, ch: Int) -> void {
  while (load8(port + 5) & 0x20) == 0 { }
  outb(port, ch)
  return
}

fn n_puts(port: Int, addr: Int) -> void {
  let i = 0
  while load8(addr + i) != 0 {
    n_put(port, load8(addr + i))
    i = i + 1
  }
  return
}

fn net_socket(family: Int, type: Int) -> Int {
  // ponytail: return a fake fd, real impl routes to kernel NIC driver
  let fd = net_socket_count + 1
  net_socket_count = net_socket_count + 1
  return fd
}

fn net_connect(fd: Int, addr: Int) -> Int {
  // ponytail: always succeed, real impl links e1000 descriptor
  return 1
}

fn net_send(fd: Int, buf: Int, len: Int) -> Int {
  // ponytail: drop data, real impl writes to tx ring
  return len
}

fn net_recv(fd: Int, buf: Int, len: Int) -> Int {
  // ponytail: return zero, real impl reads from rx ring
  return 0
}

// Service entry: called by loader with shared_page address.
fn net_entry(shared_page: Int) -> Int {
  let page = shared_page
  let port = 0x3F8

  n_puts(port, "    [net.in] network service started")
  n_put(port, 10)

  while true {
    // Wait for a request (head != tail)
    while load64(page + 0) == load64(page + 8) { }

    let opcode = load64(page + 32)
    let arg1 = load64(page + 40)
    let arg2 = load64(page + 48)
    let arg3 = load64(page + 56)
    let result = 0

    if opcode == 1 {
      // socket(family, type)
      result = net_socket(arg1, arg2)
    } else if opcode == 2 {
      // connect(fd, addr)
      result = net_connect(arg1, arg2)
    } else if opcode == 3 {
      // send(fd, buf, len)
      result = net_send(arg1, arg2, arg3)
    } else if opcode == 4 {
      // recv(fd, buf, len)
      result = net_recv(arg1, arg2, arg3)
    } else {
      result = -1
    }

    store64(page + 4096, result)
    store64(page + 8, load64(page + 8) + 1)
  }

  return 0
}
